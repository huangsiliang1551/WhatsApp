APP_NAME=WhatsApp Support Platform
APP_ENV=development
LOG_LEVEL=INFO
TEST_MODE=false
AUTH_REQUIRED=true

POSTGRES_USER=whatsapp_user
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=whatsapp_bot
DATABASE_URL=postgresql://whatsapp_user:secure_password@postgres:5432/whatsapp_bot
REDIS_URL=redis://redis:6379/0
QUEUE_REDIS_URL=redis://redis:6379/1
QUEUE_PROVIDER=redis
QUEUE_DEFAULT_TIMEOUT=30
QUEUE_MAX_RETRIES=3
QUEUE_POLL_TIMEOUT_SECONDS=5
MEDIA_STORAGE_ROOT=storage/media-assets
TASK_PROOF_STORAGE_ROOT=storage/task-proofs

AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_CONFIG_CACHE_TTL_SECONDS=60
AI_CONFIG_DB_ENABLED=true
AI_CONTEXT_MAX_MESSAGES=10
AI_CONTEXT_MAX_HISTORY_CHARS=2000
AI_CONTEXT_MAX_MESSAGE_CHARS=500
AI_CONTEXT_MAX_TOTAL_CHARS=4000
AI_QUALITY_CHECK_ENABLED=true
AI_QUALITY_REJECT_THRESHOLD=0.3

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

MESSAGING_PROVIDER=mock
META_MANAGEMENT_PROVIDER=
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_BASE=https://graph.facebook.com
META_GRAPH_API_VERSION=v20.0
META_WEBHOOK_SUBSCRIBED_FIELDS=messages,message_template_status_update,message_template_quality_update,phone_number_quality_update,phone_number_name_update,phone_number_status_update
META_GLOBAL_WEBHOOK_CALLBACK_URL=
META_GLOBAL_WEBHOOK_VERIFY_TOKEN=
TEMPLATE_REGISTRY_PROVIDER=
MESSAGING_REQUEST_TIMEOUT_SECONDS=30
ECOMMERCE_PROVIDER=mock
ECOMMERCE_REQUEST_TIMEOUT_SECONDS=15
WEBHOOK_SIGNATURE_ENABLED=true

# Leave TRANSLATION_PROVIDER empty to follow AI_PROVIDER.
# Translation stays assistive by default: no auto conversation translation,
# but operator outbound translation remains available.
TRANSLATION_PROVIDER=
LIVE_TRANSLATION_ENABLED=true
CONSOLE_LANGUAGE=zh-CN
AUTO_TRANSLATE_ON_HUMAN_HANDOVER=false
AUTO_TRANSLATE_ON_CONVERSATION_OPEN=false
AUTO_TRANSLATE_OPERATOR_OUTBOUND=true
LLM_REQUEST_TIMEOUT_SECONDS=30

# ==============================
# H5 Member Session
# ==============================
H5_MEMBER_SESSION_COOKIE_NAME=h5_member_session
H5_MEMBER_SESSION_TTL_HOURS=12
H5_MEMBER_REFRESH_COOKIE_NAME=h5_member_refresh
H5_MEMBER_REFRESH_TTL_DAYS=30
H5_MEMBER_COOKIE_SECURE=false
H5_MEMBER_COOKIE_DOMAIN=
H5_MEMBER_COOKIE_SAMESITE=lax
H5_MEMBER_MAX_SESSIONS_PER_USER=5
H5_MEMBER_LOGIN_LOCKOUT_THRESHOLD=5
H5_MEMBER_LOGIN_LOCKOUT_MINUTES=15
H5_MEMBER_ORDER_CACHE_TTL_SECONDS=300
H5_MEMBER_LOGISTICS_CACHE_TTL_SECONDS=600
WHATSAPP_AUTH_SESSION_TTL_MINUTES=15
WHATSAPP_AUTO_BIND_INVITE_TTL_MINUTES=30
WHATSAPP_PHONE_POOL_REBALANCE_ENABLED=true
WHATSAPP_UNBOUND_MESSAGE_REPLY_TEXT=Please complete WhatsApp binding before continuing.

# ==============================
# Conversation Runtime
# ==============================
SLA_WARNING_SECONDS=300
SLA_CRITICAL_SECONDS=600
SLEEPING_SCAN_INTERVAL_SECONDS=900
SLEEPING_THRESHOLD_HOURS=48

# ==============================
# H5 Gateway / Templates
# ==============================
TEMPLATE_STATIC_ROOT=/opt/whatsapp/static/templates
TEMPLATE_UPLOAD_ROOT=/opt/whatsapp/uploads/templates
H5_GATEWAY_DRY_RUN=true
H5_GATEWAY_AGENT_SHARED_SECRET=
H5_GATEWAY_ALLOWED_JOB_TYPES=test_ssh,bootstrap,install_agent,deploy_frontend,sync_config,issue_cert,renew_cert,reload_nginx,security_hardening,block_domain,unblock_domain,health_check,rollback
H5_GATEWAY_SCRIPT_ROOT=deploy/h5-gateway/scripts
H5_GATEWAY_PULL_INTERVAL_SECONDS=15

# ==============================
# Deployment / Infra
# ==============================
DNS_PROVIDER=dry_run
CDN_PROVIDER=dry_run
HEALTH_CHECK_INTERVAL_MINUTES=60
BACKUP_DIR=/opt/whatsapp/backups
PRODUCTION_GUARD_STRICT=false
SECRET_ENCRYPTION_KEY=
GENERIC_HMAC_PAYMENT_SECRET=
GENERIC_HMAC_PAYMENT_WINDOW_SECONDS=300

# ==============================
# Grafana
# ==============================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==============================
# Alerting
# ==============================
# Webhook URL for alert notifications (DingTalk / WeCom / Slack)
ALERT_WEBHOOK_URL=
# Queue backlog alert threshold
QUEUE_LENGTH_ALERT_THRESHOLD=500
# Error rate alert threshold (percentage)
ERROR_RATE_ALERT_THRESHOLD=10

# Frontend H5 member prototype
# Vite dev server proxies /api requests to the local FastAPI backend by default.
# Override the backend target only when your API is not running on 127.0.0.1:8000.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# Leave empty in development to auto-enable local prototype fallback when the
# member auth API is unavailable or returns HTML. Set true/false to force behavior.
VITE_H5_MEMBER_LEGACY_FALLBACK=

# Legacy single-account fallback only.
# Formal multi-account rollout should persist Meta credentials and phone scopes
# through /api/meta/accounts and the WABA/Phone Number registry instead.
WA_PHONE_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=
WA_APP_SECRET=
WA_BUSINESS_ACCOUNT_ID=

# ==============================
# Admin JWT Authentication
# ==============================
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_ACCESS_TOKEN_TTL_MINUTES=120
ADMIN_REFRESH_TOKEN_TTL_DAYS=7
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# ==============================
# CORS
# ==============================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_ENABLED=true

# ==============================
# Database Connection Pool
# ==============================
# 当前容器配置：pool_size=5 + overflow=10 = 最多 15 连接（与 max_connections=30 匹配）
# 生产环境建议：DB_POOL_SIZE=80, DB_MAX_OVERFLOW=50
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ==============================
# Uvicorn Workers
# ==============================
# 生产环境建议设为 CPU 核数 × 2 + 1（如 8 核设 17）
UVICORN_WORKERS=4

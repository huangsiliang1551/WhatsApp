import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  Row,
  Select,
  Space,
  Statistic,
  Tag,
  Typography,
} from "antd";

import {
  createSupportKnowledgeEntry,
  deleteSupportKnowledgeEntry,
  exportSupportKnowledge,
  getConversationAiStatus,
  getRuntimeConfigSummary,
  importSupportKnowledge,
  listRuntimeState,
  listSupportKnowledge,
  setAccountAiEnabled,
  setConversationAiEnabled,
  setGlobalAiEnabled,
  updateSupportKnowledgeEntry,
  type ConversationAiStatus,
  type RuntimeConfigSummary,
  type RuntimeConversationState,
  type RuntimeState,
  type SupportKnowledgeEntryCreatePayload,
  type SupportKnowledgeEntryView,
  type SupportKnowledgeImportResult,
} from "../services/api";
import { useAppStore } from "../stores/appStore";

type KnowledgeFilters = {
  accountId: string;
  category: string;
  sourceType: "all" | "builtin" | "database";
  search: string;
};

type KnowledgeEditorValues = {
  account_id: string;
  article_id: string;
  route_name: string;
  category: string;
  title: string;
  answer: string;
  source_language: string;
  keywords_text: string;
  minimum_score: number;
  priority: number;
  is_active: boolean;
};

function formatBool(value: boolean): string {
  return value ? "�€�? : "�����";
}

function formatSourceType(value: string): string {
  if (value === "builtin") return "����";
  if (value === "database") return "数据�?;
  return value;
}

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function getConversationKey(conversation: RuntimeConversationState): string {
  return `${conversation.account_id}:${conversation.conversation_id}`;
}

function parseKeywords(value: string): string[] {
  return value
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);
}

function stringifyKeywords(values: string[]): string {
  return values.join(", ");
}

function buildKnowledgeDraft(entry?: SupportKnowledgeEntryView): KnowledgeEditorValues {
  if (!entry) {
    return {
      account_id: "",
      article_id: "",
      route_name: "",
      category: "faq",
      title: "",
      answer: "",
      source_language: "zh-CN",
      keywords_text: "",
      minimum_score: 1,
      priority: 100,
      is_active: true,
    };
  }

  return {
    account_id: entry.account_id ?? "",
    article_id: entry.article_id,
    route_name: entry.route_name,
    category: entry.category,
    title: entry.title,
    answer: entry.answer,
    source_language: entry.source_language,
    keywords_text: stringifyKeywords(entry.keywords),
    minimum_score: entry.minimum_score,
    priority: entry.priority,
    is_active: entry.is_active,
  };
}

function formatAiReason(status: ConversationAiStatus | null): string {
  if (!status) return "����";
  if (status.effective_ai_enabled) return "�€����������AI ����?;
  if (status.primary_blocking_reason) return `�€����������AI �������������${status.primary_blocking_reason.message}`;
  if (status.blocking_reasons.length > 0) return `�€����������AI �������������${status.blocking_reasons[0].message}`;
  return "�€����������AI ���";
}

export function SettingsPage(): JSX.Element {
  const settingsPagePrefill = useAppStore((state) => state.settingsPagePrefill);
  const clearSettingsPagePrefill = useAppStore((state) => state.clearSettingsPagePrefill);
  const setSettingsPagePrefill = useAppStore((state) => state.setSettingsPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);
  const [runtimeState, setRuntimeState] = useState<RuntimeState | null>(null);
  const [configSummary, setConfigSummary] = useState<RuntimeConfigSummary | null>(null);
  const [supportKnowledge, setSupportKnowledge] = useState<SupportKnowledgeEntryView[]>([]);
  const [filters, setFilters] = useState<KnowledgeFilters>({
    accountId: "all",
    category: "all",
    sourceType: "all",
    search: "",
  });
  const [selectedConversationKey, setSelectedConversationKey] = useState<string>("");
  const [conversationAiStatus, setConversationAiStatus] = useState<ConversationAiStatus | null>(null);
  const [editingKey, setEditingKey] = useState<string | null>(null);
  const [knowledgeDraft, setKnowledgeDraft] = useState<KnowledgeEditorValues>(buildKnowledgeDraft());
  const [transferPayload, setTransferPayload] = useState("");
  const [transferTargetAccountId, setTransferTargetAccountId] = useState("");
  const [transferUpsert, setTransferUpsert] = useState(true);
  const [transferResult, setTransferResult] = useState<SupportKnowledgeImportResult | null>(null);
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const [conversationSelectionLocked, setConversationSelectionLocked] = useState(false);

  const accountOptions = useMemo(() => {
    const values = new Set<string>();
    runtimeState?.accounts.forEach((item) => values.add(item.account_id));
    supportKnowledge.forEach((item) => {
      if (item.account_id) values.add(item.account_id);
    });
    return Array.from(values).sort();
  }, [runtimeState, supportKnowledge]);

  const conversationOptions = useMemo(() => {
    return (runtimeState?.conversations ?? []).map((item) => ({
      label: `${item.account_id} / ${item.conversation_id} / ${item.management_mode}`,
      value: getConversationKey(item),
    }));
  }, [runtimeState]);

  const selectedConversation = useMemo(
    () =>
      (runtimeState?.conversations ?? []).find((item) => getConversationKey(item) === selectedConversationKey) ??
      null,
    [runtimeState, selectedConversationKey]
  );

  const filteredKnowledge = useMemo(() => {
    const normalizedSearch = filters.search.trim().toLowerCase();
    return supportKnowledge.filter((entry) => {
      if (filters.accountId !== "all" && (entry.account_id ?? "builtin") !== filters.accountId) return false;
      if (filters.category !== "all" && entry.category !== filters.category) return false;
      if (filters.sourceType !== "all" && entry.source_type !== filters.sourceType) return false;
      if (!normalizedSearch) return true;

      return [
        entry.article_id,
        entry.route_name,
        entry.title,
        entry.answer,
        entry.account_id ?? "",
        ...entry.keywords,
      ]
        .join(" ")
        .toLowerCase()
        .includes(normalizedSearch);
    });
  }, [filters, supportKnowledge]);

  useEffect(() => {
    void refreshData();
  }, []);

  useEffect(() => {
    if (!settingsPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === settingsPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = settingsPagePrefill.nonce;
    setFilters({
      accountId: settingsPagePrefill.account_id ?? "all",
      category: settingsPagePrefill.category ?? "all",
      sourceType: settingsPagePrefill.source_type ?? "all",
      search: settingsPagePrefill.search ?? "",
    });
    setConversationSelectionLocked(Boolean(settingsPagePrefill.selected_conversation_key));
    setSelectedConversationKey(settingsPagePrefill.selected_conversation_key ?? "");
    clearSettingsPagePrefill();
  }, [clearSettingsPagePrefill, settingsPagePrefill]);

  useEffect(() => {
    if (!conversationOptions.length) {
      if (!conversationSelectionLocked) {
        setSelectedConversationKey("");
      }
      setConversationAiStatus(null);
      return;
    }
    if (selectedConversationKey && conversationOptions.some((item) => item.value === selectedConversationKey)) {
      return;
    }
    if (conversationSelectionLocked && selectedConversationKey) {
      return;
    }
    setSelectedConversationKey(conversationOptions[0].value);
  }, [conversationOptions, conversationSelectionLocked, selectedConversationKey]);

  useEffect(() => {
    if (!selectedConversation) {
      setConversationAiStatus(null);
      return;
    }
    void refreshConversationAiStatus(selectedConversation.account_id, selectedConversation.conversation_id);
  }, [selectedConversation?.account_id, selectedConversation?.conversation_id]);

  // �����������������������������������������������������������������������

  async function refreshData(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      const [nextRuntimeState, nextConfigSummary, nextSupportKnowledge] = await Promise.all([
        listRuntimeState(),
        getRuntimeConfigSummary(),
        listSupportKnowledge(),
      ]);
      setRuntimeState(nextRuntimeState);
      setConfigSummary(nextConfigSummary);
      setSupportKnowledge(nextSupportKnowledge);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "设置ҳ加载ʧ�?);
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function refreshConversationAiStatus(accountId: string, conversationId: string): Promise<void> {
    try {
      const next = await getConversationAiStatus(accountId, conversationId);
      setConversationAiStatus(next);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "����� AI ���€����������?);
      setConversationAiStatus(null);
    }
  }

  async function handleToggleGlobalAi(): Promise<void> {
    if (!runtimeState) return;
    setPendingAction("global-ai");
    setError(null);
    try {
      const nextState = await setGlobalAiEnabled({ enabled: !runtimeState.global_ai_enabled });
      setRuntimeState(nextState);
      setNotice(nextState.global_ai_enabled ? "ȫ局 AI 已开�? : "ȫ局 AI 已关�?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "����ȫ�� AI ʧ��");
      setPendingAction(null);
    }
  }

  async function handleToggleAccountAi(accountId: string, enabled: boolean): Promise<void> {
    setPendingAction(`account-ai:${accountId}`);
    setError(null);
    try {
      await setAccountAiEnabled(accountId, { enabled: !enabled });
      await refreshData();
      setNotice(`���� ${accountId} AI ������`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������� AI ʧ��");
      setPendingAction(null);
    }
  }

  async function handleToggleConversationAi(): Promise<void> {
    if (!selectedConversation) return;
    setPendingAction("conversation-ai");
    setError(null);
    try {
      await setConversationAiEnabled(selectedConversation.account_id, selectedConversation.conversation_id, {
        enabled: !selectedConversation.ai_enabled,
      });
      await refreshData();
      await refreshConversationAiStatus(selectedConversation.account_id, selectedConversation.conversation_id);
      setNotice("会话 AI 已更�?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������� AI ʧ��");
      setPendingAction(null);
    }
  }

  async function handleCreateKnowledge(values: KnowledgeEditorValues): Promise<void> {
    setPendingAction("knowledge-create");
    setError(null);
    try {
      const payload: SupportKnowledgeEntryCreatePayload = {
        account_id: values.account_id.trim(),
        article_id: values.article_id.trim(),
        route_name: values.route_name.trim(),
        category: values.category,
        title: values.title.trim(),
        answer: values.answer.trim(),
        source_language: values.source_language.trim(),
        keywords: parseKeywords(values.keywords_text),
        minimum_score: Number(values.minimum_score),
        priority: Number(values.priority),
        is_active: values.is_active,
      };
      await createSupportKnowledgeEntry(payload);
      await refreshData();
      setKnowledgeDraft(buildKnowledgeDraft());
      setNotice("������������������");
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������������?);
      setPendingAction(null);
    }
  }

  async function handleUpdateKnowledge(values: KnowledgeEditorValues): Promise<void> {
    if (!editingKey) return;
    const [accountId, articleId] = editingKey.split("::");
    setPendingAction("knowledge-update");
    setError(null);
    try {
      await updateSupportKnowledgeEntry(articleId, accountId, {
        route_name: values.route_name.trim(),
        category: values.category,
        title: values.title.trim(),
        answer: values.answer.trim(),
        source_language: values.source_language.trim(),
        keywords: parseKeywords(values.keywords_text),
        minimum_score: Number(values.minimum_score),
        priority: Number(values.priority),
        is_active: values.is_active,
      });
      await refreshData();
      setNotice("������������������");
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������������?);
      setPendingAction(null);
    }
  }

  async function handleDeleteKnowledge(entry: SupportKnowledgeEntryView): Promise<void> {
    if (!entry.account_id) return;
    setPendingAction(`knowledge-delete:${entry.article_id}`);
    setError(null);
    try {
      await deleteSupportKnowledgeEntry(entry.article_id, entry.account_id);
      await refreshData();
      if (editingKey === `${entry.account_id}::${entry.article_id}`) {
        setEditingKey(null);
      }
      setNotice("������������������");
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������������?);
      setPendingAction(null);
    }
  }

  async function handleToggleKnowledge(entry: SupportKnowledgeEntryView): Promise<void> {
    if (!entry.account_id || entry.source_type !== "database") return;
    setPendingAction(`knowledge-toggle:${entry.article_id}`);
    setError(null);
    try {
      await updateSupportKnowledgeEntry(entry.article_id, entry.account_id, { is_active: !entry.is_active });
      await refreshData();
      setNotice("֪ʶ����ͣ״̬������");
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "更新֪ʶ库״̬ʧ�?);
      setPendingAction(null);
    }
  }

  async function handleExportKnowledge(): Promise<void> {
    setPendingAction("knowledge-export");
    setError(null);
    try {
      const bundle = await exportSupportKnowledge(filters.accountId !== "all" ? filters.accountId : undefined);
      setTransferPayload(JSON.stringify(bundle, null, 2));
      setNotice(`����?${bundle.total_entries} ���������������`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "导出֪ʶ库ʧ�?);
      setPendingAction(null);
    }
  }

  async function handleImportKnowledge(): Promise<void> {
    setPendingAction("knowledge-import");
    setError(null);
    try {
      const parsed = JSON.parse(transferPayload) as { entries?: SupportKnowledgeEntryCreatePayload[] } | SupportKnowledgeEntryCreatePayload[];
      const entries = Array.isArray(parsed) ? parsed : parsed.entries ?? [];
      const result = await importSupportKnowledge({
        target_account_id: transferTargetAccountId.trim() || undefined,
        upsert_existing: transferUpsert,
        entries,
      });
      setTransferResult(result);
      await refreshData();
      setNotice("����������������");
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "导入֪ʶ库ʧ�?);
      setPendingAction(null);
    }
  }

  const knowledgeColumns: ProColumns<SupportKnowledgeEntryView>[] = [
    {
      title: "��Ŀ",
      key: "entry",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.title}</Typography.Text>
          <Typography.Text type="secondary">{`${record.account_id ?? "builtin"} / ${record.article_id}`}</Typography.Text>
        </Space>
      ),
    },
    { title: "route_name", dataIndex: "route_name" },
    { title: "category", dataIndex: "category" },
    {
      title: "��Դ",
      render: (_, record) => (
        <Space size={[6, 6]} wrap>
          <Tag>{formatSourceType(record.source_type)}</Tag>
          <Tag color={record.is_active ? "success" : "default"}>
            {record.is_active ? "���" : "�����"}
          </Tag>
        </Space>
      ),
    },
    {
      title: "����",
      render: (_, record) =>
        record.account_id && record.source_type === "database" ? (
          <Space size={[8, 8]} wrap>
            <Button
              size="small"
              onClick={() => {
                setEditingKey(`${record.account_id}::${record.article_id}`);
                setKnowledgeDraft(buildKnowledgeDraft(record));
              }}
            >
              ����
            </Button>
            <Button size="small" onClick={() => void handleToggleKnowledge(record)}>
              {record.is_active ? "�����" : "���"}
            </Button>
            <Button danger size="small" onClick={() => void handleDeleteKnowledge(record)}>
              ɾ��
            </Button>
          </Space>
        ) : (
          <Typography.Text type="secondary">�</Typography.Text>
        ),
    },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      
      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title="ȫ�� AI"
              value={runtimeState?.global_ai_enabled ? "�€�? : "�����"}
            />
            <Button
              block
              loading={pendingAction === "global-ai"}
              onClick={() => void handleToggleGlobalAi()}
              type="primary"
            >
              {runtimeState?.global_ai_enabled ? "���������� AI" : "�€����€ AI"}
            </Button>
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title="��Ϣͨ��"
              value={configSummary?.messaging_provider ?? "����"}
            />
            <Typography.Text type="secondary">
              {configSummary?.test_mode ? "����ģʽ" : "����ģʽ"}
            </Typography.Text>
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="AI ͨ��" value={configSummary?.ai_provider ?? "����"} />
            <Typography.Text type="secondary">
              {`OpenAI ${formatBool(configSummary?.openai_configured ?? false)} / DeepSeek ${formatBool(configSummary?.deepseek_configured ?? false)}`}
            </Typography.Text>
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="֪ʶ库条�? value={supportKnowledge.length} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={10} xs={24}>
          <Card title="��������">
            <Descriptions bordered column={1} size="small">
              <Descriptions.Item label="�">{configSummary?.app_env ?? "�����"}</Descriptions.Item>
              <Descriptions.Item label="��������">{configSummary?.queue_backend ?? "�����"}</Descriptions.Item>
              <Descriptions.Item label="AI ģ��">{configSummary?.ai_model ?? "����"}</Descriptions.Item>
              <Descriptions.Item label="����ͨ��">
                {configSummary?.translation_provider ?? "����"}
              </Descriptions.Item>
              <Descriptions.Item label="ʵʱ����">
                {formatBool(configSummary?.live_translation_enabled ?? false)}
              </Descriptions.Item>
              <Descriptions.Item label="���������€">
                {configSummary?.console_language ?? "����"}
              </Descriptions.Item>
              <Descriptions.Item label="������������?>
                {formatBool(configSummary?.auto_translate_to_console ?? false)}
              </Descriptions.Item>
              <Descriptions.Item label="�������������">
                {formatBool(configSummary?.auto_translate_outbound ?? false)}
              </Descriptions.Item>
            </Descriptions>
          </Card>
        </Col>

        <Col lg={14} xs={24}>
          <Card title="账号�?AI">
            <ProTable
              columns={[
                {
                  title: "����",
                  render: (_, record: RuntimeState["accounts"][number]) => (
                    <Space direction="vertical" size={0}>
                      <Typography.Text strong>{record.display_name}</Typography.Text>
                      <Typography.Text type="secondary">{record.account_id}</Typography.Text>
                    </Space>
                  ),
                },
                {
                  title: "���€?,
                  render: (_, record: RuntimeState["accounts"][number]) => (
                    <Space size={[8, 8]} wrap>
                      <Tag color={record.is_active ? "success" : "default"}>
                        {record.is_active ? "��������" : "����������"}
                      </Tag>
                      <Tag color={record.ai_enabled ? "processing" : "default"}>
                        {record.ai_enabled ? "����� AI �€�? : "����� AI �����"}
                      </Tag>
                    </Space>
                  ),
                },
                {
                  title: "����",
                  render: (_, record: RuntimeState["accounts"][number]) => (
                    <Button
                      size="small"
                      loading={pendingAction === `account-ai:${record.account_id}`}
                      onClick={() => void handleToggleAccountAi(record.account_id, record.ai_enabled)}
                    >
                      {record.ai_enabled ? "���������� AI" : "�€����?AI"}
                    </Button>
                  ),
                },
              ]}
              dataSource={runtimeState?.accounts ?? []}
              loading={loading}
              options={false}
              pagination={false}
              rowKey="account_id"
              search={false}
              toolBarRender={false}
            />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={10} xs={24}>
          <Card title="会话�?AI">
            <Space direction="vertical" size={16} style={{ width: "100%" }}>
              <Select
                options={conversationOptions}
                value={selectedConversationKey || undefined}
                onChange={(value) => {
                  setConversationSelectionLocked(false);
                  setSelectedConversationKey(value);
                }}
                placeholder="ѡ������"
              />
              {conversationSelectionLocked && selectedConversationKey && !selectedConversation ? (
                <Alert message="��������������������������€�����? showIcon type="warning" />
              ) : null}
              {selectedConversation ? (
                <>
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="����">{selectedConversation.account_id}</Descriptions.Item>
                    <Descriptions.Item label="����">{selectedConversation.conversation_id}</Descriptions.Item>
                    <Descriptions.Item label="��������">{selectedConversation.management_mode}</Descriptions.Item>
                    <Descriptions.Item label="���� AI">{formatBool(selectedConversation.ai_enabled)}</Descriptions.Item>
                    <Descriptions.Item label="�€������?>{formatAiReason(conversationAiStatus)}</Descriptions.Item>
                  </Descriptions>
                  <Button
                    block
                    loading={pendingAction === "conversation-ai"}
                    onClick={() => void handleToggleConversationAi()}
                    type="primary"
                  >
                    {selectedConversation.ai_enabled ? "���������� AI" : "�€����?AI"}
                  </Button>
                </>
              ) : (
                <Typography.Text type="secondary">暂无会话�?/Typography.Text>
              )}
            </Space>
          </Card>
        </Col>

        <Col lg={14} xs={24}>
          <Card title="֪ʶ库ɸ�?>
            <Space direction="vertical" size={16} style={{ width: "100%" }}>
              <Space size={[12, 12]} wrap>
                <Select
                  style={{ width: 200 }}
                  value={filters.accountId}
                  options={[
                    { label: "ȫ������", value: "all" },
                    { label: "builtin", value: "builtin" },
                    ...accountOptions.map((item) => ({ label: item, value: item })),
                  ]}
                  onChange={(value) => setFilters((current) => ({ ...current, accountId: value }))}
                />
                <Input
                  style={{ width: 180 }}
                  placeholder="����"
                  value={filters.category === "all" ? "" : filters.category}
                  onChange={(event) =>
                    setFilters((current) => ({
                      ...current,
                      category: event.target.value.trim() || "all",
                    }))
                  }
                />
                <Select
                  style={{ width: 180 }}
                  value={filters.sourceType}
                  options={[
                    { label: "ȫ����Դ", value: "all" },
                    { label: "����", value: "builtin" },
                    { label: "数据�?, value: "database" },
                  ]}
                  onChange={(value) => setFilters((current) => ({ ...current, sourceType: value }))}
                />
                <Input.Search
                  style={{ width: 240 }}
                  placeholder="����"
                  value={filters.search}
                  onChange={(event) => setFilters((current) => ({ ...current, search: event.target.value }))}
                />
              </Space>
            </Space>
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<SupportKnowledgeEntryView>
            columns={knowledgeColumns}
            dataSource={filteredKnowledge}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey={(record) => `${record.account_id ?? "builtin"}:${record.article_id}`}
            search={false}
            toolBarRender={false}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title={editingKey ? "编辑֪ʶ库条�? : "新建֪ʶ库条�?}>
              <Form
                layout="vertical"
                initialValues={knowledgeDraft}
                key={editingKey ?? "knowledge-create"}
                onFinish={(values) =>
                  editingKey ? void handleUpdateKnowledge(values) : void handleCreateKnowledge(values)
                }
              >
                <Form.Item label="account_id" name="account_id" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="article_id" name="article_id" rules={[{ required: true }]}>
                  <Input disabled={Boolean(editingKey)} />
                </Form.Item>
                <Form.Item label="route_name" name="route_name" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="category" name="category" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="title" name="title" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="answer" name="answer" rules={[{ required: true }]}>
                  <Input.TextArea rows={4} />
                </Form.Item>
                <Form.Item label="source_language" name="source_language">
                  <Input />
                </Form.Item>
                <Form.Item label="keywords" name="keywords_text">
                  <Input.TextArea rows={2} placeholder="关键�? />
                </Form.Item>
                <Form.Item label="minimum_score" name="minimum_score">
                  <Input type="number" />
                </Form.Item>
                <Form.Item label="priority" name="priority">
                  <Input type="number" />
                </Form.Item>
                <Form.Item label="is_active" name="is_active">
                  <Select
                    options={[
                      { label: "���", value: true },
                      { label: "��ͣ", value: false },
                    ]}
                  />
                </Form.Item>
                <Space size={[8, 8]} wrap>
                  <Button
                    htmlType="submit"
                    loading={pendingAction === "knowledge-create" || pendingAction === "knowledge-update"}
                    type="primary"
                  >
                    {editingKey ? "��������" : "����������"}
                  </Button>
                  {editingKey ? (
                    <Button
                      onClick={() => {
                        setEditingKey(null);
                        setKnowledgeDraft(buildKnowledgeDraft());
                      }}
                    >
                      ȡ������
                    </Button>
                  ) : null}
                </Space>
              </Form>
            </Card>

            <Card title="导入 / 导出֪ʶ�?>
              <Space direction="vertical" size={12} style={{ width: "100%" }}>
                <Space size={[8, 8]} wrap>
                  <Input
                    style={{ width: 220 }}
                    placeholder="account_id"
                    value={transferTargetAccountId}
                    onChange={(event) => setTransferTargetAccountId(event.target.value)}
                  />
                  <Select
                    style={{ width: 180 }}
                    value={transferUpsert}
                    options={[
                      { label: "�?article_id ʱ更�?, value: true },
                      { label: "�?article_id ʱ跳�?, value: false },
                    ]}
                    onChange={setTransferUpsert}
                  />
                </Space>
                <Input.TextArea
                  rows={10}
                  placeholder="JSON"
                  value={transferPayload}
                  onChange={(event) => setTransferPayload(event.target.value)}
                />
                <Space size={[8, 8]} wrap>
                  <Button loading={pendingAction === "knowledge-export"} onClick={() => void handleExportKnowledge()}>
                    ���� JSON
                  </Button>
                  <Button loading={pendingAction === "knowledge-import"} onClick={() => void handleImportKnowledge()} type="primary">
                    ���� JSON
                  </Button>
                </Space>
                {transferResult ? (
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="已创�?>{transferResult.created_count}</Descriptions.Item>
                    <Descriptions.Item label="已更�?>{transferResult.updated_count}</Descriptions.Item>
                    <Descriptions.Item label="已跳�?>{transferResult.skipped_count}</Descriptions.Item>
                    <Descriptions.Item label="������ϸ">
                      <Space direction="vertical" size={4}>
                        {transferResult.items.map((item) => (
                          <Typography.Text key={`${item.account_id}:${item.article_id}`}>
                            {`${item.account_id} / ${item.article_id} / ${item.status} / ${item.detail}`}
                          </Typography.Text>
                        ))}
                      </Space>
                    </Descriptions.Item>
                  </Descriptions>
                ) : null}
              </Space>
            </Card>
          </Space>
        </Col>
      </Row>
    </Space>
  );
}


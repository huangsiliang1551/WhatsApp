                account_id: record.account_id ?? undefined,
                selected_profile_id: record.user_id,
                query: record.public_user_id,
              })
            }
          >
            瀹㈡�?          </Button>
          <Button
            size="small"
            onClick={() =>
              openWorkspacePage({
                accountId: record.account_id ?? undefined,
                search: record.public_user_id,
              })
            }
          >
            ����
          </Button>
        </Space>
      ),
    },
  ];

  const providerColumns = [
    {
      title: "����",
      dataIndex: "account_id",
    },
    {
      title: "ͨ��",
      dataIndex: "provider_name",
    },
    {
      title: "��������€?,
      dataIndex: "external_status",
    },
    {
      title: "����",
      render: (_: unknown, record: OperationsProviderBacklogItem) => (
        <Tag color={record.replay_state === "pending" ? "warning" : "success"}>
          {record.replay_state}
        </Tag>
      ),
    },
    {
      title: "��Ϣ ID",
      dataIndex: "provider_message_id",
      ellipsis: true,
    },
    {
      title: "����ʱ��",
      render: (_: unknown, record: OperationsProviderBacklogItem) => formatTime(record.occurred_at),
    },
    {
      title: "����",
      render: (_: unknown, record: OperationsProviderBacklogItem) => (
        <Space wrap>
          <Button
            size="small"
            loading={pendingAction === `replay:${record.id}`}
            onClick={() => void handleReplayProvider(record)}
            type="primary"
          >
            ����
          </Button>
          <Button
            size="small"
            onClick={() =>
              openProviderEventsPage({
                account_id: record.account_id,
                provider_name: record.provider_name,
                provider_message_id: record.provider_message_id,
                external_status: record.external_status,
                replay_state: "pending",
              })
            }
          >
            ����
          </Button>
        </Space>
      ),
    },
  ];

  const auditColumns = [
    {
      title: "����",
      render: (_: unknown, record: OperationsAuditItem) => record.account_id ?? "ȫ��",
    },
    {
      title: "����",
      dataIndex: "action",
    },
    {
      title: "���",
      render: (_: unknown, record: OperationsAuditItem) => (
        <Space direction="vertical" size={0}>
          <Typography.Text>{record.target_type}</Typography.Text>
          <Typography.Text type="secondary">{record.target_id ?? "-"}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "ʱ��",
      render: (_: unknown, record: OperationsAuditItem) => formatTime(record.created_at),
    },
    {
      title: "����",
      render: (_: unknown, record: OperationsAuditItem) => (
        <Button
          size="small"
          onClick={() =>
            openAuditPage({
              account_id: record.account_id ?? undefined,
              action: record.action,
              target_type: record.target_type,
              target_id: record.target_id ?? undefined,
              limit: 50,
            })
          }
        >
          ���
        </Button>
      ),
    },
  ];

  const batchColumns = [
    {
      title: "����",
      render: (_: unknown, record: OperationsBatchJob) => record.account_id ?? "ȫ��",
    },
    {
      title: "����",
      dataIndex: "name",
    },
    {
      title: "��Χ",
      dataIndex: "target_scope",
    },
    {
      title: "���€?,
      render: (_: unknown, record: OperationsBatchJob) => (
        <Tag color={record.source === "mock" ? "gold" : "default"}>{record.status}</Tag>
      ),
    },
    {
      title: "����",
      dataIndex: "affected_count",
    },
    {
      title: "����ʱ��",
      render: (_: unknown, record: OperationsBatchJob) => formatTime(record.updated_at),

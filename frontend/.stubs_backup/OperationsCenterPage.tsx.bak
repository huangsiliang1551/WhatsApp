  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={accountOptions}
            onChange={setAccountFilter}
          />
          <Radio.Group
            value={timeDimension}
            onChange={(e) => setTimeDimension(e.target.value)}
            optionType="button"
            buttonStyle="solid"
          >
            <Radio.Button value="today">����</Radio.Button>
            <Radio.Button value="week">���</Radio.Button>
            <Radio.Button value="month">���</Radio.Button>
          </Radio.Group>
          <Button
            onClick={() =>
              openProviderEventsPage({
                account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                replay_state: "pending",
              })
            }
          >
            待回�?          </Button>
          <Button onClick={() => setActivePage("tasks")}>
            ��������
          </Button>
          <Button onClick={() => setActivePage("tickets")}>
            ��������
          </Button>
          <Button onClick={() => setActivePage("reviews")}>
            ��������
          </Button>
          <Button
            onClick={() =>
              openAuditPage({
                account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                limit: 50,
              })
            }
          >
            ���
          </Button>
          <Button
            onClick={() =>
              openEvidencePage({
                account_id: accountFilter !== "ALL" ? accountFilter : undefined,
              })
            }
          >
            ��������
          </Button>
          <Button loading={loading} onClick={() => void loadSnapshot()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="���������? value={operationsStats.taskPending} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="���€����" value={operationsStats.taskApproved} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="已拒�? value={operationsStats.taskRejected} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="��Ծ����" value={operationsStats.ticketTotal} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="���������? value={operationsStats.mockWithdrawalPending} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="���������? value={operationsStats.mockWithdrawalProcessed} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="��������" value={snapshot?.queued_jobs ?? 0} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="ʧ������" value={snapshot?.failed_jobs ?? 0} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={24} xs={24}>
          <Card title="�����������" size="small">
            <Space direction="vertical" size={8} style={{ width: "100%" }}>
              {operationsStats.mockAlerts.length === 0 ? (
                <Typography.Text type="secondary">��������</Typography.Text>
              ) : (
                operationsStats.mockAlerts.map((alert, idx) => (
                  <Alert
                    key={idx}
                    message={alert.message}
                    showIcon
                    type={alert.level === "warning" ? "warning" : "info"}
                  />
                ))
              )}
            </Space>
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <Card title="���������?>
            <ProTable<OperationsTaskItem>
              columns={taskColumns}
              dataSource={snapshot?.tasks ?? []}
              loading={loading}
              options={false}
              pagination={{ pageSize: 8 }}
              rowKey="id"
              search={false}
              toolBarRender={false}
            />
          </Card>
        </Col>
        <Col lg={10} xs={24}>
          <Card title="��������">
            <Space direction="vertical" size={16} style={{ width: "100%" }}>
              <Form<BatchJobFormValues>
                form={form}
                layout="vertical"
                onFinish={(values) => void handleCreateBatchJob(values)}
              >
                <Form.Item label="����" name="account_id">
                  <Select
                    allowClear
                    options={actorAccountIds.map((item) => ({ label: item, value: item }))}
                  />
                </Form.Item>
                <Form.Item label="任务�? name="name" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="��������" name="target_scope" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="Ӱ������" name="affected_count" rules={[{ required: true }]}>
                  <Input type="number" />
                </Form.Item>
                <Button htmlType="submit" loading={pendingAction === "batch"} type="primary" block>
                  �������������
                </Button>
              </Form>
            </Space>
          </Card>
        </Col>
      </Row>

      <Card title="��������">
        <Table<OperationsProviderBacklogItem>
          columns={providerColumns}
          dataSource={snapshot?.provider_backlog ?? []}
          loading={loading}
          pagination={false}
          rowKey="id"
          size="small"
        />
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={12} xs={24}>
          <Card title="�€����?>
            <Table<OperationsAuditItem>
              columns={auditColumns}
              dataSource={snapshot?.audit_items ?? []}
              loading={loading}
              pagination={false}
              rowKey="id"
              size="small"
            />
          </Card>
        </Col>
        <Col lg={12} xs={24}>
          <Card title="�€�����������?>
            <Table<OperationsBatchJob>
              columns={batchColumns}
              dataSource={snapshot?.batch_jobs ?? []}
              loading={loading}
              pagination={false}
              rowKey="job_id"
              size="small"
            />
          </Card>
        </Col>
      </Row>
    </Space>
  );
}


import { useEffect, useMemo, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Form,
  Input,
  Radio,
  Row,
  Select,
  Space,
  Statistic,
  Table,
  Tag,
  Typography,
} from "antd";

import {
  claimOperationsTask,
  createOperationsBatchJob,
  getOperationsCenterSnapshot,
  listPlatformUserMemberStatusIndex,
  replayOperationsProviderStatus,
  type PlatformUserMemberStatusSummary,
} from "../services/operations";
import { useAppStore } from "../stores/appStore";
import type {
  OperationsAuditItem,
  OperationsBatchJob,
  OperationsBatchJobCreatePayload,
  OperationsCenterSnapshot,
  OperationsProviderBacklogItem,
  OperationsTaskItem,
} from "../types/operations";

type BatchJobFormValues = {
  account_id?: string;
  name: string;
  target_scope: string;
  affected_count: number;
};

function formatTime(value: string | null | undefined): string {
  if (!value) return "-";
  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? value : date.toLocaleString("zh-CN");
}

function getVerificationStatusColor(status: string): string {
  if (status === "approved") return "success";
  if (status === "rejected") return "error";
  if (status === "submitted" || status === "under_review") return "processing";
  return "default";
}

function getBindingStatusColor(status: string): string {
  if (status === "bound" || status === "approved") return "success";
  if (status === "failed" || status === "rejected") return "error";
  if (status === "submitted" || status === "pending" || status === "verifying") return "processing";
  return "default";
}

export function OperationsCenterPage(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const setActivePage = useAppStore((state) => state.setActivePage);
  const openCustomersPage = useAppStore((state) => state.openCustomersPage);
  const openWorkspacePage = useAppStore((state) => state.openWorkspacePage);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openProviderEventsPage = useAppStore((state) => state.openProviderEventsPage);
  const openEvidencePage = useAppStore((state) => state.openEvidencePage);
  const operationsPagePrefill = useAppStore((state) => state.operationsPagePrefill);
  const clearOperationsPagePrefill = useAppStore((state) => state.clearOperationsPagePrefill);
  const setOperationsPagePrefill = useAppStore((state) => state.setOperationsPagePrefill);

  const [form] = Form.useForm<BatchJobFormValues>();
  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [timeDimension, setTimeDimension] = useState<"today" | "week" | "month">("today");
  const [snapshot, setSnapshot] = useState<OperationsCenterSnapshot | null>(null);
  const [taskMemberStatusIndex, setTaskMemberStatusIndex] = useState<
    Record<string, PlatformUserMemberStatusSummary>
  >({});
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const accountOptions = useMemo(
    () => [
      { label: "ȫ������", value: "ALL" },
      ...actorAccountIds.map((item) => ({ label: item, value: item })),
    ],
    [actorAccountIds]
  );

  // Mock operation stats - computed from snapshot data
  const operationsStats = useMemo(() => {
    const tasks = snapshot?.tasks ?? [];
    const taskPending = tasks.filter((t) => t.status === "pending" || t.status === "open").length;
    const taskApproved = tasks.filter((t) => t.status === "approved").length;
    const taskRejected = tasks.filter((t) => t.status === "rejected").length;
    const ticketTotal = tasks.reduce((sum, t) => sum + t.active_ticket_count, 0);
    // Mock withdrawal stats (no real data source yet)
    const mockWithdrawalPending = 3;
    const mockWithdrawalProcessed = 12;
    // Mock alert summary
    const mockAlerts = [
      { level: "warning" as const, message: "工单处理超ʱ (3 �?" },
      { level: "info" as const, message: "��������€��������� > 5%" },
      { level: "warning" as const, message: "�������� > 50 �? },
    ];
    return { taskPending, taskApproved, taskRejected, ticketTotal, mockWithdrawalPending, mockWithdrawalProcessed, mockAlerts };
  }, [snapshot]);

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!operationsPagePrefill) {
      return;
    }
    setAccountFilter(operationsPagePrefill.account_id ?? "ALL");
    clearOperationsPagePrefill();
  }, [clearOperationsPagePrefill, operationsPagePrefill]);

  useEffect(() => {
    void loadSnapshot();
  }, [accountFilter]);

  useEffect(() => {
    setOperationsPagePrefill({
      account_id: accountFilter,
    });
  }, [accountFilter, setOperationsPagePrefill]);

  async function loadSnapshot(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      const nextSnapshot = await getOperationsCenterSnapshot(
        accountFilter !== "ALL" ? accountFilter : undefined
      );
      const nextStatusIndex = await listPlatformUserMemberStatusIndex(
        nextSnapshot.tasks.map((task) => ({
          id: task.user_id,
          account_id: task.account_id,
          public_user_id: task.public_user_id,
        })),
        accountFilter !== "ALL" ? accountFilter : undefined
      );
      setSnapshot(nextSnapshot);
      setTaskMemberStatusIndex(nextStatusIndex);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "������������������");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleClaimTask(task: OperationsTaskItem): Promise<void> {
    setPendingAction(`claim:${task.id}`);
    setError(null);
    setNotice(null);
    try {
      await claimOperationsTask(task.id);
      setNotice("���������?);
      await loadSnapshot();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������ȡʧ��");
      setPendingAction(null);
    }
  }

  async function handleReplayProvider(item: OperationsProviderBacklogItem): Promise<void> {
    setPendingAction(`replay:${item.id}`);
    setError(null);
    setNotice(null);
    try {
      const result = await replayOperationsProviderStatus(item.replay_payload);
      setNotice(`�������� ${result.replayed_count}`);
      await loadSnapshot();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "���€����������?);
      setPendingAction(null);
    }
  }

  async function handleCreateBatchJob(values: BatchJobFormValues): Promise<void> {
    setPendingAction("batch");
    setError(null);
    setNotice(null);
    try {
      const payload: OperationsBatchJobCreatePayload = {
        account_id: values.account_id?.trim() || null,
        name: values.name.trim(),
        target_scope: values.target_scope.trim(),
        affected_count: Number(values.affected_count),
      };
      await createOperationsBatchJob(payload);
      setNotice("批量任务已加入本地队�?);
      form.resetFields();
      await loadSnapshot();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������ʧ��");
      setPendingAction(null);
    }
  }

  /* const taskMemberStatusColumns: ProColumns<OperationsTaskItem>[] = [
    {
      title: "会员认证",
      key: "member_verification",
      render: (_, record) => {
        const summary = taskMemberStatusIndex[record.user_id];
        if (!summary?.latestVerificationStatus) {
          return <Typography.Text type="secondary">鏆傛�?/Typography.Text>;
        }
        return (
          <Space size={[6, 6]} wrap>
            <Tag color={getVerificationStatusColor(summary.latestVerificationStatus)}>
              {summary.latestVerificationStatus}
            </Tag>
            <Typography.Text type="secondary">{summary.verificationCount} �?/Typography.Text>
          </Space>
        );
      },
    },
    {
      title: "WhatsApp 缁戝�?,
      key: "member_whatsapp_binding",
      render: (_, record) => {
        const summary = taskMemberStatusIndex[record.user_id];
        if (!summary?.latestBindingStatus) {
          return <Typography.Text type="secondary">鏆傛�?/Typography.Text>;
        }
        return (
          <Space size={[6, 6]} wrap>
            <Tag color={getBindingStatusColor(summary.latestBindingStatus)}>
              {summary.latestBindingStatus}
            </Tag>
            <Typography.Text type="secondary">{summary.bindingCount} �?/Typography.Text>
          </Space>
        );
      },
    },
  ];

  ];
  */
  /* const taskMemberStatusColumns: ProColumns<OperationsTaskItem>[] = [
    {
      title: "会员认证",
      key: "member_verification",
      render: (_, record) => {
        const summary = taskMemberStatusIndex[record.user_id];
        if (!summary?.latestVerificationStatus) {
          return <Typography.Text type="secondary">����</Typography.Text>;
        }
        return (
          <Space size={[6, 6]} wrap>
            <Tag color={getVerificationStatusColor(summary.latestVerificationStatus)}>
              {summary.latestVerificationStatus}
            </Tag>
            <Typography.Text type="secondary">{summary.verificationCount} �?/Typography.Text>
          </Space>
        );
      },
    },
    {
      title: "WhatsApp 缁戝�?,
      key: "member_whatsapp_binding",
      render: (_, record) => {
        const summary = taskMemberStatusIndex[record.user_id];
        if (!summary?.latestBindingStatus) {
          return <Typography.Text type="secondary">����</Typography.Text>;
        }
        return (
          <Space size={[6, 6]} wrap>
            <Tag color={getBindingStatusColor(summary.latestBindingStatus)}>
              {summary.latestBindingStatus}
            </Tag>
            <Typography.Text type="secondary">{summary.bindingCount} �?/Typography.Text>
          </Space>
        );
      },
    },
  ];

  ];
  */
  const taskMemberStatusColumns: ProColumns<OperationsTaskItem>[] = [
    {
      title: "Verification",
      key: "member_verification",
      render: (_, record) => {
        const summary = taskMemberStatusIndex[record.user_id];
        if (!summary?.latestVerificationStatus) {
          return <Typography.Text type="secondary">N/A</Typography.Text>;
        }
        return (
          <Space size={[6, 6]} wrap>
            <Tag color={getVerificationStatusColor(summary.latestVerificationStatus)}>
              {summary.latestVerificationStatus}
            </Tag>
            <Typography.Text type="secondary">{summary.verificationCount}x</Typography.Text>
          </Space>
        );
      },
    },
    {
      title: "Binding",
      key: "member_whatsapp_binding",
      render: (_, record) => {
        const summary = taskMemberStatusIndex[record.user_id];
        if (!summary?.latestBindingStatus) {

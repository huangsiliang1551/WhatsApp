import { useEffect, useMemo, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Checkbox,
  Col,
  DatePicker,
  Descriptions,
  Divider,
  Form,
  Input,
  InputNumber,
  List,
  Row,
  Select,
  Space,
  Statistic,
  Table,
  Tag,
  Timeline,
  Typography,
  type TableColumnsType,
} from "antd";

import {
  getEvidenceCenterSnapshot,
  requestEvidenceExport,
  saveEvidenceBundle,
} from "../services/evidenceCenter";
import { useAppStore } from "../stores/appStore";
import type {
  EvidenceBundlePayload,
  EvidenceBundleView,
  EvidenceCenterSnapshot,
  EvidenceCoverageItem,
  EvidenceExportJob,
  EvidenceIncidentItem,
  EvidenceSourceKind,
} from "../types/evidenceCenter";

type BundleFormValues = Omit<EvidenceBundlePayload, "bundle_id" | "account_id">;
type EvidenceSourceFilter = EvidenceSourceKind | "all";

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function getBundleStatusTag(status: EvidenceBundleView["status"]): JSX.Element {
  if (status === "ready") return <Tag color="success">��?/Tag>;
  if (status === "collecting") return <Tag color="processing">采集�?/Tag>;
  return <Tag color="warning">����?/Tag>;
}

function getCoverageTag(result: EvidenceCoverageItem["coverage_result"]): JSX.Element {
  if (result === "healthy") return <Tag color="success">����</Tag>;
  if (result === "warning") return <Tag color="warning">��ע</Tag>;
  return <Tag color="error">����</Tag>;
}

function getExportTag(status: EvidenceExportJob["status"]): JSX.Element {
  if (status === "ready") return <Tag color="success">����</Tag>;
  if (status === "queued") return <Tag color="processing">����</Tag>;
  return <Tag color="error">ʧ��</Tag>;
}

function getIncidentTag(severity: EvidenceIncidentItem["severity"]): JSX.Element {
  if (severity === "critical") return <Tag color="error">��������</Tag>;
  if (severity === "warning") return <Tag color="warning">��ע</Tag>;
  return <Tag color="processing">��¼</Tag>;
}

function getSourceLabel(source: EvidenceSourceKind): string {
  if (source === "audit") return "���";
  if (source === "provider") return "ͨ��";
  if (source === "queue") return "����";
  return "Webhook";
}

function getSourceCount(item: EvidenceCoverageItem, sourceFilter: EvidenceSourceFilter): number {
  if (sourceFilter === "provider") return item.provider_pending_count;
  if (sourceFilter === "queue") return item.failed_job_count;
  if (sourceFilter === "webhook") return item.webhook_issue_count;
  return item.audit_count;
}

function getSourceMetricLabel(sourceFilter: EvidenceSourceFilter): string {
  if (sourceFilter === "provider") return "��������";
  if (sourceFilter === "queue") return "ʧ������";
  if (sourceFilter === "webhook") return "Webhook ����";
  return "��������";
}

export function EvidenceCenterPage(): JSX.Element {
  const [form] = Form.useForm<BundleFormValues>();
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openProviderEventsPage = useAppStore((state) => state.openProviderEventsPage);
  const openSystemLogsPage = useAppStore((state) => state.openSystemLogsPage);
  const openOperationsPage = useAppStore((state) => state.openOperationsPage);
  const evidencePagePrefill = useAppStore((state) => state.evidencePagePrefill);
  const clearEvidencePagePrefill = useAppStore((state) => state.clearEvidencePagePrefill);
  const setEvidencePagePrefill = useAppStore((state) => state.setEvidencePagePrefill);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [sourceFilter, setSourceFilter] = useState<EvidenceSourceFilter>("all");
  const [statusFilter, setStatusFilter] = useState<string>("all");
  const [dateFrom, setDateFrom] = useState<string>("");
  const [dateTo, setDateTo] = useState<string>("");
  const [selectedBundleKeys, setSelectedBundleKeys] = useState<string[]>([]);
  const [snapshot, setSnapshot] = useState<EvidenceCenterSnapshot | null>(null);
  const [selectedBundleId, setSelectedBundleId] = useState<string>("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  useEffect(() => {
    void loadPage();
  }, [accountFilter]);

  useEffect(() => {
    if (!evidencePagePrefill) {
      return;
    }
    setAccountFilter(evidencePagePrefill.account_id ?? "ALL");
    if (evidencePagePrefill.selected_bundle_id) {
      setSelectedBundleId(evidencePagePrefill.selected_bundle_id);
    }
    setSourceFilter(evidencePagePrefill.source_kind ?? "all");
    clearEvidencePagePrefill();
  }, [clearEvidencePagePrefill, evidencePagePrefill, form]);

  useEffect(() => {
    setEvidencePagePrefill({
      account_id: accountFilter !== "ALL" ? accountFilter : undefined,
      selected_bundle_id: selectedBundleId || undefined,
      source_kind: sourceFilter !== "all" ? sourceFilter : undefined,
    });
  }, [accountFilter, selectedBundleId, setEvidencePagePrefill, sourceFilter]);

  const bundles = useMemo(
    () =>
      (snapshot?.bundles ?? []).filter(
        (item) =>
          (sourceFilter === "all" || item.included_sources.includes(sourceFilter)) &&
          (statusFilter === "all" || item.status === statusFilter) &&
          (!dateFrom || item.date_from >= dateFrom) &&
          (!dateTo || item.date_to <= dateTo)
      ),
    [snapshot, sourceFilter, statusFilter, dateFrom, dateTo]
  );
  const selectedBundle = useMemo(
    () => bundles.find((item) => item.bundle_id === selectedBundleId) ?? null,
    [bundles, selectedBundleId]
  );
  const coverageItems = useMemo(
    () =>
      (snapshot?.coverage ?? []).filter(
        (item) => sourceFilter === "all" || getSourceCount(item, sourceFilter) > 0
      ),
    [snapshot, sourceFilter]
  );
  const incidents = useMemo(
    () =>
      (snapshot?.incidents ?? []).filter(
        (item) => sourceFilter === "all" || item.source_kind === sourceFilter
      ),
    [snapshot, sourceFilter]
  );

  useEffect(() => {
    if (!bundles.length) {
      setSelectedBundleId("");
      return;
    }
    if (selectedBundleId && bundles.some((item) => item.bundle_id === selectedBundleId)) {
      return;
    }
    setSelectedBundleId(bundles[0].bundle_id);
  }, [bundles, selectedBundleId]);

  useEffect(() => {
    if (!selectedBundle) {
      form.setFieldsValue({
        name: "",
        scope: accountFilter === "ALL" ? "system" : "account",
        target_ref: accountFilter !== "ALL" ? accountFilter : "",
        date_from: "2026-06-01",
        date_to: "2026-06-11",
        included_sources:
          sourceFilter === "all" ? ["audit", "provider", "queue", "webhook"] : [sourceFilter],
        retention_days: 180,
        effective_reason: "",
      });
      return;
    }

    form.setFieldsValue({
      name: selectedBundle.name,
      scope: selectedBundle.scope,
      target_ref: selectedBundle.target_ref ?? "",
      date_from: selectedBundle.date_from,
      date_to: selectedBundle.date_to,
      included_sources: [...selectedBundle.included_sources],
      retention_days: selectedBundle.retention_days,
      effective_reason: selectedBundle.effective_reason,
    });
  }, [accountFilter, form, selectedBundle, sourceFilter]);

  async function loadPage(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      const nextSnapshot = await getEvidenceCenterSnapshot(
        accountFilter !== "ALL" ? accountFilter : undefined
      );
      setSnapshot(nextSnapshot);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "������������������");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleSaveBundle(values: BundleFormValues): Promise<void> {
    setPendingAction("save-bundle");
    setError(null);
    try {
      const saved = await saveEvidenceBundle({
        bundle_id: selectedBundle?.bundle_id,
        account_id: accountFilter !== "ALL" ? accountFilter : undefined,
        name: values.name,
        scope: values.scope,
        target_ref: values.target_ref,
        date_from: values.date_from,
        date_to: values.date_to,
        included_sources: values.included_sources,
        retention_days: values.retention_days,
        effective_reason: values.effective_reason,
      });
      setSelectedBundleId(saved.bundle_id);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "֤据包保存ʧ�?);
      setPendingAction(null);
    }
  }

  async function handleExport(fileFormat: EvidenceExportJob["file_format"]): Promise<void> {
    if (!selectedBundle) {
      return;
    }
    setPendingAction(`export:${fileFormat}`);
    setError(null);
    try {
      await requestEvidenceExport(selectedBundle.bundle_id, fileFormat);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "����ʧ��");
      setPendingAction(null);
    }
  }

  function openIncident(incident: EvidenceIncidentItem): void {
    if (incident.target_page === "audit") {
      openAuditPage({
        account_id: incident.account_id ?? undefined,
        target_type: incident.target_type ?? undefined,
        target_id: incident.target_id ?? undefined,
        limit: 50,
      });
      return;
    }
    if (incident.target_page === "provider_events") {
      openProviderEventsPage({
        account_id: incident.account_id ?? undefined,
        provider_name: incident.provider_name ?? undefined,
        provider_message_id: incident.provider_message_id ?? undefined,
        replay_state: "pending",
      });
      return;
    }
    if (incident.target_page === "system_logs") {
      openSystemLogsPage({
        account_id: incident.account_id ?? undefined,
        source_kind: incident.source_kind === "webhook" ? "provider" : incident.source_kind,
        selected_log_id: incident.system_log_id ?? incident.incident_id,
        severity: incident.severity,
      });
      return;
    }
    openOperationsPage({
      account_id: incident.account_id ?? undefined,
    });
  }

  const bundleColumns: ProColumns<EvidenceBundleView>[] = [
    {
      title: "֤据�?,
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.name}</Typography.Text>
          <Typography.Text type="secondary">{record.account_id ?? "ȫ��"}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "��Χ",
      render: (_, record) => (
        <Space size={[8, 8]} wrap>
          <Tag>{record.scope.toUpperCase()}</Tag>
          {record.included_sources.map((item) => (
            <Tag key={`${record.bundle_id}:${item}`}>{getSourceLabel(item)}</Tag>
          ))}
        </Space>
      ),
    },
    {
      title: "���� / ����",
      render: (_, record) => `${record.event_count} / ${record.anomaly_count}`,
    },
    {
      title: "���€?,
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          {getBundleStatusTag(record.status)}
          <Typography.Text type="secondary">{record.effective_reason}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "�€����?,
      render: (_, record) => formatTimestamp(record.last_export_at),
    },
  ];

  const coverageColumns: TableColumnsType<EvidenceCoverageItem> = [
    { title: "����", dataIndex: "account_label", key: "account_label" },
    { title: "���", dataIndex: "audit_count", key: "audit_count" },
    { title: "ͨ��", dataIndex: "provider_pending_count", key: "provider_pending_count" },
    { title: "Webhook", dataIndex: "webhook_issue_count", key: "webhook_issue_count" },
    { title: "ʧ������", dataIndex: "failed_job_count", key: "failed_job_count" },
    {
      title: "����",
      key: "coverage_result",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          {getCoverageTag(record.coverage_result)}
          <Typography.Text type="secondary">{record.coverage_reason}</Typography.Text>
        </Space>
      ),
    },
  ];

  const exportColumns: ProColumns<EvidenceExportJob>[] = [
    {
      title: "����",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.file_name}</Typography.Text>
          <Typography.Text type="secondary">{record.account_id ?? "ȫ��"}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "��ʽ",
      dataIndex: "file_format",
    },
    {
      title: "���€?,
      render: (_, record) => getExportTag(record.status),
    },
    {
      title: "条Ŀ�?,
      dataIndex: "item_count",
    },
    {
      title: "����ʱ��",
      render: (_, record) => formatTimestamp(record.requested_at),
    },
  ];

  const exportJobs = useMemo(
    () =>
      (snapshot?.exports ?? []).filter((item) =>
        selectedBundle ? item.bundle_id === selectedBundle.bundle_id : true
      ),
    [selectedBundle, snapshot]
  );

  const sourceMetricValue =
    coverageItems.reduce((sum, item) => sum + getSourceCount(item, sourceFilter), 0);
  const anomalyCount = incidents.length;
  const exportCount = exportJobs.length;

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="success" closable onClose={() => setNotice(null)} /> : null}
      {snapshot?.warnings.map((item) => (
        <Alert key={item} message={item} showIcon type="warning" />
      ))}
      
      <Card>
        <Space direction="vertical" size={12} style={{ width: "100%" }}>
          <Space align="center" size={[12, 12]} wrap>
            <Select
              style={{ width: 220 }}
              value={accountFilter}
              options={[
                { label: "ȫ������", value: "ALL" },
                ...actorAccountIds.map((item) => ({ label: item, value: item })),
              ]}
              onChange={(value) => { setAccountFilter(value); setSelectedBundleKeys([]); }}
            />
            <Select
              style={{ width: 180 }}
              value={sourceFilter}
              options={[
                { label: "ȫ����Դ", value: "all" },
                { label: "���", value: "audit" },
                { label: "ͨ��", value: "provider" },
                { label: "����", value: "queue" },
                { label: "Webhook", value: "webhook" },
              ]}
              onChange={(value) => setSourceFilter(value as EvidenceSourceFilter)}
            />
            <Select
              style={{ width: 120 }}
              value={statusFilter}
              onChange={setStatusFilter}
              options={[
                { label: "��������€?, value: "all" },
                { label: "��?, value: "ready" },
                { label: "采集�?, value: "collecting" },
                { label: "����?, value: "review" },
              ]}
            />
            <DatePicker
              placeholder="�€������?
              onChange={(_, dateStr) => setDateFrom(dateStr as string)}
            />
            <DatePicker
              placeholder="��������"
              onChange={(_, dateStr) => setDateTo(dateStr as string)}
            />
          </Space>
          <Space align="center" size={[12, 12]} wrap>
            <Button
              onClick={() =>
                openAuditPage({
                  account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                  limit: 50,
                })
              }
            >
              ���
            </Button>
            <Button
              onClick={() =>
                openSystemLogsPage({
                  account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                  source_kind:
                    sourceFilter !== "all" && sourceFilter !== "webhook" ? sourceFilter : undefined,
                })
              }
            >
              ϵͳ��־
            </Button>
            <Button
              onClick={() =>
                openProviderEventsPage({
                  account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                  replay_state: "pending",
                })
              }
            >
              Webhook
            </Button>
            <Button
              onClick={() =>
                openOperationsPage({
                  account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                })
              }
            >
              ��������
            </Button>
            <Button loading={loading} onClick={() => void loadPage()} type="primary">
              ˢ��
            </Button>
          </Space>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="֤据�? value={bundles.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title={getSourceMetricLabel(sourceFilter)} value={sourceMetricValue} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="�€������? value={anomalyCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��������" value={exportCount} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={13} xs={24}>
          <Space direction="vertical" size={12} style={{ width: "100%" }}>
            {selectedBundleKeys.length > 0 ? (
              <Card size="small">
                <Space align="center" size={12}>
                  <Typography.Text strong>���€?{selectedBundleKeys.length} �?/Typography.Text>
                  <Button
                    type="primary"
                    size="small"
                    onClick={() => {
                      selectedBundleKeys.forEach((bid) => {
                        const bundle = bundles.find((b) => b.bundle_id === bid);
                        if (bundle) void handleExport("zip");
                      });
                    }}
                  >
                    �������� ZIP
                  </Button>
                  <Button
                    size="small"
                    onClick={() => {
                      setNotice(`�����������? ${selectedBundleKeys.length} ��������`);
                    }}
                  >
                    �������� (CSV)
                  </Button>
                  <Button size="small" onClick={() => setSelectedBundleKeys([])}>
                    ȡ��ѡ��
                  </Button>
                </Space>
              </Card>
            ) : null}
            <ProTable<EvidenceBundleView>
              columns={bundleColumns}
              dataSource={bundles}
              loading={loading}
              options={false}
              pagination={{ pageSize: 6 }}
              rowKey="bundle_id"
              search={false}
              toolBarRender={false}
              rowSelection={{
                selectedRowKeys: selectedBundleKeys,
                onChange: (keys) => setSelectedBundleKeys(keys as string[]),
              }}
              onRow={(record) => ({
                onClick: () => setSelectedBundleId(record.bundle_id),
              })}
            />
          </Space>
        </Col>
        <Col lg={11} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="���������?>
              {selectedBundle ? (
                <Space direction="vertical" size={12} style={{ width: "100%" }}>
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="����">{selectedBundle.account_id ?? "ȫ��"}</Descriptions.Item>
                    <Descriptions.Item label="���€?>
                      <Space direction="vertical" size={4}>
                        {getBundleStatusTag(selectedBundle.status)}
                        <Typography.Text type="secondary">
                          {selectedBundle.effective_reason}
                        </Typography.Text>
                      </Space>
                    </Descriptions.Item>
                    <Descriptions.Item label="ʱ����Χ">
                      {`${selectedBundle.date_from} ~ ${selectedBundle.date_to}`}
                    </Descriptions.Item>
                    <Descriptions.Item label="������€�?>
                      <Tag color={selectedBundle.export_enabled ? "success" : "error"}>
                        {selectedBundle.export_enabled ? "�€�? : "�����"}
                      </Tag>
                    </Descriptions.Item>
                    <Descriptions.Item label="���� / ����">
                      {`${selectedBundle.event_count} / ${selectedBundle.anomaly_count}`}
                    </Descriptions.Item>
                    <Descriptions.Item label="�€����?>
                      {formatTimestamp(selectedBundle.last_export_at)}
                    </Descriptions.Item>
                    <Descriptions.Item label="��������">
                      <Space direction="vertical" size={4}>
                        <Typography.Text>���: {selectedBundle.scope.toUpperCase()} / {selectedBundle.target_ref ?? "�?}</Typography.Text>
                        <Typography.Text type="secondary">��Դ: {selectedBundle.included_sources.map((s) => getSourceLabel(s)).join(", ")}</Typography.Text>
                      </Space>
                    </Descriptions.Item>
                  </Descriptions>
                  <Divider style={{ margin: "8px 0" }} />
                  <Typography.Text strong>������ʷ</Typography.Text>
                  {snapshot?.exports.filter((e) => e.bundle_id === selectedBundle.bundle_id).length ? (
                    <Timeline
                      items={snapshot.exports
                        .filter((e) => e.bundle_id === selectedBundle.bundle_id)
                        .slice(0, 5)
                        .map((e) => ({
                          children: `${e.file_format.toUpperCase()} 导出 �?${e.status === "ready" ? "成功" : e.status}�?{e.item_count} 项）`,
                          color: e.status === "ready" ? "green" : e.status === "failed" ? "red" : "blue",
                        }))}
                    />
                  ) : (
                    <Typography.Text type="secondary">����������ʷ</Typography.Text>
                  )}
                </Space>
              ) : (
                <Typography.Text type="secondary">暂无֤据�?/Typography.Text>
              )}
            </Card>

            <Card title="��������">
              <Form<BundleFormValues> form={form} layout="vertical" onFinish={(values) => void handleSaveBundle(values)}>
                <Form.Item label="����" name="name" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Row gutter={[12, 12]}>
                  <Col md={12} xs={24}>
                    <Form.Item label="��Χ" name="scope" rules={[{ required: true }]}>
                      <Select
                        options={[
                          { label: "ϵͳ", value: "system" },
                          { label: "����", value: "account" },
                          { label: "����", value: "incident" },
                        ]}
                      />
                    </Form.Item>
                  </Col>
                  <Col md={12} xs={24}>
                    <Form.Item label="���" name="target_ref">
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col md={12} xs={24}>
                    <Form.Item label="�€������? name="date_from" rules={[{ required: true }]}>
                      <Input type="date" />
                    </Form.Item>
                  </Col>
                  <Col md={12} xs={24}>
                    <Form.Item label="��������" name="date_to" rules={[{ required: true }]}>
                      <Input type="date" />
                    </Form.Item>
                  </Col>
                  <Col span={24}>
                    <Form.Item label="������Դ" name="included_sources" rules={[{ required: true }]}>
                      <Select
                        mode="multiple"
                        options={[
                          { label: "���", value: "audit" },
                          { label: "ͨ��", value: "provider" },
                          { label: "����", value: "queue" },
                          { label: "Webhook", value: "webhook" },
                        ]}
                      />
                    </Form.Item>
                  </Col>
                  <Col md={8} xs={24}>
                    <Form.Item label="��������" name="retention_days" rules={[{ required: true }]}>
                      <InputNumber min={30} step={30} style={{ width: "100%" }} />
                    </Form.Item>
                  </Col>
                  <Col md={16} xs={24}>
                    <Form.Item label="����ԭ��" name="effective_reason" rules={[{ required: true }]}>
                      <Input />
                    </Form.Item>
                  </Col>
                </Row>
                <Space>
                  <Button htmlType="submit" loading={pendingAction === "save-bundle"} type="primary">
                    ����
                  </Button>
                  <Button
                    disabled={!selectedBundle}
                    loading={pendingAction === "export:zip"}
                    onClick={() => void handleExport("zip")}
                  >
                    ���� ZIP
                  </Button>
                  <Button
                    disabled={!selectedBundle}
                    loading={pendingAction === "export:json"}
                    onClick={() => void handleExport("json")}
                  >
                    ���� JSON
                  </Button>
                  <Button
                    disabled={!selectedBundle}
                    loading={pendingAction === "export:csv"}
                    onClick={() => {
                      if (!selectedBundle) return;
                      setPendingAction("export:csv");
                      setError(null);
                      setTimeout(() => {
                        setNotice(`CSV 清单已生�? ${selectedBundle.name}.csv`);
                        setPendingAction(null);
                      }, 500);
                    }}
                  >
                    ���� CSV
                  </Button>
                </Space>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <Card title="覆盖�?>
            <Table<EvidenceCoverageItem>
              columns={coverageColumns}
              dataSource={coverageItems}
              locale={{ emptyText: "������������" }}
              pagination={false}
              rowKey={(record) => record.account_id ?? "global"}
              size="small"
            />
          </Card>
        </Col>
        <Col lg={10} xs={24}>
          <Card title="�€������?>
            <List<EvidenceIncidentItem>
              dataSource={incidents}
              locale={{ emptyText: "��������" }}
              renderItem={(item) => (
                <List.Item
                  actions={[
                    <Button key={`${item.incident_id}:open`} onClick={() => openIncident(item)} type="link">
                      ����
                    </Button>,
                  ]}
                >
                  <List.Item.Meta
                    description={
                      <Space direction="vertical" size={0}>
                        <Typography.Text>{item.summary}</Typography.Text>
                        <Typography.Text type="secondary">
                          {`${item.account_id ?? "ȫ��"} / ${formatTimestamp(item.occurred_at)}`}
                        </Typography.Text>
                      </Space>
                    }
                    title={
                      <Space size={[8, 8]} wrap>
                        <span>{item.title}</span>
                        {getIncidentTag(item.severity)}
                        <Tag>{getSourceLabel(item.source_kind)}</Tag>
                      </Space>
                    }
                  />
                </List.Item>
              )}
            />
          </Card>
        </Col>
      </Row>

      <Card title="��������">
        <ProTable<EvidenceExportJob>
          columns={exportColumns}
          dataSource={exportJobs}
          loading={loading}
          options={false}
          pagination={{ pageSize: 6 }}
          rowKey="export_id"
          search={false}
          toolBarRender={false}
        />
      </Card>
    </Space>
  );
}


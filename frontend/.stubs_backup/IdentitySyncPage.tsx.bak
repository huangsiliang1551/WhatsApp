import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  InputNumber,
  List,
  Row,
  Select,
  Space,
  Statistic,
  Table,
  Tabs,
  Tag,
  Typography,
  type TableColumnsType,
} from "antd";

import { primaryConsoleRoutes } from "../routes/consoleRoutes";
import {
  getIdentitySyncSnapshot,
  saveIdentityRoleMapping,
  toggleIdentityDomain,
  triggerIdentitySync,
} from "../services/identitySync";
import { useAppStore } from "../stores/appStore";
import type {
  IdentityDomainBinding,
  IdentityMemberPreview,
  IdentityProviderView,
  IdentityRoleMapping,
  IdentityRoleMappingPayload,
  IdentitySessionPreview,
  IdentitySyncJob,
  IdentitySyncSnapshot,
} from "../types/identitySync";

type MappingFormValues = Omit<IdentityRoleMappingPayload, "provider_id" | "account_id">;

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function getProviderName(value: IdentityProviderView["provider_name"]): string {
  if (value === "google") return "Google";
  if (value === "microsoft") return "Microsoft";
  if (value === "okta") return "Okta";
  return "OIDC";
}

function getEffectiveTag(
  result:
    | IdentityProviderView["effective_result"]
    | IdentityRoleMapping["effective_result"]
    | IdentityDomainBinding["effective_result"]
): JSX.Element {
  return result === "enforced" || result === "active" ? (
    <Tag color="success">已生�?/Tag>
  ) : result === "partial" ? (
    <Tag color="processing">������Ч</Tag>
  ) : (
    <Tag color="warning">����?/Tag>
  );
}

function getBindingStatusTag(status: IdentityProviderView["account_binding_status"]): JSX.Element {
  if (status === "linked") return <Tag color="success">已联�?/Tag>;
  if (status === "limited") return <Tag color="warning">����</Tag>;
  return <Tag color="error">ȱʧ</Tag>;
}

function getSessionStatusTag(status: IdentitySessionPreview["status"]): JSX.Element {
  if (status === "active") return <Tag color="success">����</Tag>;
  if (status === "idle") return <Tag color="warning">����</Tag>;
  return <Tag color="default">已下�?/Tag>;
}

function getLoginModeLabel(
  mode: IdentityProviderView["login_mode"] | IdentitySessionPreview["login_mode"]
): string {
  if (mode === "sso") return "��������";
  if (mode === "sso_first") return "�������������";
  if (mode === "password") return "仅密�?;
  return "����";
}

function getJobStatusTag(status: IdentitySyncJob["status"]): JSX.Element {
  if (status === "completed") return <Tag color="success">����</Tag>;
  if (status === "running") return <Tag color="processing">����?/Tag>;
  if (status === "queued") return <Tag color="warning">����</Tag>;
  return <Tag color="error">ʧ��</Tag>;
}

function buildPageScopeOptions(snapshot: IdentitySyncSnapshot | null): string[] {
  const values = new Set<string>();
  primaryConsoleRoutes.forEach((route) => values.add(route.navLabel));
  snapshot?.roles.forEach((role) => role.page_scope.forEach((item) => values.add(item)));
  snapshot?.mappings.forEach((mapping) => mapping.page_scope.forEach((item) => values.add(item)));
  return Array.from(values).sort((left, right) => left.localeCompare(right, "zh-CN"));
}

export function IdentitySyncPage(): JSX.Element {
  const [form] = Form.useForm<MappingFormValues>();
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openRolesPage = useAppStore((state) => state.openRolesPage);
  const openSecuritySettingsPage = useAppStore((state) => state.openSecuritySettingsPage);
  const openMemberAccessPage = useAppStore((state) => state.openMemberAccessPage);
  const openAccessControlPage = useAppStore((state) => state.openAccessControlPage);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const identitySyncPagePrefill = useAppStore((state) => state.identitySyncPagePrefill);
  const clearIdentitySyncPagePrefill = useAppStore((state) => state.clearIdentitySyncPagePrefill);
  const setIdentitySyncPagePrefill = useAppStore((state) => state.setIdentitySyncPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [snapshot, setSnapshot] = useState<IdentitySyncSnapshot | null>(null);
  const [selectedProviderId, setSelectedProviderId] = useState<string>("");
  const [selectedMappingId, setSelectedMappingId] = useState<string>("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const selectedProvider = useMemo(
    () => snapshot?.providers.find((item) => item.provider_id === selectedProviderId) ?? null,
    [selectedProviderId, snapshot]
  );

  const setActivePage = (page: "security_settings" | "member_access" | "access_control"): void => {
    const targetAccount =
      selectedProvider?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined);
    if (page === "security_settings") {
      openSecuritySettingsPage({
        account_id: targetAccount,
      });
      return;
    }
    if (page === "member_access") {
      openMemberAccessPage({
        account_id: targetAccount,
      });
      return;
    }
    openAccessControlPage({
      account_id: targetAccount,
    });
  };

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!identitySyncPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === identitySyncPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = identitySyncPagePrefill.nonce;
    setAccountFilter(identitySyncPagePrefill.account_id ?? "ALL");
    setSelectedProviderId(identitySyncPagePrefill.selected_provider_id ?? "");
    setSelectedMappingId(identitySyncPagePrefill.selected_mapping_id ?? "");
    clearIdentitySyncPagePrefill();
  }, [clearIdentitySyncPagePrefill, identitySyncPagePrefill]);

  useEffect(() => {
    void loadPage();
  }, [accountFilter]);

  useEffect(() => {
    if (!snapshot?.providers.length) {
      setSelectedProviderId("");
      return;
    }
    if (selectedProviderId && snapshot.providers.some((item) => item.provider_id === selectedProviderId)) {
      return;
    }
    setSelectedProviderId(snapshot.providers[0].provider_id);
  }, [selectedProviderId, snapshot]);

  useEffect(() => {
    setIdentitySyncPagePrefill({
      account_id: accountFilter,
      selected_provider_id: selectedProviderId || undefined,
      selected_mapping_id: selectedMappingId || undefined,
    });
  }, [accountFilter, selectedProviderId, selectedMappingId, setIdentitySyncPagePrefill]);

  const selectedMappings = useMemo(
    () => (snapshot?.mappings ?? []).filter((item) => item.provider_id === selectedProviderId),
    [selectedProviderId, snapshot]
  );

  const selectedDomains = useMemo(
    () => (snapshot?.domains ?? []).filter((item) => item.provider_id === selectedProviderId),
    [selectedProviderId, snapshot]
  );

  const selectedJobs = useMemo(
    () => (snapshot?.jobs ?? []).filter((item) => item.provider_id === selectedProviderId).slice(0, 6),
    [selectedProviderId, snapshot]
  );

  const selectedMembers = useMemo(
    () => (snapshot?.members ?? []).filter((item) => item.provider_id === selectedProviderId).slice(0, 6),
    [selectedProviderId, snapshot]
  );

  const selectedSessions = useMemo(
    () => (snapshot?.sessions ?? []).filter((item) => item.provider_id === selectedProviderId).slice(0, 6),
    [selectedProviderId, snapshot]
  );

  const selectedMapping = useMemo(
    () => selectedMappings.find((item) => item.mapping_id === selectedMappingId) ?? null,
    [selectedMappingId, selectedMappings]
  );

  useEffect(() => {
    if (!selectedMappings.length) {
      setSelectedMappingId("");
      form.resetFields();
      return;
    }
    if (selectedMappingId && selectedMappings.some((item) => item.mapping_id === selectedMappingId)) {
      return;
    }
    setSelectedMappingId(selectedMappings[0].mapping_id);
  }, [form, selectedMappingId, selectedMappings]);

  useEffect(() => {
    if (!selectedMapping) {
      form.setFieldsValue({
        external_group: "",
        role_key: undefined,
        account_scope: selectedProvider?.account_id ? [selectedProvider.account_id] : ["ALL"],
        page_scope: [],
        priority: 60,
        effective_reason: "",
      });
      return;
    }
    form.setFieldsValue({
      external_group: selectedMapping.external_group,
      role_key: selectedMapping.role_key,
      account_scope: [...selectedMapping.account_scope],
      page_scope: [...selectedMapping.page_scope],
      priority: selectedMapping.priority,
      effective_reason: selectedMapping.effective_reason,
    });
  }, [form, selectedMapping, selectedProvider]);

  async function loadPage(): Promise<void> {
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      const nextSnapshot = await getIdentitySyncSnapshot(
        accountFilter !== "ALL" ? accountFilter : undefined
      );
      setSnapshot(nextSnapshot);
      setNotice(`已ˢ�?${formatTimestamp(nextSnapshot.generated_at)}`);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "������������������");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleSaveMapping(values: MappingFormValues): Promise<void> {
    if (!selectedProvider) {
      return;
    }
    setPendingAction(`mapping:${selectedProvider.provider_id}`);
    setError(null);
    setNotice(null);
    try {
      await saveIdentityRoleMapping({
        provider_id: selectedProvider.provider_id,
        account_id: selectedProvider.account_id,
        external_group: values.external_group,
        role_key: values.role_key,
        account_scope: values.account_scope,
        page_scope: values.page_scope,
        priority: values.priority,
        effective_reason: values.effective_reason,
      });
      setNotice(`ӳ射已保�?/ ${values.external_group}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "ӳ������ʧ��");
      setPendingAction(null);
    }
  }

  async function handleTriggerSync(providerId: string): Promise<void> {
    setPendingAction(`sync:${providerId}`);
    setError(null);
    setNotice(null);
    try {
      const job = await triggerIdentitySync(providerId);
      setNotice(`������������?/ ${job.summary}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�����������");
      setPendingAction(null);
    }
  }

  async function handleToggleDomain(domainId: string): Promise<void> {
    setPendingAction(`domain:${domainId}`);
    setError(null);
    setNotice(null);
    try {
      const updated = await toggleIdentityDomain(domainId);
      setNotice(`域名已更�?/ ${updated.domain}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������ʧ��");
      setPendingAction(null);
    }
  }

  const accountOptions = useMemo(() => {
    const values = new Set<string>(actorAccountIds);
    snapshot?.providers.forEach((item) => {
      if (item.account_id) values.add(item.account_id);
    });
    snapshot?.mappings.forEach((item) => {
      if (item.account_id) values.add(item.account_id);
    });
    snapshot?.domains.forEach((item) => {
      if (item.account_id) values.add(item.account_id);
    });
    snapshot?.jobs.forEach((item) => {
      if (item.account_id) values.add(item.account_id);
    });
    return [
      { label: "ȫ������", value: "ALL" },
      ...Array.from(values)
        .sort((left, right) => left.localeCompare(right, "zh-CN"))
        .map((item) => ({ label: item, value: item })),
    ];
  }, [actorAccountIds, snapshot]);
  const roleOptions = (snapshot?.roles ?? []).map((role) => ({
    label: role.name,
    value: role.role_key,
  }));
  const pageScopeOptions = buildPageScopeOptions(snapshot);

  const providerColumns: ProColumns<IdentityProviderView>[] = [
    {
      title: "����?,
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{getProviderName(record.provider_name)}</Typography.Text>
          <Typography.Text type="secondary">{record.account_id ?? "ȫ��"}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "��������",
      render: (_, record) => `${record.directory_member_count} / ${record.mapped_member_count}`,
    },
    {
      title: "��ɫӳ��",
      dataIndex: "mapped_role_count",
    },
    {
      title: "��¼",
      render: (_, record) => (
        <Space size={[8, 8]} wrap>
          <Tag>{getLoginModeLabel(record.login_mode)}</Tag>
          <Tag color={record.mfa_required ? "success" : "warning"}>
            {record.mfa_required ? "����������" : "����?}
          </Tag>
        </Space>
      ),
    },
    {
      title: "�€������?,
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          {getEffectiveTag(record.effective_result)}
          <Typography.Text type="secondary">{record.effective_reason}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "�€������?,
      render: (_, record) => formatTimestamp(record.last_sync_at),
    },
    {
      title: "����",
      render: (_, record) => (
        <Button
          loading={pendingAction === `sync:${record.provider_id}`}
          onClick={() => void handleTriggerSync(record.provider_id)}
          size="small"
          type="primary"
        >
          ���
        </Button>
      ),
    },
  ];

  const mappingColumns: ProColumns<IdentityRoleMapping>[] = [
    {
      title: "外部�?/ Claim",
      dataIndex: "external_group",
    },
    {
      title: "��ɫ",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.role_name}</Typography.Text>
          <Typography.Text type="secondary">{record.role_key}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "������Χ",
      render: (_, record) => record.account_scope.join(", "),
    },
    {
      title: "ҳ����Χ",
      render: (_, record) => record.page_scope.join(", ") || "������ɫ",
    },
    {
      title: "����",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          {getEffectiveTag(record.effective_result)}
          <Typography.Text type="secondary">{record.effective_reason}</Typography.Text>
        </Space>
      ),
    },
  ];

  const domainColumns: TableColumnsType<IdentityDomainBinding> = [
    { title: "����", dataIndex: "domain", key: "domain" },
    {
      title: "��֤",
      key: "verified",
      render: (_, record) => (
        <Tag color={record.verified ? "success" : "warning"}>
          {record.verified ? "������? : "����?}
        </Tag>
      ),
    },
    {
      title: "JIT",
      key: "jit_enabled",
      render: (_, record) => (
        <Tag color={record.jit_enabled ? "processing" : "default"}>
          {record.jit_enabled ? "�€�? : "�����"}
        </Tag>
      ),
    },
    {
      title: "��������",
      key: "auto_provision_enabled",
      render: (_, record) => (
        <Tag color={record.auto_provision_enabled ? "success" : "default"}>
          {record.auto_provision_enabled ? "�€�? : "�����"}
        </Tag>
      ),
    },
    {
      title: "����",
      key: "effective_result",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          {getEffectiveTag(record.effective_result)}
          <Typography.Text type="secondary">{record.effective_reason}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "����",
      key: "action",
      render: (_, record) => (
        <Button
          loading={pendingAction === `domain:${record.domain_id}`}
          onClick={() => void handleToggleDomain(record.domain_id)}
          size="small"
        >
          ����
        </Button>
      ),
    },
  ];

  const enabledProviderCount = snapshot?.providers.filter((item) => item.enabled).length ?? 0;
  const ssoPreferredCount =
    snapshot?.providers.filter((item) => item.login_mode === "sso" || item.login_mode === "sso_first")
      .length ?? 0;
  const syncedProviderCount = snapshot?.providers.filter((item) => item.last_sync_at).length ?? 0;
  const mappedMemberCount =
    snapshot?.providers.reduce((sum, item) => sum + item.mapped_member_count, 0) ?? 0;
  const verifiedDomainCount = snapshot?.domains.filter((item) => item.verified).length ?? 0;
  const reviewMappingCount =
    snapshot?.mappings.filter((item) => item.effective_result === "review").length ?? 0;

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      {snapshot?.warnings.map((item) => (
        <Alert key={item} message={item} showIcon type="warning" />
      ))}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            onChange={setAccountFilter}
            options={accountOptions}
            style={{ width: 220 }}
            value={accountFilter}
          />
          <Button onClick={() => setActivePage("security_settings")}>��ȫ����</Button>
          <Button onClick={() => setActivePage("member_access")}>��Ա��Ȩ</Button>
          <Button onClick={() => setActivePage("access_control")}>��������</Button>
          <Button
            onClick={() =>
              openRolesPage({
                account_id:
                  selectedProvider?.account_id ??
                  (accountFilter !== "ALL" ? accountFilter : undefined),
                selected_role_key: selectedMapping?.role_key ?? undefined,
              })
            }
          >
            ��ɫȨ��
          </Button>
          <Button
            onClick={() =>
              openAuditPage({
                account_id:
                  selectedProvider?.account_id ??
                  (accountFilter !== "ALL" ? accountFilter : undefined),
                action: "identity_sync",
                limit: 50,
              })
            }
          >
            ���
          </Button>
          <Button loading={loading} onClick={() => void loadPage()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={8} md={12} xs={24}>
          <Card>
            <Statistic title="����������Դ" value={enabledProviderCount} />
          </Card>
        </Col>
        <Col lg={8} md={12} xs={24}>
          <Card>
            <Statistic title="������������������" value={ssoPreferredCount} />
          </Card>
        </Col>
        <Col lg={8} md={12} xs={24}>
          <Card>
            <Statistic title="�€��������" value={syncedProviderCount} />
          </Card>
        </Col>
        <Col lg={8} md={12} xs={24}>
          <Card>
            <Statistic title="ӳ����Ա" value={mappedMemberCount} />
          </Card>
        </Col>
        <Col lg={8} md={12} xs={24}>
          <Card>
            <Statistic title="已验֤域�? value={verifiedDomainCount} />
          </Card>
        </Col>
        <Col lg={8} md={12} xs={24}>
          <Card>
            <Statistic title="���������? value={reviewMappingCount} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={11} xs={24}>
          <ProTable<IdentityProviderView>
            columns={providerColumns}
            dataSource={snapshot?.providers ?? []}
            loading={loading}
            options={false}
            pagination={{ pageSize: 6 }}
            rowKey="provider_id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => {
                setSelectedProviderId(record.provider_id);
                setSelectedMappingId("");
              },
            })}
          />
        </Col>

        <Col lg={13} xs={24}>
          <Card title="�������? extra={selectedProvider ? <Tag color="cyan">�����</Tag> : null}>
            {selectedProvider ? (
              <Space direction="vertical" size={16} style={{ width: "100%" }}>
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="����?>
                    <Space size={[8, 8]} wrap>
                      <Typography.Text strong>
                        {getProviderName(selectedProvider.provider_name)}
                      </Typography.Text>
                      <Tag color={selectedProvider.enabled ? "success" : "default"}>
                        {selectedProvider.enabled ? "���" : "�����"}
                      </Tag>
                    </Space>
                  </Descriptions.Item>
                  <Descriptions.Item label="����">{selectedProvider.account_id ?? "ȫ��"}</Descriptions.Item>
                  <Descriptions.Item label="��������€?>
                    <Space direction="vertical" size={4}>
                      {getBindingStatusTag(selectedProvider.account_binding_status)}
                      <Typography.Text type="secondary">
                        {selectedProvider.account_binding_reason}
                      </Typography.Text>
                    </Space>
                  </Descriptions.Item>
                  <Descriptions.Item label="�€������?>
                    <Space direction="vertical" size={4}>
                      {getEffectiveTag(selectedProvider.effective_result)}
                      <Typography.Text type="secondary">
                        {selectedProvider.effective_reason}
                      </Typography.Text>
                    </Space>
                  </Descriptions.Item>
                </Descriptions>

                <Tabs
                  items={[
                    {
                      key: "directory",
                      label: "������",
                      children: (
                        <Space direction="vertical" size={16} style={{ width: "100%" }}>
                          <Descriptions bordered column={2} size="small">
                            <Descriptions.Item label="��������">
                              {selectedProvider.directory_member_count}
                            </Descriptions.Item>
                            <Descriptions.Item label="��̨����">
                              {selectedProvider.active_session_count}
                            </Descriptions.Item>
                            <Descriptions.Item label="��ɫӳ��">
                              {selectedProvider.mapped_role_count}
                            </Descriptions.Item>
                            <Descriptions.Item label="�€������?>
                              {formatTimestamp(selectedProvider.last_sync_at)}
                            </Descriptions.Item>
                          </Descriptions>

                          <Table<IdentityDomainBinding>
                            columns={domainColumns}
                            dataSource={selectedDomains}
                            locale={{ emptyText: "������������" }}
                            pagination={false}
                            rowKey="domain_id"
                            size="small"
                          />

                          <List
                            dataSource={selectedJobs}
                            locale={{ emptyText: "�������������" }}
                            renderItem={(item) => (
                              <List.Item>
                                <List.Item.Meta
                                  description={
                                    <Space direction="vertical" size={0}>
                                      <Typography.Text>{item.summary}</Typography.Text>
                                      <Typography.Text type="secondary">
                                        {`${formatTimestamp(item.started_at)} / ���� ${item.imported_count} / ���� ${item.updated_count}`}
                                      </Typography.Text>
                                    </Space>
                                  }
                                  title={
                                    <Space size={[8, 8]} wrap>
                                      {getJobStatusTag(item.status)}
                                      <span>{item.error_count ? `��� ${item.error_count}` : "������?}</span>
                                    </Space>
                                  }
                                />
                              </List.Item>
                            )}
                          />
                        </Space>
                      ),
                    },
                    {
                      key: "mapping",
                      label: "��ɫӳ��",
                      children: (
                        <Space direction="vertical" size={16} style={{ width: "100%" }}>
                          <Form<MappingFormValues>
                            form={form}
                            layout="vertical"
                            onFinish={(values) => void handleSaveMapping(values)}
                          >
                            <Row gutter={[12, 12]}>
                              <Col md={12} xs={24}>
                                <Form.Item
                                  label="外部�?/ Claim"
                                  name="external_group"
                                  rules={[{ required: true }]}
                                >
                                  <Input placeholder="��� wa-admins" />
                                </Form.Item>
                              </Col>
                              <Col md={12} xs={24}>
                                <Form.Item label="��ɫ" name="role_key" rules={[{ required: true }]}>
                                  <Select options={roleOptions} placeholder="ѡ����ɫ" />
                                </Form.Item>
                              </Col>
                              <Col md={12} xs={24}>
                                <Form.Item label="������Χ" name="account_scope">
                                  <Select
                                    mode="multiple"
                                    options={
                                      selectedProvider.account_id
                                        ? [{ label: selectedProvider.account_id, value: selectedProvider.account_id }]
                                        : [{ label: "ALL", value: "ALL" }, ...actorAccountIds.map((item) => ({ label: item, value: item }))]
                                    }
                                  />
                                </Form.Item>
                              </Col>
                              <Col md={12} xs={24}>
                                <Form.Item label="ҳ����Χ" name="page_scope">
                                  <Select
                                    mode="multiple"
                                    options={pageScopeOptions.map((item) => ({ label: item, value: item }))}
                                    placeholder="����������ɫ"
                                  />
                                </Form.Item>
                              </Col>
                              <Col md={8} xs={24}>
                                <Form.Item label="优先�? name="priority" rules={[{ required: true }]}>
                                  <InputNumber min={1} max={999} style={{ width: "100%" }} />
                                </Form.Item>
                              </Col>
                              <Col md={16} xs={24}>
                                <Form.Item
                                  label="����ԭ��"
                                  name="effective_reason"
                                  rules={[{ required: true }]}
                                >
                                  <Input />
                                </Form.Item>
                              </Col>
                            </Row>
                            <Space>
                              <Button
                                onClick={() => {
                                  setSelectedMappingId("");
                                  form.resetFields();
                                }}
                              >
                                ����
                              </Button>
                              <Button
                                htmlType="submit"
                                loading={pendingAction === `mapping:${selectedProvider.provider_id}`}
                                type="primary"
                              >
                                ����ӳ��
                              </Button>
                            </Space>
                          </Form>

                          <ProTable<IdentityRoleMapping>
                            columns={mappingColumns}
                            dataSource={selectedMappings}
                            options={false}
                            pagination={{ pageSize: 5 }}
                            rowKey="mapping_id"
                            search={false}
                            toolBarRender={false}
                            onRow={(record) => ({
                              onClick: () => setSelectedMappingId(record.mapping_id),
                            })}
                          />
                        </Space>
                      ),
                    },
                    {
                      key: "preview",
                      label: "��������",
                      children: (
                        <Row gutter={[16, 16]}>
                          <Col md={12} xs={24}>
                            <Card size="small" title="��������">
                              <List<IdentityMemberPreview>
                                dataSource={selectedMembers}
                                locale={{ emptyText: "������Ա" }}
                                renderItem={(item) => (
                                  <List.Item>
                                    <List.Item.Meta
                                      description={
                                        <Space direction="vertical" size={0}>
                                          <Typography.Text>{item.role_labels.join(", ") || "������������?}</Typography.Text>
                                          <Typography.Text type="secondary">{item.access_reason}</Typography.Text>
                                        </Space>
                                      }
                                      title={
                                        <Space size={[8, 8]} wrap>
                                          <span>{item.display_name}</span>
                                          {getEffectiveTag(item.access_result === "active" ? "active" : "review")}
                                        </Space>
                                      }
                                    />
                                  </List.Item>
                                )}
                              />
                            </Card>
                          </Col>
                          <Col md={12} xs={24}>
                            <Card size="small" title="��̨����">
                              <List<IdentitySessionPreview>
                                dataSource={selectedSessions}
                                locale={{ emptyText: "��������" }}
                                renderItem={(item) => (
                                  <List.Item>
                                    <List.Item.Meta
                                      description={
                                        <Space direction="vertical" size={0}>
                                          <Typography.Text>{item.role_name}</Typography.Text>
                                          <Typography.Text type="secondary">
                                            {`${getLoginModeLabel(item.login_mode)} / ${formatTimestamp(item.last_seen_at)}`}
                                          </Typography.Text>
                                        </Space>
                                      }
                                      title={
                                        <Space size={[8, 8]} wrap>
                                          <span>{item.display_name}</span>
                                          {getSessionStatusTag(item.status)}
                                          <Tag color={item.mfa_verified ? "success" : "warning"}>
                                            {item.mfa_verified ? "������? : "����?}
                                          </Tag>
                                        </Space>
                                      }
                                    />
                                  </List.Item>
                                )}
                              />
                            </Card>
                          </Col>
                        </Row>
                      ),
                    },
                  ]}
                />
              </Space>
            ) : (
              <Typography.Text type="secondary">���������?/Typography.Text>
            )}
          </Card>
        </Col>
      </Row>
    </Space>
  );
}


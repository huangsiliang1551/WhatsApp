import { useEffect, useMemo, useState, type JSX } from "react";

import { Alert, Button, Card, Col, Descriptions, Form, Input, Row, Space, Statistic, Tag, Timeline, Typography } from "antd";

import { ECOMMERCE_MOCK_EXAMPLES, type EcommerceOrderShipment } from "../services/ecommerce";
import {
  getEcommerceOrderDetail,
  getEcommerceTrackingDetail,
  listRuntimeState,
  type EcommerceOrderLookupResult,
  type EcommerceTrackingLookupResult,
  type RuntimeAccountState,
} from "../services/api";

function formatTimestamp(value: string | null): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function formatMoney(currency: string, amount: number): string {
  return new Intl.NumberFormat("zh-CN", {
    style: "currency",
    currency,
    maximumFractionDigits: 2,
  }).format(amount);
}

function getShipmentStatusLabel(status: EcommerceOrderShipment["status"]): string {
  if (status === "pending") return "������";
  if (status === "processing") return "������";
  if (status === "in_transit") return "������";
  return "������";
}

function resolveErrorMessage(error: unknown, fallback: string): string {
  if (error instanceof Error && error.message.trim()) return error.message;
  return fallback;
}

export function EcommercePage(): JSX.Element {
  const [runtimeAccounts, setRuntimeAccounts] = useState<RuntimeAccountState[]>([]);
  const [accountId, setAccountId] = useState("");
  const [orderId, setOrderId] = useState("MOCK-1001");
  const [trackingNumber, setTrackingNumber] = useState("YTES123456789");
  const [orderResult, setOrderResult] = useState<EcommerceOrderLookupResult | null>(null);
  const [trackingResult, setTrackingResult] = useState<EcommerceTrackingLookupResult | null>(null);
  const [orderError, setOrderError] = useState<string | null>(null);
  const [trackingError, setTrackingError] = useState<string | null>(null);
  const [loadingAccounts, setLoadingAccounts] = useState(false);
  const [loadingOrder, setLoadingOrder] = useState(false);
  const [loadingTracking, setLoadingTracking] = useState(false);

  useEffect(() => {
    void loadAccounts();
  }, []);

  const availableAccounts = useMemo(() => {
    const values = new Set<string>();
    runtimeAccounts.forEach((item) => values.add(item.account_id));
    ECOMMERCE_MOCK_EXAMPLES.forEach((item) => values.add(item.account_id));
    return Array.from(values);
  }, [runtimeAccounts]);

  useEffect(() => {
    if (!accountId && availableAccounts[0]) {
      setAccountId(availableAccounts[0]);
    }
  }, [accountId, availableAccounts]);

  async function loadAccounts(): Promise<void> {
    setLoadingAccounts(true);
    try {
      const runtime = await listRuntimeState();
      setRuntimeAccounts(runtime.accounts);
    } catch {
      setRuntimeAccounts([]);
    } finally {
      setLoadingAccounts(false);
    }
  }

  async function handleOrderLookup(): Promise<void> {
    if (!accountId.trim() || !orderId.trim()) {
      setOrderError("������д account_id �� order_id");
      return;
    }
    setLoadingOrder(true);
    setOrderError(null);
    try {
      const next = await getEcommerceOrderDetail(accountId.trim(), orderId.trim());
      setOrderResult(next);
    } catch (error) {
      setOrderResult(null);
      setOrderError(resolveErrorMessage(error, `δ�������� ${orderId.trim()}`));
    } finally {
      setLoadingOrder(false);
    }
  }

  async function handleTrackingLookup(nextTrackingNumber?: string): Promise<void> {
    const resolvedTracking = (nextTrackingNumber ?? trackingNumber).trim();
    if (!accountId.trim() || !resolvedTracking) {
      setTrackingError("������д account_id �� tracking_number");
      return;
    }
    setLoadingTracking(true);
    setTrackingError(null);
    try {
      const next = await getEcommerceTrackingDetail(accountId.trim(), resolvedTracking);
      setTrackingResult(next);
      setTrackingNumber(resolvedTracking);
    } catch (error) {
      setTrackingResult(null);
      setTrackingError(resolveErrorMessage(error, `δ������������ ${resolvedTracking}`));
    } finally {
      setLoadingTracking(false);
    }
  }

  function applyExample(index: number): void {
    const example = ECOMMERCE_MOCK_EXAMPLES[index];
    setAccountId(example.account_id);
    setOrderId(example.order_id);
    setTrackingNumber(example.tracking_number);
    setOrderError(null);
    setTrackingError(null);
  }

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {orderError ? <Alert message={orderError} showIcon type="error" /> : null}
      {trackingError ? <Alert message={trackingError} showIcon type="error" /> : null}

      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Tag color="blue">{loadingAccounts ? "����������" : `��ѡ���� ${availableAccounts.length}`}</Tag>
          {ECOMMERCE_MOCK_EXAMPLES.map((example, index) => (
            <Button key={example.order_id} onClick={() => applyExample(index)}>
              {example.label}
            </Button>
          ))}
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="������ѡ" value={availableAccounts.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title="������ѯԴ"
              value={orderResult?.source === "api" ? "API" : orderResult ? "ģ��" : "����"}
            />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title="������ѯԴ"
              value={trackingResult?.source === "api" ? "API" : trackingResult ? "ģ��" : "����"}
            />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��ǰ����" value={accountId || "����"} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={12} xs={24}>
          <Card title="������ѯ">
            <Form layout="vertical" onFinish={() => void handleOrderLookup()}>
              <Form.Item label="account_id">
                <Input value={accountId} onChange={(event) => setAccountId(event.target.value)} />
              </Form.Item>
              <Form.Item label="order_id">
                <Input value={orderId} onChange={(event) => setOrderId(event.target.value)} />
              </Form.Item>
              <Button htmlType="submit" loading={loadingOrder} type="primary">
                ��ѯ����
              </Button>
            </Form>

            {orderResult ? (
              <Space direction="vertical" size={16} style={{ width: "100%", marginTop: 16 }}>
                <Tag color={orderResult.source === "api" ? "success" : "gold"}>
                  {orderResult.source === "api" ? "API" : "ģ��"}
                </Tag>
                <Descriptions bordered column={2} size="small">
                  <Descriptions.Item label="account_id">{orderResult.data.account_id}</Descriptions.Item>
                  <Descriptions.Item label="order_id">{orderResult.data.order_id}</Descriptions.Item>
                  <Descriptions.Item label="external_order_id">{orderResult.data.external_order_id}</Descriptions.Item>
                  <Descriptions.Item label="����">{orderResult.data.customer_name}</Descriptions.Item>
                  <Descriptions.Item label="֧��״̬">{orderResult.data.payment_status}</Descriptions.Item>
                  <Descriptions.Item label="��Լ״̬">{orderResult.data.fulfillment_status}</Descriptions.Item>
                  <Descriptions.Item label="������">
                    {formatMoney(orderResult.data.currency, orderResult.data.total_amount)}
                  </Descriptions.Item>
                  <Descriptions.Item label="����ʱ��">{formatTimestamp(orderResult.data.updated_at)}</Descriptions.Item>
                  <Descriptions.Item label="��ַ" span={2}>
                    {orderResult.data.shipping_address}
                  </Descriptions.Item>
                </Descriptions>

                <Card size="small" title="��Ʒ��ϸ">
                  {orderResult.data.items.map((item) => (
                    <Card key={item.sku} size="small" style={{ marginBottom: 8 }}>
                      <Space direction="vertical" size={2}>
                        <Typography.Text strong>{item.title}</Typography.Text>
                        <Typography.Text type="secondary">{`${item.sku} / ���� ${item.quantity}`}</Typography.Text>
                        <Typography.Text>{formatMoney(item.currency, item.unit_price)}</Typography.Text>
                      </Space>
                    </Card>
                  ))}
                </Card>

                <Card size="small" title="��������">
                  {orderResult.data.shipments.map((shipment) => (
                    <Card key={shipment.shipment_id} size="small" style={{ marginBottom: 8 }}>
                      <Space direction="vertical" size={6}>
                        <Typography.Text strong>{shipment.tracking_number}</Typography.Text>
                        <Typography.Text type="secondary">
                          {`${shipment.carrier} / ${getShipmentStatusLabel(shipment.status)}`}
                        </Typography.Text>
                        <Typography.Text type="secondary">
                          {`ETA ${formatTimestamp(shipment.estimated_delivery_at)}`}
                        </Typography.Text>
                        <Button onClick={() => void handleTrackingLookup(shipment.tracking_number)}>
                          ������������
                        </Button>
                      </Space>
                    </Card>
                  ))}
                </Card>
              </Space>
            ) : null}
          </Card>
        </Col>

        <Col lg={12} xs={24}>
          <Card title="������ѯ">
            <Form layout="vertical" onFinish={() => void handleTrackingLookup()}>
              <Form.Item label="account_id">
                <Input value={accountId} onChange={(event) => setAccountId(event.target.value)} />
              </Form.Item>
              <Form.Item label="tracking_number">
                <Input value={trackingNumber} onChange={(event) => setTrackingNumber(event.target.value)} />
              </Form.Item>
              <Button htmlType="submit" loading={loadingTracking} type="primary">
                ��ѯ����
              </Button>
            </Form>

            {trackingResult ? (
              <Space direction="vertical" size={16} style={{ width: "100%", marginTop: 16 }}>
                <Tag color={trackingResult.source === "api" ? "success" : "gold"}>
                  {trackingResult.source === "api" ? "API" : "ģ��"}
                </Tag>
                <Descriptions bordered column={2} size="small">
                  <Descriptions.Item label="account_id">{trackingResult.data.account_id}</Descriptions.Item>
                  <Descriptions.Item label="order_id">{trackingResult.data.order_id}</Descriptions.Item>
                  <Descriptions.Item label="tracking">{trackingResult.data.tracking_number}</Descriptions.Item>
                  <Descriptions.Item label="carrier">{trackingResult.data.carrier}</Descriptions.Item>
                  <Descriptions.Item label="״̬">{getShipmentStatusLabel(trackingResult.data.status)}</Descriptions.Item>
                  <Descriptions.Item label="������">{trackingResult.data.recipient_name}</Descriptions.Item>
                  <Descriptions.Item label="Ŀ����">{trackingResult.data.destination}</Descriptions.Item>
                  <Descriptions.Item label="Ԥ������">{formatTimestamp(trackingResult.data.estimated_delivery_at)}</Descriptions.Item>
                </Descriptions>
                <Timeline
                  items={trackingResult.data.events.map((event) => ({
                    children: (
                      <Space direction="vertical" size={2}>
                        <Typography.Text strong>{event.status}</Typography.Text>
                        <Typography.Text>{`${event.location} / ${event.description}`}</Typography.Text>
                        <Typography.Text type="secondary">{formatTimestamp(event.occurred_at)}</Typography.Text>
                      </Space>
                    ),
                  }))}
                />
              </Space>
            ) : null}
          </Card>
        </Col>
      </Row>
    </Space>
  );
}

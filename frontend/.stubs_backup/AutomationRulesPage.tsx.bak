import { useEffect, useMemo, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Form,
  Input,
  Row,
  Select,
  Space,
  Statistic,
  Tag,
  Typography,
} from "antd";

import {
  createAutomationRulePrototype,
  listAutomationRules,
  updateAutomationRuleStatus,
} from "../services/operations";
import { useAppStore } from "../stores/appStore";
import type {
  AutomationRuleDefinition,
  AutomationRulePrototypePayload,
} from "../types/operations";

type RuleFormValues = {
  account_id?: string;
  name: string;
  scope: "global" | "account";
  priority: number;
  trigger_type: string;
  condition_text: string;
  action_text: string;
};

function getStatusColor(status: AutomationRuleDefinition["status"]): string {
  if (status === "active") return "success";
  if (status === "paused") return "warning";
  return "default";
}

function getStatusLabel(status: AutomationRuleDefinition["status"]): string {
  if (status === "active") return "����";
  if (status === "paused") return "��ͣ";
  return "�ݸ�";
}

function getScopeLabel(scope: AutomationRuleDefinition["scope"]): string {
  return scope === "global" ? "ȫ��������" : "�˺�������";
}

function formatTimestamp(value: string): string {
  return new Date(value).toLocaleString("zh-CN");
}

export function AutomationRulesPage(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const [form] = Form.useForm<RuleFormValues>();
  const formScope = Form.useWatch("scope", form);
  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [rules, setRules] = useState<AutomationRuleDefinition[]>([]);
  const [selectedRuleId, setSelectedRuleId] = useState("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const selectedRule = useMemo(
    () => rules.find((item) => item.rule_id === selectedRuleId) ?? null,
    [rules, selectedRuleId]
  );

  const activeCount = useMemo(
    () => rules.filter((item) => item.status === "active").length,
    [rules]
  );
  const pausedCount = useMemo(
    () => rules.filter((item) => item.status === "paused").length,
    [rules]
  );
  const draftCount = useMemo(
    () => rules.filter((item) => item.status === "draft").length,
    [rules]
  );
  const totalMatches = useMemo(
    () => rules.reduce((sum, item) => sum + item.match_count_24h, 0),
    [rules]
  );

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    void loadRules();
  }, [accountFilter]);

  useEffect(() => {
    if (!rules.length) {
      setSelectedRuleId("");
      return;
    }

    if (selectedRuleId && rules.some((item) => item.rule_id === selectedRuleId)) {
      return;
    }

    setSelectedRuleId(rules[0].rule_id);
  }, [rules, selectedRuleId]);

  useEffect(() => {
    form.setFieldsValue({
      scope: "account",
      priority: 50,
      account_id: accountFilter !== "ALL" ? accountFilter : undefined,
    });
  }, [accountFilter, form]);

  async function loadRules(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      setRules(await listAutomationRules(accountFilter !== "ALL" ? accountFilter : undefined));
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "�Զ����������ʧ��");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleCreateRule(values: RuleFormValues): Promise<void> {
    setPendingAction("create");
    setError(null);
    setNotice(null);
    try {
      const payload: AutomationRulePrototypePayload = {
        account_id: values.scope === "account" ? values.account_id?.trim() || null : null,
        name: values.name.trim(),
        scope: values.scope,
        priority: Number(values.priority),
        trigger_type: values.trigger_type.trim(),
        condition_lines: values.condition_text.split(/\r?\n/),
        action_lines: values.action_text.split(/\r?\n/),
      };
      const created = await createAutomationRulePrototype(payload);
      if (
        accountFilter === "ALL" ||
        created.account_id === null ||
        created.account_id === accountFilter
      ) {
        setRules((current) => [created, ...current]);
        setSelectedRuleId(created.rule_id);
      }
      setNotice(`�����Ѵ�����${created.name}`);
      form.resetFields();
      form.setFieldsValue({
        scope: "account",
        priority: 50,
        account_id: accountFilter !== "ALL" ? accountFilter : undefined,
      });
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "���򴴽�ʧ��");
      setPendingAction(null);
    }
  }

  async function handleToggleStatus(rule: AutomationRuleDefinition): Promise<void> {
    const nextStatus =
      rule.status === "active" ? "paused" : rule.status === "paused" ? "active" : "active";
    setPendingAction(`status:${rule.rule_id}`);
    setError(null);
    setNotice(null);
    try {
      const updated = await updateAutomationRuleStatus(rule.rule_id, nextStatus);
      setRules((current) =>
        current.map((item) => (item.rule_id === updated.rule_id ? updated : item))
      );
      setNotice(`����״̬�Ѹ��£�${updated.name}`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "����״̬����ʧ��");
      setPendingAction(null);
    }
  }

  const columns: ProColumns<AutomationRuleDefinition>[] = [
    {
      title: "����",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.name}</Typography.Text>
          <Typography.Text type="secondary">{record.rule_id}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "�˺�",
      render: (_, record) => record.account_id ?? "ȫ��",
    },
    {
      title: "������",
      dataIndex: "trigger_type",
    },
    {
      title: "���ȼ�",
      dataIndex: "priority",
    },
    {
      title: "״̬",
      render: (_, record) => (
        <Tag color={getStatusColor(record.status)}>{getStatusLabel(record.status)}</Tag>
      ),
    },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}

      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={[
              { label: "ȫ���˺�", value: "ALL" },
              ...actorAccountIds.map((item) => ({ label: item, value: item })),
            ]}
            onChange={setAccountFilter}
          />
          <Button loading={loading} onClick={() => void loadRules()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card><Statistic title="��������" value={rules.length} /></Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card><Statistic title="���ù���" value={activeCount} /></Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card><Statistic title="��ͣ����" value={pausedCount} /></Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card><Statistic title="�ݸ����" value={draftCount} /></Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<AutomationRuleDefinition>
            columns={columns}
            dataSource={rules}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="rule_id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => setSelectedRuleId(record.rule_id),
            })}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="��������">
              {selectedRule ? (
                <Space direction="vertical" size={16} style={{ width: "100%" }}>
                  <Space size={[8, 8]} wrap>
                    <Tag>{selectedRule.account_id ?? "ȫ��"}</Tag>
                    <Tag color={getStatusColor(selectedRule.status)}>
                      {getStatusLabel(selectedRule.status)}
                    </Tag>
                    <Tag color={selectedRule.scope === "global" ? "blue" : "cyan"}>
                      {getScopeLabel(selectedRule.scope)}
                    </Tag>
                    <Tag>{`���ȼ� ${selectedRule.priority}`}</Tag>
                    <Tag>{selectedRule.trigger_type}</Tag>
                  </Space>

                  <Card size="small" title="����">
                    <Space direction="vertical" size={8} style={{ width: "100%" }}>
                      {selectedRule.conditions.map((condition, index) => (
                        <Tag key={`${selectedRule.rule_id}:condition:${index}`}>
                          {`${condition.field} ${condition.operator} ${condition.value}`}
                        </Tag>
                      ))}
                    </Space>
                  </Card>

                  <Card size="small" title="����">
                    <Space direction="vertical" size={8} style={{ width: "100%" }}>
                      {selectedRule.actions.map((action, index) => (
                        <Tag key={`${selectedRule.rule_id}:action:${index}`}>
                          {`${action.action_type} / ${action.summary}`}
                        </Tag>
                      ))}
                    </Space>
                  </Card>

                  <Space align="center" style={{ justifyContent: "space-between", width: "100%" }}>
                    <Typography.Text type="secondary">
                      {`24h ���� ${selectedRule.match_count_24h} / ������ ${formatTimestamp(
                        selectedRule.updated_at
                      )}`}
                    </Typography.Text>
                    <Button
                      loading={pendingAction === `status:${selectedRule.rule_id}`}
                      onClick={() => void handleToggleStatus(selectedRule)}
                    >
                      {selectedRule.status === "active" ? "��ͣ����" : "���ù���"}
                    </Button>
                  </Space>
                </Space>
              ) : (
                <Typography.Text type="secondary">���޹���</Typography.Text>
              )}
            </Card>

            <Card
              title="�½�����"
              extra={<Tag color="gold">ģ��</Tag>}
            >
              <Form<RuleFormValues>
                form={form}
                layout="vertical"
                initialValues={{
                  scope: "account",
                  priority: 50,
                  account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                }}
                onFinish={(values) => void handleCreateRule(values)}
              >
                <Form.Item label="��������" name="name" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="������" name="scope" rules={[{ required: true }]}>
                  <Select
                    options={[
                      { label: "�˺ż�", value: "account" },
                      { label: "ȫ�ּ�", value: "global" },
                    ]}
                  />
                </Form.Item>
                <Form.Item label="�˺�" name="account_id">
                  <Select
                    allowClear
                    disabled={formScope === "global"}
                    options={actorAccountIds.map((item) => ({ label: item, value: item }))}
                    placeholder="ѡ���˺�"
                  />
                </Form.Item>
                <Form.Item label="���ȼ�" name="priority" rules={[{ required: true }]}>
                  <Input type="number" />
                </Form.Item>
                <Form.Item label="������" name="trigger_type" rules={[{ required: true }]}>
                  <Input placeholder="���� handover_recommended" />
                </Form.Item>
                <Form.Item label="����" name="condition_text" rules={[{ required: true }]}>
                  <Input.TextArea rows={4} placeholder="���� conversation.latest_intent_name = refund" />
                </Form.Item>
                <Form.Item label="����" name="action_text" rules={[{ required: true }]}>
                  <Input.TextArea rows={4} placeholder="���� notify_members" />
                </Form.Item>
                <Button htmlType="submit" loading={pendingAction === "create"} type="primary" block>
                  ��������
                </Button>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>

      <Card>
        <Statistic title="��ǰɸѡ 24h ������" value={totalMatches} />
      </Card>
    </Space>
  );
}

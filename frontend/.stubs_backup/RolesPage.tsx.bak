import { lazy, useEffect, useMemo, useRef, useState, type ComponentType, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Form,
  Input,
  Row,
  Select,
  Space,
  Statistic,
  Table,
  Tabs,
  Tag,
  Typography,
} from "antd";

const LazyMemberAccessContent = lazy(() =>
  import("./MemberAccessPage").then((m) => ({ default: m.MemberAccessPage }))
);
const LazyAccessControlContent = lazy(() =>
  import("./AccessControlPage").then((m) => ({ default: m.AccessControlPage }))
);

import { createRoleDefinition, listRoleDefinitions } from "../services/operations";
import { useAppStore } from "../stores/appStore";
import type {
  RoleDefinition,
  RoleDefinitionCreatePayload,
  RolePermissionAction,
  RolePermissionResource,
} from "../types/operations";

type RoleFormValues = {
  role_key: string;
  name: string;
  scope: "global" | "account";
  account_scope_text?: string;
};

const PERMISSION_ACTIONS: RolePermissionAction[] = [
  "view",
  "edit",
  "assign",
  "approve",
  "export",
];

function getActionLabel(action: RolePermissionAction): string {
  if (action === "view") return "����";
  if (action === "edit") return "����";
  if (action === "assign") return "����";
  if (action === "approve") return "����";
  return "����";
}

function getScopeLabel(scope: RoleFormValues["scope"]): string {
  return scope === "global" ? "ȫ��" : "����";
}

function getStatusTag(status: RoleDefinition["status"]): JSX.Element {
  return (
    <Tag color={status === "active" ? "success" : "warning"}>
      {status === "active" ? "���" : "���"}
    </Tag>
  );
}

export function RolesContent(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openMemberAccessPage = useAppStore((state) => state.openMemberAccessPage);
  const openAccessControlPage = useAppStore((state) => state.openAccessControlPage);
  const openSecuritySettingsPage = useAppStore((state) => state.openSecuritySettingsPage);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const rolesPagePrefill = useAppStore((state) => state.rolesPagePrefill);
  const clearRolesPagePrefill = useAppStore((state) => state.clearRolesPagePrefill);
  const setRolesPagePrefill = useAppStore((state) => state.setRolesPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);
  const loadRequestIdRef = useRef(0);
  const [form] = Form.useForm<RoleFormValues>();
  const [roles, setRoles] = useState<RoleDefinition[]>([]);
  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [query, setQuery] = useState("");
  const [selectedRoleKey, setSelectedRoleKey] = useState<string>("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const selectedRole = useMemo(
    () => roles.find((role) => role.role_key === selectedRoleKey) ?? null,
    [roles, selectedRoleKey]
  );

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!rolesPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === rolesPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = rolesPagePrefill.nonce;
    setAccountFilter(rolesPagePrefill.account_id ?? "ALL");
    setSelectedRoleKey(rolesPagePrefill.selected_role_key ?? "");
    clearRolesPagePrefill();
  }, [clearRolesPagePrefill, rolesPagePrefill]);

  useEffect(() => {
    void loadRoles();
  }, [accountFilter]);

  useEffect(() => {
    form.setFieldsValue({
      scope: "account",
      account_scope_text: accountFilter !== "ALL" ? accountFilter : undefined,
    });
  }, [accountFilter, form]);

  const accountOptions = useMemo(() => {
    const values = new Set<string>(actorAccountIds);
    roles.forEach((role) => {
      role.account_scope.forEach((item) => {
        if (item !== "ALL") values.add(item);
      });
    });
    return ["ALL", ...Array.from(values).sort((left, right) => left.localeCompare(right, "zh-CN"))];
  }, [actorAccountIds, roles]);

  const filteredRoles = useMemo(() => {
    const keyword = query.trim().toLowerCase();
    return roles.filter((role) => {
      if (accountFilter !== "ALL" && !role.account_scope.includes("ALL") && !role.account_scope.includes(accountFilter)) {
        return false;
      }
      if (!keyword) return true;
      return [role.name, role.role_key, ...role.account_scope, ...role.page_scope]
        .join(" ")
        .toLowerCase()
        .includes(keyword);
    });
  }, [accountFilter, query, roles]);

  useEffect(() => {
    if (!filteredRoles.length) {
      setSelectedRoleKey("");
      return;
    }

    if (selectedRoleKey && filteredRoles.some((role) => role.role_key === selectedRoleKey)) {
      return;
    }

    setSelectedRoleKey(filteredRoles[0].role_key);
  }, [filteredRoles, selectedRoleKey]);

  useEffect(() => {
    setRolesPagePrefill({
      account_id: accountFilter !== "ALL" ? accountFilter : undefined,
      selected_role_key: selectedRoleKey || undefined,
    });
  }, [accountFilter, selectedRoleKey, setRolesPagePrefill]);

  const activeRoleCount = filteredRoles.filter((role) => role.status === "active").length;
  const accountScopedRoleCount = filteredRoles.filter((role) => role.scope === "account").length;
  const coveredMemberCount = filteredRoles.reduce((sum, role) => sum + role.member_count, 0);
  const customRoleCount = filteredRoles.filter(
    (role) => role.permission_origin === "custom"
  ).length;

  async function loadRoles(): Promise<void> {
    const requestId = ++loadRequestIdRef.current;
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      const scopedAccountId = accountFilter !== "ALL" ? accountFilter : undefined;
      const nextRoles = await listRoleDefinitions(scopedAccountId);
      if (requestId !== loadRequestIdRef.current) {
        return;
      }
      setRoles(nextRoles);
      setNotice(`已ˢ�?${new Date().toLocaleString("zh-CN")}`);
    } catch (loadError) {
      if (requestId !== loadRequestIdRef.current) {
        return;
      }
      setError(loadError instanceof Error ? loadError.message : "��ɫ��������ʧ��");
    } finally {
      if (requestId === loadRequestIdRef.current) {
        setLoading(false);
        setPendingAction(null);
      }
    }
  }

  async function handleCreateRole(values: RoleFormValues): Promise<void> {
    const payload: RoleDefinitionCreatePayload = {
      role_key: values.role_key.trim(),
      name: values.name.trim(),
      scope: values.scope,
      account_scope:
        values.scope === "account"
          ? (() => {
              const scopedAccounts = (values.account_scope_text ?? "")
                .split(",")
                .map((item) => item.trim())
                .filter(Boolean);
              if (scopedAccounts.length > 0) {
                return scopedAccounts;
              }
              return accountFilter !== "ALL" ? [accountFilter] : [];
            })()
          : ["ALL"],
    };

    setPendingAction("create-role");
    setError(null);
    setNotice(null);
    try {
      const created = await createRoleDefinition(payload);
      await loadRoles();
      setSelectedRoleKey(created.role_key);
      setNotice(`��ɫ��������${created.name}`);
      form.resetFields();
      form.setFieldsValue({
        scope: "account",
        account_scope_text: accountFilter !== "ALL" ? accountFilter : undefined,
      });
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������ɫʧ��");
      setPendingAction(null);
    }
  }

  const columns: ProColumns<RoleDefinition>[] = [
    {
      title: "��ɫ",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.name}</Typography.Text>
          <Typography.Text type="secondary">{record.role_key}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "作用�?,
      render: (_, record) => (
        <Tag color={record.scope === "global" ? "processing" : "default"}>
          {getScopeLabel(record.scope)}
        </Tag>
      ),
    },
    {
      title: "成Ա�?,
      dataIndex: "member_count",
    },
    {
      title: "���€?,
      render: (_, record) => getStatusTag(record.status),
    },
  ];

  const permissionColumns = [
    {
      title: "��Դ",
      dataIndex: "label",
      key: "label",
    },
    ...PERMISSION_ACTIONS.map((action) => ({
      title: getActionLabel(action),
      key: action,
      render: (_: unknown, record: RolePermissionResource) =>
        record.actions[action] ? <Tag color="success">�?/Tag> : <Tag>�?/Tag>,
    })),
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}

      <Card>
        <Space align="center" size={[12, 12]} wrap>
                    <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={accountOptions.map((item) => ({
              label: item === "ALL" ? "ȫ������" : item,
              value: item,
            }))}
            onChange={setAccountFilter}
          />
          <Input.Search
            allowClear
            style={{ width: 260 }}
            placeholder="������ɫ / ���� / ҳ��"
            value={query}
            onChange={(event) => setQuery(event.target.value)}
          />
          <Button
            onClick={() =>
              openMemberAccessPage({
                account_id:
                  selectedRole?.scope === "account" && selectedRole.account_scope.length === 1
                    ? selectedRole.account_scope[0]
                    : accountFilter !== "ALL"
                      ? accountFilter
                      : undefined,
                role_key: selectedRoleKey || undefined,
              })
            }
          >
            ��Ա��Ȩ
          </Button>
          <Button
            onClick={() =>
              openAccessControlPage({
                account_id:
                  selectedRole?.scope === "account" && selectedRole.account_scope.length === 1
                    ? selectedRole.account_scope[0]
                    : accountFilter !== "ALL"
                      ? accountFilter
                      : undefined,
              })
            }
          >
            ��������
          </Button>
          <Button
            onClick={() =>
              openSecuritySettingsPage({
                account_id:
                  selectedRole?.scope === "account" && selectedRole.account_scope.length === 1
                    ? selectedRole.account_scope[0]
                    : accountFilter !== "ALL"
                      ? accountFilter
                      : undefined,
              })
            }
          >
            ��ȫ����
          </Button>
          <Button
            onClick={() =>
              openAuditPage({
                account_id:
                  selectedRole?.scope === "account" && selectedRole.account_scope.length === 1
                    ? selectedRole.account_scope[0]
                    : accountFilter !== "ALL"
                      ? accountFilter
                      : undefined,
                target_type: selectedRole ? "role_definition" : undefined,
                target_id: selectedRoleKey || undefined,
                limit: 50,
              })
            }
          >
            ���
          </Button>
          <Button loading={loading} onClick={() => void loadRoles()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��ɫ����" value={filteredRoles.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��������" value={activeRoleCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="���������? value={accountScopedRoleCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="�������? value={customRoleCount} />
            <Typography.Text type="secondary">{`��Ա���� ${coveredMemberCount}`}</Typography.Text>
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<RoleDefinition>
            columns={columns}
            dataSource={filteredRoles}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="role_key"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => setSelectedRoleKey(record.role_key),
            })}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="��ɫ����">
              {selectedRole ? (
                <Space direction="vertical" size={16} style={{ width: "100%" }}>
                  <Row gutter={[12, 12]}>
                    <Col span={12}>
                      <Card size="small">
                        <Typography.Text type="secondary">作用�?/Typography.Text>
                        <div>{getScopeLabel(selectedRole.scope)}</div>
                      </Card>
                    </Col>
                    <Col span={12}>
                      <Card size="small">
                        <Typography.Text type="secondary">成Ա�?/Typography.Text>
                        <div>{selectedRole.member_count}</div>
                      </Card>
                    </Col>
                    <Col span={24}>
                      <Card size="small">
                        <Space align="center" size={[8, 8]} wrap>
                          <Typography.Text type="secondary">��Դ</Typography.Text>
                          <Tag
                            color={
                              selectedRole.source === "hybrid"
                                ? "cyan"
                                : selectedRole.source === "api"
                                  ? "blue"
                                  : "gold"
                            }
                          >
                            {selectedRole.source === "hybrid"
                              ? "����"
                              : selectedRole.source === "api"
                                ? "API"
                                : "ģ��"}
                          </Tag>
                          <Tag>{selectedRole.status === "active" ? "���" : "���"}</Tag>
                        </Space>
                      </Card>
                    </Col>
                  </Row>

                  <Card size="small" title="������Χ">
                    <Space size={[8, 8]} wrap>
                      {selectedRole.account_scope.map((item) => (
                        <Tag key={`${selectedRole.role_key}:${item}`}>{item}</Tag>
                      ))}
                    </Space>
                  </Card>

                  <Card size="small" title="ҳ����Χ">
                    <Space size={[8, 8]} wrap>
                      {selectedRole.page_scope.length > 0 ? (
                        selectedRole.page_scope.map((item) => (
                          <Tag key={`${selectedRole.role_key}:${item}`}>{item}</Tag>
                        ))
                      ) : (
                        <Typography.Text type="secondary">����?/Typography.Text>
                      )}
                    </Space>
                  </Card>

                  <Card size="small" title="Ȩ������">
                    <Space size={[8, 8]} style={{ marginBottom: 12 }} wrap>
                      <Tag color={selectedRole.permission_origin === "custom" ? "gold" : "blue"}>
                        {selectedRole.permission_origin === "custom"
                          ? "Custom"
                          : selectedRole.permission_origin === "derived"
                            ? "Derived"
                            : "Preset"}
                      </Tag>
                      {selectedRole.permission_origin === "derived" &&
                      selectedRole.permission_origin_role_key ? (
                        <Tag>{selectedRole.permission_origin_role_key}</Tag>
                      ) : null}
                    </Space>
                    <Table<RolePermissionResource>
                      columns={permissionColumns}
                      dataSource={selectedRole.permissions}
                      pagination={false}
                      rowKey="resource_key"
                      size="small"
                    />
                  </Card>
                </Space>
              ) : (
                <Typography.Text type="secondary">������ɫ</Typography.Text>
              )}
            </Card>

            <Card title="������ɫ">
              <Form<RoleFormValues>
                form={form}
                layout="vertical"
                initialValues={{ scope: "account" }}
                onFinish={(values) => void handleCreateRole(values)}
              >
                <Form.Item label="role_key" name="role_key" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="����" name="name" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="作用�? name="scope" rules={[{ required: true }]}>
                  <Select
                    options={[
                      { label: "账号�?, value: "account" },
                      { label: "ȫ局�?, value: "global" },
                    ]}
                  />
                </Form.Item>
                <Form.Item label="������Χ" name="account_scope_text">
                  <Input.TextArea rows={3} placeholder="brand-demo-cn,brand-demo-es" />
                </Form.Item>
                <Button htmlType="submit" loading={pendingAction === "create-role"} type="primary" block>
                  ������ɫ
                </Button>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>
    </Space>
  );
}

export function RolesPage(): JSX.Element {
  return (
    <Tabs
      defaultActiveKey="roles"
      items={[
        { key: "roles", label: "��ɫ����", children: <RolesContent /> },
        { key: "authorization", label: "��Ա��Ȩ", children: <LazyMemberAccessContent /> },
        { key: "access", label: "��������", children: <LazyAccessControlContent /> },
      ]}
    />
  );
}

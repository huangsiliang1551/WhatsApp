import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  Row,
  Select,
  Space,
  Statistic,
  Tag,
  Typography,
} from "antd";

import {
  createPlatformUser,
  listPlatformSites,
  listPlatformUsers,
  type PlatformSite,
  type PlatformUser,
  type PlatformUserCreatePayload,
} from "../services/api";
import {
  listPlatformUserMemberStatusIndex,
  type PlatformUserMemberStatusSummary,
} from "../services/operations";
import { useMemberStatus } from "../hooks/useMemberStatus";
import { useAppStore } from "../stores/appStore";

type UserFormValues = {
  account_id?: string;
  public_user_id: string;
  registration_site_id?: string;
  display_name?: string;
  country_code?: string;
  language_code: string;
  is_anonymous: boolean;
  lifecycle_status: string;
  restrict_task_claim: boolean;
  registration_invite_code?: string;
  phone_identity?: string;
  whatsapp_identity?: string;
  email_identity?: string;
  tag_keys_text?: string;
};

function parseTagKeys(value: string): string[] {
  return value
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);
}

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function getVerificationStatusColor(status: string): string {
  if (status === "approved") return "success";
  if (status === "rejected") return "error";
  if (status === "under_review") return "processing";
  return "default";
}

function getBindingStatusColor(status: string): string {
  if (status === "bound") return "success";
  if (status === "failed") return "error";
  return "processing";
}

function formatLifecycleStatus(status: string): string {
  if (status === "active") return "���";
  if (status === "frozen") return "����";
  if (status === "blacklisted") return "黑名�?;
  return status;
}

function formatVerificationStatus(status: string): string {
  if (status === "approved") return "���€����";
  if (status === "rejected") return "已拒�?;
  if (status === "under_review") return "审核�?;
  return status;
}

function formatBindingStatus(status: string): string {
  if (status === "bound") return "已绑�?;
  if (status === "failed") return "ʧ��";
  if (status === "pending") return "处理�?;
  return status;
}

export function UsersPage(): JSX.Element {
  const [form] = Form.useForm<UserFormValues>();
  const formAccountId = Form.useWatch("account_id", form);
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openWorkspacePage = useAppStore((state) => state.openWorkspacePage);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openCustomersPage = useAppStore((state) => state.openCustomersPage);
  const usersPagePrefill = useAppStore((state) => state.usersPagePrefill);
  const clearUsersPagePrefill = useAppStore((state) => state.clearUsersPagePrefill);
  const setUsersPagePrefill = useAppStore((state) => state.setUsersPagePrefill);
  const {
    memberStatus,
    memberStatusLoading,
    memberStatusError,
    loadMemberStatus,
    resetMemberStatus,
  } = useMemberStatus();
  const lastAppliedPrefillNonce = useRef<number | null>(null);

  const [users, setUsers] = useState<PlatformUser[]>([]);
  const [sites, setSites] = useState<PlatformSite[]>([]);
  const [selectedUserId, setSelectedUserId] = useState<string>("");
  const [userMemberStatusIndex, setUserMemberStatusIndex] = useState<
    Record<string, PlatformUserMemberStatusSummary>
  >({});
  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [siteFilter, setSiteFilter] = useState<string>("ALL");
  const [lifecycleFilter, setLifecycleFilter] = useState<string>("ALL");
  const [search, setSearch] = useState("");
  const [selectionLocked, setSelectionLocked] = useState(false);
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const [selectionWarning, setSelectionWarning] = useState<string | null>(null);

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!usersPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === usersPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = usersPagePrefill.nonce;
    setAccountFilter(usersPagePrefill.account_id ?? "ALL");
    setSiteFilter(usersPagePrefill.site_id ?? "ALL");
    setLifecycleFilter(usersPagePrefill.lifecycle_status ?? "ALL");
    setSearch(usersPagePrefill.search ?? "");
    setSelectedUserId(usersPagePrefill.selected_user_id ?? "");
    setSelectionLocked(Boolean(usersPagePrefill.selected_user_id));
    setSelectionWarning(null);
    clearUsersPagePrefill();
  }, [clearUsersPagePrefill, usersPagePrefill]);

  useEffect(() => {
    void loadData();
  }, []);

  const filteredUsers = useMemo(() => {
    const keyword = search.trim().toLowerCase();
    return users.filter((item) => {
      if (accountFilter !== "ALL" && item.account_id !== accountFilter) {
        return false;
      }
      if (siteFilter !== "ALL" && item.registration_site_id !== siteFilter) {
        return false;
      }
      if (lifecycleFilter !== "ALL" && item.lifecycle_status !== lifecycleFilter) {
        return false;
      }
      if (!keyword) {
        return true;
      }
      return [
        item.public_user_id,
        item.display_name ?? "",
        item.account_id ?? "",
        item.registration_site_key ?? "",
        item.registration_site_domain ?? "",
        item.country_code ?? "",
        item.language_code,
        item.registration_invite_code ?? "",
        ...item.identities.map((identity) => identity.identity_value),
        ...item.tags.map((tag) => tag.tag_key),
      ]
        .join(" ")
        .toLowerCase()
        .includes(keyword);
    });
  }, [accountFilter, lifecycleFilter, search, siteFilter, users]);

  useEffect(() => {
    if (!filteredUsers.length) {
      setSelectedUserId("");
      if (selectionLocked) {
        setSelectionLocked(false);
      }
      return;
    }

    if (selectedUserId && filteredUsers.some((item) => item.id === selectedUserId)) {
      return;
    }

    if (selectionLocked && selectedUserId) {
      setSelectionWarning("��������������������������€�����?);
      setSelectionLocked(false);
      return;
    }

    setSelectionWarning(null);
    setSelectedUserId(filteredUsers[0].id);
  }, [filteredUsers, selectedUserId, selectionLocked]);

  useEffect(() => {
    setUsersPagePrefill({
      account_id: accountFilter,
      site_id: siteFilter,
      lifecycle_status: lifecycleFilter,
      search: search || undefined,
      selected_user_id: selectedUserId || undefined,
    });
  }, [
    accountFilter,
    lifecycleFilter,
    search,
    selectedUserId,
    setUsersPagePrefill,
    siteFilter,
  ]);

  useEffect(() => {
    form.setFieldValue("account_id", accountFilter !== "ALL" ? accountFilter : undefined);
  }, [accountFilter, form]);

  async function loadData(): Promise<void> {
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      const [nextUsers, nextSites] = await Promise.all([listPlatformUsers(), listPlatformSites()]);
      const nextStatusIndex = await listPlatformUserMemberStatusIndex(nextUsers);
      setUsers(nextUsers);
      setSites(nextSites);
      setUserMemberStatusIndex(nextStatusIndex);
      setNotice(`已ˢ�?${new Date().toLocaleString("zh-CN")}`);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "用户ҳ加载ʧ�?);
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleCreateUser(values: UserFormValues): Promise<void> {
    setPendingAction("create-user");
    setError(null);
    setNotice(null);
    try {
      const identities = [
        values.phone_identity?.trim()
          ? {
              identity_type: "phone",
              identity_value: values.phone_identity.trim(),
              country_code: values.country_code?.trim() || undefined,
              is_verified: true,
              is_primary: true,
            }
          : null,
        values.email_identity?.trim()
          ? {
              identity_type: "email",
              identity_value: values.email_identity.trim(),
              is_verified: true,
              is_primary: !values.phone_identity?.trim(),
            }
          : null,
        values.whatsapp_identity?.trim()
          ? {
              identity_type: "whatsapp",
              identity_value: values.whatsapp_identity.trim(),
              is_verified: true,
              is_primary: false,
            }
          : null,
      ].filter((item): item is NonNullable<typeof item> => item !== null);

      const payload: PlatformUserCreatePayload = {
        account_id: values.account_id?.trim() || undefined,
        public_user_id: values.public_user_id.trim(),
        registration_site_id: values.registration_site_id?.trim() || undefined,
        display_name: values.display_name?.trim() || undefined,
        country_code: values.country_code?.trim() || undefined,
        language_code: values.language_code.trim(),
        is_anonymous: values.is_anonymous,
        lifecycle_status: values.lifecycle_status,
        restrict_task_claim: values.restrict_task_claim,
        registration_invite_code: values.registration_invite_code?.trim() || undefined,
        identities,
        tag_keys: parseTagKeys(values.tag_keys_text ?? ""),
      };

      const created = await createPlatformUser(payload);
      setNotice(`已创�?${created.public_user_id}`);
      setSelectionLocked(false);
      setSelectedUserId(created.id);
      form.resetFields();
      form.setFieldsValue({
        account_id: accountFilter !== "ALL" ? accountFilter : undefined,
        language_code: "zh-CN",
        lifecycle_status: "active",
        is_anonymous: false,
        restrict_task_claim: false,
      });
      await loadData();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "��������ʧ��");
      setPendingAction(null);
    }
  }



  const selectedUser = useMemo(
    () => filteredUsers.find((item) => item.id === selectedUserId) ?? null,
    [filteredUsers, selectedUserId]
  );

  useEffect(() => {
    if (!selectedUser) {
      resetMemberStatus();
      return;
    }
    void loadMemberStatus(selectedUser);
  }, [selectedUser, resetMemberStatus, loadMemberStatus]);

  const accountOptions = useMemo(() => {
    const values = new Set<string>(actorAccountIds);
    users.forEach((item) => {
      if (item.account_id) {
        values.add(item.account_id);
      }
    });
    return Array.from(values).filter(Boolean).sort((left, right) => left.localeCompare(right));
  }, [actorAccountIds, users]);

  const siteOptions = useMemo(() => {
    const filteredSites = accountFilter === "ALL"
      ? sites
      : sites.filter((site) => !site.account_id || site.account_id === accountFilter);
    return filteredSites.sort((left, right) => left.brand_name.localeCompare(right.brand_name));
  }, [accountFilter, sites]);

  const createSiteOptions = useMemo(() => {
    const scopedAccountId =
      typeof formAccountId === "string" && formAccountId.trim().length > 0
        ? formAccountId
        : accountFilter !== "ALL"
          ? accountFilter
          : undefined;
    const filteredSites = scopedAccountId
      ? sites.filter((site) => !site.account_id || site.account_id === scopedAccountId)
      : sites;
    return filteredSites.sort((left, right) => left.brand_name.localeCompare(right.brand_name));
  }, [accountFilter, formAccountId, sites]);

  useEffect(() => {
    if (siteFilter === "ALL") {
      return;
    }
    if (siteOptions.some((site) => site.id === siteFilter)) {
      return;
    }
    setSiteFilter("ALL");
  }, [siteFilter, siteOptions]);

  useEffect(() => {
    const currentSiteId = form.getFieldValue("registration_site_id");
    if (!currentSiteId) {
      return;
    }
    if (createSiteOptions.some((site) => site.id === currentSiteId)) {
      return;
    }
    form.setFieldValue("registration_site_id", undefined);
  }, [createSiteOptions, form]);

  const lifecycleOptions = useMemo(
    () => [
      { label: "��������€?, value: "ALL" },
      ...Array.from(new Set(users.map((item) => item.lifecycle_status)))
        .filter(Boolean)
        .sort((left, right) => left.localeCompare(right))
        .map((value) => ({ label: formatLifecycleStatus(value), value })),
    ],
    [users]
  );

  const columns: ProColumns<PlatformUser>[] = [
    {
      title: "����",
      key: "user",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.display_name || record.public_user_id}</Typography.Text>
          <Typography.Text type="secondary">{record.public_user_id}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "���� / վ��",
      key: "scope",
      render: (_, record) => `${record.account_id ?? "����"} / ${record.registration_site_key ?? "����"}`,
    },
    {
      title: "���",
      key: "identity",
      render: (_, record) => (
        <Space size={[6, 6]} wrap>
          <Tag color={record.has_phone ? "processing" : "default"}>����</Tag>
          <Tag color={record.has_email ? "processing" : "default"}>�</Tag>
          <Tag color={record.has_whatsapp ? "success" : "default"}>WhatsApp</Tag>
        </Space>
      ),
    },
    {
      title: "���€?,
      key: "status",
      render: (_, record) => (
        <Space size={[6, 6]} wrap>
          <Tag color={record.lifecycle_status === "active" ? "success" : "default"}>
            {formatLifecycleStatus(record.lifecycle_status)}
          </Tag>
          <Tag color={record.is_anonymous ? "warning" : "default"}>
            {record.is_anonymous ? "����" : "ʵ��"}
          </Tag>
          {record.is_new_user ? <Tag color="processing">新用�?/Tag> : null}
        </Space>
      ),
    },
    {
      title: "��Ա��֤",
      key: "member_verification",
      render: (_, record) => {
        const summary = userMemberStatusIndex[record.id];
        if (!summary?.latestVerificationStatus) {
          return <Typography.Text type="secondary">����</Typography.Text>;
        }
        return (
          <Space size={[6, 6]} wrap>
            <Tag color={getVerificationStatusColor(summary.latestVerificationStatus)}>
              {formatVerificationStatus(summary.latestVerificationStatus)}
            </Tag>
            <Typography.Text type="secondary">{summary.verificationCount} �?/Typography.Text>
          </Space>
        );
      },
    },
    {
      title: "WhatsApp ����",
      key: "member_whatsapp_binding",
      render: (_, record) => {
        const summary = userMemberStatusIndex[record.id];
        if (!summary?.latestBindingStatus) {
          return <Typography.Text type="secondary">����</Typography.Text>;
        }
        return (
          <Space size={[6, 6]} wrap>
            <Tag color={getBindingStatusColor(summary.latestBindingStatus)}>
              {formatBindingStatus(summary.latestBindingStatus)}
            </Tag>
            <Typography.Text type="secondary">{summary.bindingCount} �?/Typography.Text>
          </Space>
        );
      },
    },
    {
      title: "�€������?,
      key: "last_active_at",
      render: (_, record) => formatTimestamp(record.last_active_at),
    },
    {
      title: "����",
      key: "actions",
      render: (_, record) => (
        <Space size={[4, 4]} wrap>
          <Button
            size="small"
            type="link"
            onClick={(event) => {
              event.stopPropagation();
              openWorkspacePage({
                accountId: record.account_id ?? undefined,
                search: record.public_user_id,
              });
            }}
          >
            工作�?          </Button>
          <Button
            size="small"
            type="link"
            onClick={(event) => {
              event.stopPropagation();
              openCustomersPage({
                account_id: record.account_id ?? undefined,
                selected_profile_id: record.id,
                query: record.public_user_id,
              });
            }}
          >
            ����
          </Button>
          <Button
            size="small"
            type="link"
            onClick={(event) => {
              event.stopPropagation();
              openAuditPage({
                account_id: record.account_id ?? undefined,
                target_type: "platform_user",
                target_id: record.public_user_id,
                limit: 50,
              });
            }}
          >
            ���
          </Button>
        </Space>
      ),
    },
  ];

  const accountCount = new Set(filteredUsers.map((item) => item.account_id ?? "unscoped")).size;
  const siteCount = new Set(filteredUsers.map((item) => item.registration_site_id ?? "none")).size;
  const whatsappCount = filteredUsers.filter((item) => item.has_whatsapp).length;
  const activeCount = filteredUsers.filter((item) => item.lifecycle_status === "active").length;
  const latestVerification = memberStatus?.verificationRequests[0] ?? null;
  const latestBinding = memberStatus?.bindingRequests[0] ?? null;

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {selectionWarning ? <Alert message={selectionWarning} showIcon type="warning" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={[
              { label: "ȫ������", value: "ALL" },
              ...accountOptions.map((item) => ({ label: item, value: item })),
            ]}
            onChange={(value) => {
              setSelectionLocked(false);
              setSelectionWarning(null);
              setAccountFilter(value);
            }}
          />
          <Select
            style={{ width: 220 }}
            value={siteFilter}
            options={[
              { label: "ȫ��վ��", value: "ALL" },
              ...siteOptions.map((site) => ({
                label: site.brand_name,
                value: site.id,
              })),
            ]}
            onChange={(value) => {
              setSelectionLocked(false);
              setSelectionWarning(null);
              setSiteFilter(value);
            }}
          />
          <Select
            style={{ width: 180 }}
            value={lifecycleFilter}
            options={lifecycleOptions}
            onChange={(value) => {
              setSelectionLocked(false);
              setSelectionWarning(null);
              setLifecycleFilter(value);
            }}
          />
          <Input.Search
            allowClear
            style={{ width: 280 }}
            placeholder="���������� / ��� / ���"
            value={search}
            onChange={(event) => {
              setSelectionLocked(false);
              setSelectionWarning(null);
              setSearch(event.target.value);
            }}
          />
          <Button loading={loading} onClick={() => void loadData()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="用户�? value={filteredUsers.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��Ծ����" value={activeCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="������Χ" value={accountCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="WhatsApp ���" value={whatsappCount} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<PlatformUser>
            columns={columns}
            dataSource={filteredUsers}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => {
                setSelectionLocked(false);
                setSelectionWarning(null);
                setSelectedUserId(record.id);
              },
            })}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card
              title="��������"
              extra={
                selectedUser ? (
                  <Space size={[8, 8]} wrap>
                    <Button
                      size="small"
                      onClick={() =>
                        openWorkspacePage({
                          accountId: selectedUser.account_id ?? undefined,
                          search: selectedUser.public_user_id,
                        })
                      }
                    >
                      工作�?                    </Button>
                    <Button
                      size="small"
                      onClick={() =>
                        openCustomersPage({
                          account_id: selectedUser.account_id ?? undefined,
                          selected_profile_id: selectedUser.id,
                          query: selectedUser.public_user_id,
                        })
                      }
                    >
                      ����
                    </Button>
                    <Button
                      size="small"
                      onClick={() =>
                        openAuditPage({
                          account_id: selectedUser.account_id ?? undefined,
                          target_type: "platform_user",
                          target_id: selectedUser.public_user_id,
                          limit: 50,
                        })
                      }
                    >
                      ���
                    </Button>
                  </Space>
                ) : null
              }
            >
              {selectedUser ? (
                <Space direction="vertical" size={16} style={{ width: "100%" }}>
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="���� ID">
                      {selectedUser.public_user_id}
                    </Descriptions.Item>
                    <Descriptions.Item label="显ʾ�?>
                      {selectedUser.display_name ?? "����"}
                    </Descriptions.Item>
                    <Descriptions.Item label="����">
                      {selectedUser.account_id ?? "����"}
                    </Descriptions.Item>
                    <Descriptions.Item label="վ��">
                      {selectedUser.registration_site_key ?? "����"}
                    </Descriptions.Item>
                    <Descriptions.Item label="���">
                      {selectedUser.language_code}
                    </Descriptions.Item>
                    <Descriptions.Item label="���€?>
                      <Space size={[8, 8]} wrap>
                        <Tag color={selectedUser.lifecycle_status === "active" ? "success" : "default"}>
                          {formatLifecycleStatus(selectedUser.lifecycle_status)}
                        </Tag>
                        <Tag color={selectedUser.restrict_task_claim ? "warning" : "default"}>
                          {selectedUser.restrict_task_claim ? "����������" : "����?}
                        </Tag>
                      </Space>
                    </Descriptions.Item>
                    <Descriptions.Item label="�€�����">
                      {selectedUser.registration_invite_code ?? "����"}
                    </Descriptions.Item>
                    <Descriptions.Item label="�€������?>
                      {formatTimestamp(selectedUser.last_active_at)}
                    </Descriptions.Item>
                    <Descriptions.Item label="����ʱ��">
                      {formatTimestamp(selectedUser.created_at)}
                    </Descriptions.Item>
                  </Descriptions>

                  <Card size="small" title="���">
                    <Space size={[8, 8]} wrap>
                      {selectedUser.identities.length > 0 ? (
                        selectedUser.identities.map((identity) => (
                          <Tag key={`${identity.identity_type}:${identity.identity_value}`}>
                            {`${identity.identity_type}:${identity.identity_value}`}
                          </Tag>
                        ))
                      ) : (
                        <Typography.Text type="secondary">����</Typography.Text>
                      )}
                    </Space>
                  </Card>

                  <Card size="small" title="���">
                    <Space size={[8, 8]} wrap>
                      {selectedUser.tags.length > 0 ? (
                        selectedUser.tags.map((tag) => (
                          <Tag key={`${selectedUser.id}:${tag.tag_key}`}>{tag.tag_key}</Tag>
                        ))
                      ) : (
                        <Typography.Text type="secondary">����</Typography.Text>
                      )}
                    </Space>
                  </Card>

                  <Card size="small" title="�������������€? extra={<Tag color="blue">API</Tag>}>
                    <Space direction="vertical" size={12} style={{ width: "100%" }}>
                      {memberStatusError ? (
                        <Alert message={memberStatusError} showIcon type="warning" />
                      ) : null}
                      {memberStatusLoading ? (
                        <Typography.Text type="secondary">加载�?/Typography.Text>
                      ) : latestVerification ? (
                        <>
                          <Descriptions bordered column={1} size="small">
                          <Descriptions.Item label="���€?>
                            <Tag color={getVerificationStatusColor(latestVerification.status)}>
                              {formatVerificationStatus(latestVerification.status)}
                            </Tag>
                          </Descriptions.Item>
                            <Descriptions.Item label="��֤����">
                              {latestVerification.requestType}
                            </Descriptions.Item>
                            <Descriptions.Item label="������ע">
                              {latestVerification.reviewNote ?? latestVerification.notes ?? "����"}
                            </Descriptions.Item>
                            <Descriptions.Item label="�€�����������?>
                              {formatTimestamp(latestVerification.updatedAt)}
                            </Descriptions.Item>
                          </Descriptions>
                          <Space size={[8, 8]} wrap>
                            <Typography.Text type="secondary">
                              认֤记¼ {memberStatus?.verificationRequests.length ?? 0} �?                            </Typography.Text>
                            <Button
                              size="small"
                              onClick={() =>
                                openAuditPage({
                                  account_id: selectedUser.account_id ?? undefined,
                                  target_type: "member_verification_request",
                                  target_id: latestVerification.id,
                                  limit: 50,
                                })
                              }
                            >
                              ���
                            </Button>
                          </Space>
                        </>
                      ) : (
                        <Typography.Text type="secondary">������Ա��֤��¼</Typography.Text>
                      )}
                    </Space>
                  </Card>

                  <Card size="small" title="WhatsApp ��������€? extra={<Tag color="blue">API</Tag>}>
                    <Space direction="vertical" size={12} style={{ width: "100%" }}>
                      {memberStatusLoading ? (
                        <Typography.Text type="secondary">加载�?/Typography.Text>
                      ) : latestBinding ? (
                        <>
                          <Descriptions bordered column={1} size="small">
                          <Descriptions.Item label="���€?>
                            <Tag color={getBindingStatusColor(latestBinding.status)}>
                              {formatBindingStatus(latestBinding.status)}
                            </Tag>
                          </Descriptions.Item>
                            <Descriptions.Item label="��������">
                              {latestBinding.requestedPhoneNumber ?? "����"}
                            </Descriptions.Item>
                            <Descriptions.Item label="ʧ��ԭ��">
                              {latestBinding.lastError ?? "����"}
                            </Descriptions.Item>
                            <Descriptions.Item label="�€�����������?>
                              {formatTimestamp(latestBinding.updatedAt)}
                            </Descriptions.Item>
                          </Descriptions>
                          <Space size={[8, 8]} wrap>
                            <Typography.Text type="secondary">
                              绑定记¼ {memberStatus?.bindingRequests.length ?? 0} �?                            </Typography.Text>
                            <Button
                              size="small"
                              onClick={() =>
                                openAuditPage({
                                  account_id: selectedUser.account_id ?? undefined,
                                  target_type: "member_whatsapp_binding_request",
                                  target_id: latestBinding.id,
                                  limit: 50,
                                })
                              }
                            >
                              ���
                            </Button>
                          </Space>
                        </>
                      ) : (
                        <Typography.Text type="secondary">���� WhatsApp ������¼</Typography.Text>
                      )}
                    </Space>
                  </Card>
                </Space>
              ) : (
                <Typography.Text type="secondary">��������</Typography.Text>
              )}
            </Card>

            <Card title="��������">
              <Form<UserFormValues>
                form={form}
                layout="vertical"
                initialValues={{
                  account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                  language_code: "zh-CN",
                  lifecycle_status: "active",
                  is_anonymous: false,
                  restrict_task_claim: false,
                }}
                onFinish={(values) => void handleCreateUser(values)}
              >
                <Row gutter={12}>
                  <Col span={12}>
                    <Form.Item label="���� ID" name="account_id">
                      <Select
                        allowClear
                        options={accountOptions.map((item) => ({ label: item, value: item }))}
                      />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="���� ID" name="public_user_id" rules={[{ required: true }]}>
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="显ʾ�? name="display_name">
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="ע��վ��" name="registration_site_id">
                      <Select
                        allowClear
                        options={createSiteOptions.map((site) => ({
                          label: site.brand_name,
                          value: site.id,
                        }))}
                      />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="��������" name="country_code">
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="��������" name="language_code" rules={[{ required: true }]}>
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="��������" name="lifecycle_status">
                      <Select
                        options={[
                          { label: "���", value: "active" },
                          { label: "����", value: "frozen" },
                          { label: "黑名�?, value: "blacklisted" },
                        ]}
                      />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="�€�����" name="registration_invite_code">
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="手机�? name="phone_identity">
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="�" name="email_identity">
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="WhatsApp ��ʶ" name="whatsapp_identity">
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={24}>
                    <Form.Item label="���" name="tag_keys_text">
                      <Input.TextArea rows={3} placeholder="vip,new-user" />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="��������" name="is_anonymous">
                      <Select
                        options={[
                          { label: "�?, value: false },
                          { label: "�?, value: true },
                        ]}
                      />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="��������" name="restrict_task_claim">
                      <Select
                        options={[
                          { label: "�?, value: false },
                          { label: "�?, value: true },
                        ]}
                      />
                    </Form.Item>
                  </Col>
                </Row>
                <Button htmlType="submit" loading={pendingAction === "create-user"} type="primary" block>
                  ��������
                </Button>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={12} md={12} xs={24}>
          <Card>
            <Statistic title="վ����Χ" value={siteCount} />
          </Card>
        </Col>
        <Col lg={12} md={12} xs={24}>
          <Card>
            <Statistic title="ʵ������" value={filteredUsers.filter((item) => !item.is_anonymous).length} />
          </Card>
        </Col>
      </Row>
    </Space>
  );
}


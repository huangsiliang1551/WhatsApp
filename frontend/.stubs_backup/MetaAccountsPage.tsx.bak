import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Badge,
  Button,
  Card,
  Col,
  Descriptions,
  Divider,
  Form,
  Input,
  Popconfirm,
  Row,
  Select,
  Space,
  Statistic,
  Switch,
  Tabs,
  Tag,
  Tooltip,
  Typography,
} from "antd";

import {
  createEmbeddedSignupSession,
  createManualMetaAccount,
  getLaunchReadiness,
  listEmbeddedSignupSessions,
  listMetaAccounts,
  listMetaPhoneNumbers,
  listMetaWebhookSubscriptions,
  listRuntimeState,
  setAccountAiEnabled,
  subscribeMetaWebhook,
  syncMetaPhoneNumbers,
  updateMetaAccountStatus,
  updateMetaPhoneNumberStatus,
  updateMetaWabaStatus,
  type EmbeddedSignupSession,
  type LaunchReadinessResponse,
  type MetaPhoneNumber,
  type MetaPhoneNumberScopeView,
  type MetaWabaAccount,
  type MetaWebhookSubscriptionView,
  type RuntimeAccountState,
} from "../services/api";
import { useAppStore } from "../stores/appStore";
type ManualFormValues = {
  account_id: string;
  display_name: string;
  meta_business_portfolio_id: string;
  waba_id: string;
  access_token: string;
  verify_token?: string;
  app_secret?: string;
  phone_numbers_text?: string;
};

type SignupFormValues = {
  account_id: string;
  display_name: string;
  redirect_uri: string;
  webhook_callback_url?: string;
  webhook_verify_token?: string;
  webhook_app_id?: string;
};

type WebhookDraft = {
  callback_url: string;
  verify_token: string;
  app_id: string;
};

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function formatBool(value: boolean): string {
  return value ? "�? : "�?;
}

function formatWebhookStatus(status: string | null | undefined): string {
  if (!status) return "����";
  return status.replaceAll("_", " ");
}

function formatQuality(value: string): string {
  if (value === "GREEN") return "��ɫ";
  if (value === "YELLOW") return "��ɫ";
  if (value === "RED") return "��ɫ";
  return "���";
}

function getReadinessColor(ready: boolean): string {
  return ready ? "success" : "default";
}

function parsePhoneNumbers(text: string): MetaPhoneNumber[] {
  return text
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line, index) => {
      const parts = line.split("|").map((item) => item.trim());
      if (parts.length < 5) {
        throw new Error(`号码�?${index + 1} 行格ʽӦ�?phone_number_id|display_phone_number|verified_name|quality|is_registered`);
      }
      return {
        phone_number_id: parts[0],
        display_phone_number: parts[1],
        verified_name: parts[2] || null,
        quality_rating: (parts[3] || "UNKNOWN") as MetaPhoneNumber["quality_rating"],
        is_registered: ["1", "true", "yes", "y"].includes(parts[4].toLowerCase()),
      };
    });
}

function buildWebhookDraft(account: MetaWabaAccount): WebhookDraft {
  return {
    callback_url: account.webhook_callback_url ?? "",
    verify_token: "",
    app_id: "",
  };
}

function getAccountKey(accountId: string, wabaId: string): string {
  return `${accountId}::${wabaId}`;
}

function getFormalActivationLabel(
  account: Pick<
    MetaWabaAccount,
    "ready_for_formal_activation" | "has_root_webhook_routing_conflict"
  >
): string {
  if (account.ready_for_formal_activation) {
    return "�������?;
  }
  if (account.has_root_webhook_routing_conflict) {
    return "根·由冲�?;
  }
  return "��������";
}

function getFormalActivationColor(
  account: Pick<
    MetaWabaAccount,
    "ready_for_formal_activation" | "has_root_webhook_routing_conflict"
  >
): string {
  if (account.ready_for_formal_activation) {
    return "success";
  }
  if (account.has_root_webhook_routing_conflict) {
    return "error";
  }
  return "warning";
}

export function MetaAccountsPage(): JSX.Element {
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openProviderEventsPage = useAppStore((state) => state.openProviderEventsPage);
  const openSystemLogsPage = useAppStore((state) => state.openSystemLogsPage);
  const openWhatsAppStatsPage = useAppStore((state) => state.openWhatsAppStatsPage);
  const metaAccountsPagePrefill = useAppStore((state) => state.metaAccountsPagePrefill);
  const clearMetaAccountsPagePrefill = useAppStore((state) => state.clearMetaAccountsPagePrefill);
  const setMetaAccountsPagePrefill = useAppStore((state) => state.setMetaAccountsPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);
  const [accounts, setAccounts] = useState<MetaWabaAccount[]>([]);
  const [phones, setPhones] = useState<MetaPhoneNumberScopeView[]>([]);
  const [subscriptions, setSubscriptions] = useState<MetaWebhookSubscriptionView[]>([]);
  const [signupSessions, setSignupSessions] = useState<EmbeddedSignupSession[]>([]);
  const [runtimeAccounts, setRuntimeAccounts] = useState<RuntimeAccountState[]>([]);
  const [launchReadiness, setLaunchReadiness] = useState<LaunchReadinessResponse | null>(null);
  const [focusedAccountId, setFocusedAccountId] = useState<string>("all");
  const [selectedAccountKey, setSelectedAccountKey] = useState<string>("");
  const [activeTab, setActiveTab] = useState<"accounts" | "phones" | "webhooks" | "signup">("accounts");
  const [webhookDrafts, setWebhookDrafts] = useState<Record<string, WebhookDraft>>({});
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const [accountSelectionLocked, setAccountSelectionLocked] = useState(false);

  const scopedAccountId = focusedAccountId !== "all" ? focusedAccountId : undefined;

  const selectedAccount = useMemo(
    () => accounts.find((item) => getAccountKey(item.account_id, item.waba_id) === selectedAccountKey) ?? null,
    [accounts, selectedAccountKey]
  );

  const linkedPhones = useMemo(
    () =>
      selectedAccount
        ? phones.filter(
            (item) =>
              item.account_id === selectedAccount.account_id && item.waba_id === selectedAccount.waba_id
          )
        : [],
    [phones, selectedAccount]
  );

  const runtimeAiByAccountId = useMemo(
    () => new Map(runtimeAccounts.map((item) => [item.account_id, item.ai_enabled])),
    [runtimeAccounts]
  );

  useEffect(() => {
    void refreshData();
  }, [focusedAccountId]);

  useEffect(() => {
    if (!metaAccountsPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === metaAccountsPagePrefill.nonce) {
      return;
    }

    lastAppliedPrefillNonce.current = metaAccountsPagePrefill.nonce;
    setFocusedAccountId(metaAccountsPagePrefill.focused_account_id ?? "all");
    setActiveTab(metaAccountsPagePrefill.active_tab ?? "accounts");
    setAccountSelectionLocked(Boolean(metaAccountsPagePrefill.selected_account_key));
    setSelectedAccountKey(metaAccountsPagePrefill.selected_account_key ?? "");
    clearMetaAccountsPagePrefill();
  }, [clearMetaAccountsPagePrefill, metaAccountsPagePrefill]);

  useEffect(() => {
    if (!accounts.length) {
      if (!accountSelectionLocked) {
        setSelectedAccountKey("");
      }
      return;
    }
    if (
      selectedAccountKey &&
      accounts.some((item) => getAccountKey(item.account_id, item.waba_id) === selectedAccountKey)
    ) {
      return;
    }
    if (accountSelectionLocked && selectedAccountKey) {
      return;
    }
    setSelectedAccountKey(getAccountKey(accounts[0].account_id, accounts[0].waba_id));
  }, [accountSelectionLocked, accounts, selectedAccountKey]);

  useEffect(() => {
    setMetaAccountsPagePrefill({
      focused_account_id: focusedAccountId,
      selected_account_key: selectedAccountKey || undefined,
      active_tab: activeTab,
    });
  }, [activeTab, focusedAccountId, selectedAccountKey, setMetaAccountsPagePrefill]);

  async function refreshData(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      const [nextAccounts, nextPhones, nextSubscriptions, nextSignupSessions, nextReadiness] =
        await Promise.all([
          listMetaAccounts(scopedAccountId ? { account_id: scopedAccountId } : undefined),
          listMetaPhoneNumbers(scopedAccountId ? { account_id: scopedAccountId } : undefined),
          listMetaWebhookSubscriptions(scopedAccountId ? { account_id: scopedAccountId } : undefined),
          listEmbeddedSignupSessions(scopedAccountId ? { account_id: scopedAccountId } : undefined),
          getLaunchReadiness(scopedAccountId ? { account_id: scopedAccountId } : undefined),
        ]);
      let nextRuntimeAccounts: RuntimeAccountState[] = [];
      try {
        const runtime = await listRuntimeState();
        nextRuntimeAccounts = runtime.accounts;
      } catch {
        nextRuntimeAccounts = [];
      }

      setAccounts(nextAccounts);
      setPhones(nextPhones);
      setSubscriptions(nextSubscriptions);
      setSignupSessions(nextSignupSessions);
      setRuntimeAccounts(nextRuntimeAccounts);
      setLaunchReadiness(nextReadiness);
      setWebhookDrafts((current) => {
        const next = { ...current };
        nextAccounts.forEach((account) => {
          const key = getAccountKey(account.account_id, account.waba_id);
          if (!next[key]) {
            next[key] = buildWebhookDraft(account);
          }
        });
        return next;
      });
    } catch (refreshError) {
      setError(refreshError instanceof Error ? refreshError.message : "Meta ������������ʧ��");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleToggleAccount(account: MetaWabaAccount): Promise<void> {
    setPendingAction(`account:${account.account_id}`);
    setError(null);
    try {
      await updateMetaAccountStatus(account.account_id, { is_active: !account.account_is_active });
      await refreshData();
      setNotice(`����� ${account.account_id} ���€���������`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������€�����?);
      setPendingAction(null);
    }
  }

  async function handleToggleWaba(account: MetaWabaAccount): Promise<void> {
    const actionKey = getAccountKey(account.account_id, account.waba_id);
    setPendingAction(`waba:${actionKey}`);
    setError(null);
    try {
      await updateMetaWabaStatus(account.account_id, account.waba_id, { is_active: !account.is_active });
      await refreshData();
      setNotice(`WABA ${account.waba_id} ���€���������`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "����� WABA ���€�����?);
      setPendingAction(null);
    }
  }

  async function handleTogglePhone(phone: MetaPhoneNumberScopeView): Promise<void> {
    const actionKey = `${phone.account_id}:${phone.waba_id}:${phone.phone_number_id}`;
    setPendingAction(`phone:${actionKey}`);
    setError(null);
    try {
      await updateMetaPhoneNumberStatus(phone.account_id, phone.waba_id, phone.phone_number_id, {
        is_active: !phone.is_active,
      });
      await refreshData();
      setNotice(`����� ${phone.phone_number_id} ���€���������`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������€�����?);
      setPendingAction(null);
    }
  }

  async function handleToggleAccountAi(accountId: string, enabled: boolean): Promise<void> {
    setPendingAction(`ai:${accountId}`);
    setError(null);
    try {
      await setAccountAiEnabled(accountId, { enabled });
      await refreshData();
      setNotice(`账号 ${accountId} AI ${enabled ? "已开�? : "已关�?}`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "����� AI ���€�����?);
      setPendingAction(null);
    }
  }

  async function handleSyncPhones(account: MetaWabaAccount): Promise<void> {
    const actionKey = getAccountKey(account.account_id, account.waba_id);
    setPendingAction(`sync:${actionKey}`);
    setError(null);
    try {
      await syncMetaPhoneNumbers(account.account_id, account.waba_id);
      await refreshData();
      setNotice(`WABA ${account.waba_id} ��ͬ������`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������");
      setPendingAction(null);
    }
  }

  async function handleSaveWebhook(account: MetaWabaAccount): Promise<void> {
    const accountKey = getAccountKey(account.account_id, account.waba_id);
    const draft = webhookDrafts[accountKey] ?? buildWebhookDraft(account);
    setPendingAction(`webhook:${accountKey}`);
    setError(null);
    try {
      await subscribeMetaWebhook(account.account_id, account.waba_id, {
        callback_url: draft.callback_url.trim(),
        verify_token: draft.verify_token.trim() || undefined,
        app_id: draft.app_id.trim() || undefined,
      });
      await refreshData();
      setNotice(`Webhook ��������${account.waba_id}`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "���� Webhook ʧ��");
      setPendingAction(null);
    }
  }

  async function handleCreateManualAccount(values: ManualFormValues): Promise<void> {
    setPendingAction("create-manual");
    setError(null);
    try {
      await createManualMetaAccount({
        account_id: values.account_id.trim(),
        display_name: values.display_name.trim(),
        meta_business_portfolio_id: values.meta_business_portfolio_id.trim(),
        waba_id: values.waba_id.trim(),
        access_token: values.access_token.trim(),
        verify_token: values.verify_token?.trim() || undefined,
        app_secret: values.app_secret?.trim() || undefined,
        token_source: "system_user",
        phone_numbers: parsePhoneNumbers(values.phone_numbers_text ?? ""),
      });
      await refreshData();
      setNotice(`���� Meta ������������${values.account_id}`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������ʧ��");
      setPendingAction(null);
    }
  }

  async function handleCreateSignup(values: SignupFormValues): Promise<void> {
    setPendingAction("create-signup");
    setError(null);
    try {
      await createEmbeddedSignupSession({
        account_id: values.account_id.trim(),
        display_name: values.display_name.trim(),
        redirect_uri: values.redirect_uri.trim(),
        webhook_subscription: values.webhook_callback_url?.trim()
          ? {
              callback_url: values.webhook_callback_url.trim(),
              verify_token: values.webhook_verify_token?.trim() || undefined,
              app_id: values.webhook_app_id?.trim() || undefined,
            }
          : undefined,
      });
      await refreshData();
      setNotice(`Embedded Signup ������������${values.account_id}`);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "���� Signup ����ʧ��");
      setPendingAction(null);
    }
  }

  const accountOptions = Array.from(new Set(accounts.map((item) => item.account_id))).sort();

  const accountColumns: ProColumns<MetaWabaAccount>[] = [
    {
      title: "���� / WABA",
      key: "scope",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.display_name}</Typography.Text>
          <Typography.Text type="secondary">{`${record.account_id} / ${record.waba_id}`}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "��ʽ����",
      key: "formal",
      render: (_, record) => (
        <Tag color={getFormalActivationColor(record)}>
          {getFormalActivationLabel(record)}
        </Tag>
      ),
    },
    {
      title: "��������",
      key: "local",
      render: (_, record) => (
        <Space size={[6, 6]} wrap>
          <Tag color={getReadinessColor(record.ready_for_meta_activation)}>
            {record.ready_for_meta_activation ? "���������? : "�������?}
          </Tag>
          <Tag color={record.account_is_active ? "success" : "default"}>
            {record.account_is_active ? "��������" : "����������"}
          </Tag>
          <Tag color={record.is_active ? "success" : "default"}>
            {record.is_active ? "WABA ���" : "WABA �����"}
          </Tag>
        </Space>
      ),
    },
    {
      title: "���� AI",
      key: "account_ai",
      render: (_, record) => {
        const aiEnabled = runtimeAiByAccountId.get(record.account_id);
        if (typeof aiEnabled !== "boolean") {
          return <Tag>����?/Tag>;
        }
        return <Tag color={aiEnabled ? "processing" : "default"}>{aiEnabled ? "AI �€�? : "AI �����"}</Tag>;
      },
    },
    {
      title: "Phone",
      key: "phone_count",
      renderText: (_, record) => `${record.registered_phone_number_count} / ${record.phone_number_count}`,
    },
    {
      title: "Webhook",
      key: "webhook",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text>{formatWebhookStatus(record.webhook_subscription_status)}</Typography.Text>
          <Typography.Text type="secondary">
            {formatWebhookStatus(record.webhook_runtime_status)}
          </Typography.Text>
        </Space>
      ),
    },
    {
      title: "����",
      key: "actions",
      render: (_, record) => {
        const accountKey = getAccountKey(record.account_id, record.waba_id);
        return (
          <Space size={[8, 8]} wrap>
            <Button
              size="small"
              loading={pendingAction === `account:${record.account_id}`}
              onClick={() => void handleToggleAccount(record)}
            >
              {record.account_is_active ? "����������" : "��������"}
            </Button>
            <Button
              size="small"
              loading={pendingAction === `waba:${accountKey}`}
              onClick={() => void handleToggleWaba(record)}
            >
              {record.is_active ? "����� WABA" : "��� WABA"}
            </Button>
            <Button
              size="small"
              loading={pendingAction === `sync:${accountKey}`}
              onClick={() => void handleSyncPhones(record)}
            >
              ��������
            </Button>
          </Space>
        );
      },
    },
  ];

  const phoneColumns: ProColumns<MetaPhoneNumberScopeView>[] = [
    {
      title: "����",
      key: "phone",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.display_phone_number}</Typography.Text>
          <Typography.Text type="secondary">{record.phone_number_id}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "������Χ",
      render: (_, record) => `${record.account_id} / ${record.waba_id}`,
    },
    {
      title: "���€?,
      render: (_, record) => (
        <Space size={[6, 6]} wrap>
          <Tag color={record.is_active ? "success" : "default"}>
            {record.is_active ? "���" : "�����"}
          </Tag>
          <Tag color={record.is_registered ? "processing" : "default"}>
            {record.is_registered ? "������? : "����?}
          </Tag>
          <Tag>{formatQuality(record.quality_rating)}</Tag>
        </Space>
      ),
    },
    {
      title: "��������",
      render: (_, record) => (
        <Tag color={getReadinessColor(record.ready_for_meta_activation)}>
          {record.ready_for_meta_activation ? "已就�? : "待补配置"}
        </Tag>
      ),
    },
    {
      title: "����",
      render: (_, record) => (
        <Button size="small" onClick={() => void handleTogglePhone(record)}>
          {record.is_active ? "����������" : "��������"}
        </Button>
      ),
    },
  ];

  const webhookColumns: ProColumns<MetaWebhookSubscriptionView>[] = [
    { title: "����", render: (_, record) => `${record.account_id} / ${record.waba_id}` },
    { title: "������ַ", dataIndex: "callback_url", ellipsis: true },
    { title: "��������€?, render: (_, record) => <Tag>{formatWebhookStatus(record.status)}</Tag> },
    {
      title: "������€?,
      render: (_, record) => <Tag color={record.webhook_runtime_status === "healthy" ? "success" : "warning"}>{formatWebhookStatus(record.webhook_runtime_status)}</Tag>,
    },
    { title: "�€������?, dataIndex: "updated_at", renderText: (value) => formatTimestamp(value) },
  ];

  const signupColumns: ProColumns<EmbeddedSignupSession>[] = [
    { title: "����", render: (_, record) => `${record.display_name} / ${record.account_id}` },
    { title: "���� ID", dataIndex: "session_id", ellipsis: true },
    { title: "���", dataIndex: "completion_stage" },
    { title: "���€?, render: (_, record) => <Tag>{record.status}</Tag> },
    {
      title: "WABA / Portfolio",
      render: (_, record) => `${record.linked_waba_id ?? record.waba_id ?? "����"} / ${record.meta_business_portfolio_id ?? "����"}`,
    },
    { title: "Webhook", render: (_, record) => formatWebhookStatus(record.webhook_subscription_status) },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      
      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="WABA ����" value={accounts.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��������" value={phones.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title="��ʽ����"
              value={accounts.filter((item) => item.ready_for_formal_activation).length}
            />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title="Signup ����?
              value={signupSessions.filter((item) => item.status !== "completed").length}
            />
          </Card>
        </Col>
      </Row>

      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={focusedAccountId}
            options={[
              { label: "ȫ������", value: "all" },
              ...accountOptions.map((item) => ({ label: item, value: item })),
            ]}
            onChange={(value) => {
              setAccountSelectionLocked(false);
              setFocusedAccountId(value);
            }}
          />
          <Button loading={loading} onClick={() => void refreshData()} type="primary">
            ˢ��
          </Button>
          <Button onClick={() => setActiveTab("signup")}>
            接入新账�?
          </Button>
          {launchReadiness ? <Tag>{launchReadiness.summary.overall_status}</Tag> : null}
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={16} xs={24}>
          <Tabs
            activeKey={activeTab}
            items={[
              {
                key: "accounts",
                label: "���� / WABA",
                children: (
                  <ProTable<MetaWabaAccount>
                    columns={accountColumns}
                    dataSource={accounts}
                    loading={loading}
                    options={false}
                    pagination={{ pageSize: 8 }}
                    rowKey={(record) => getAccountKey(record.account_id, record.waba_id)}
                    search={false}
                    toolBarRender={false}
                    onRow={(record) => ({
                      onClick: () => {
                        setAccountSelectionLocked(false);
                        setActiveTab("accounts");
                        setSelectedAccountKey(getAccountKey(record.account_id, record.waba_id));
                      },
                    })}
                  />
                ),
              },
              {
                key: "phones",
                label: "������Χ",
                children: (
                  <ProTable<MetaPhoneNumberScopeView>
                    columns={phoneColumns}
                    dataSource={phones}
                    loading={loading}
                    options={false}
                    pagination={{ pageSize: 10 }}
                    rowKey={(record) => `${record.account_id}:${record.waba_id}:${record.phone_number_id}`}
                    search={false}
                    toolBarRender={false}
                  />
                ),
              },
              {
                key: "webhooks",
                label: "Webhook",
                children: (
                  <ProTable<MetaWebhookSubscriptionView>
                    columns={webhookColumns}
                    dataSource={subscriptions}
                    loading={loading}
                    options={false}
                    pagination={{ pageSize: 10 }}
                    rowKey="id"
                    search={false}
                    toolBarRender={false}
                  />
                ),
              },
              {
                key: "signup",
                label: "Embedded Signup",
                children: (
                  <ProTable<EmbeddedSignupSession>
                    columns={signupColumns}
                    dataSource={signupSessions}
                    loading={loading}
                    options={false}
                    pagination={{ pageSize: 10 }}
                    rowKey="session_id"
                    search={false}
                    toolBarRender={false}
                  />
                ),
              },
            ]}
            onChange={(key) =>
              setActiveTab(key as "accounts" | "phones" | "webhooks" | "signup")
            }
          />
        </Col>

        <Col lg={8} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="ѡ����������">
              {accountSelectionLocked && selectedAccountKey && !selectedAccount ? (
                <Alert message="��������������������������€�����? showIcon type="warning" />
              ) : null}
              {selectedAccount ? (
                <Space direction="vertical" size={16} style={{ width: "100%" }}>
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="���� ID">{selectedAccount.account_id}</Descriptions.Item>
                    <Descriptions.Item label="WABA ID">{selectedAccount.waba_id}</Descriptions.Item>
                    <Descriptions.Item label="Portfolio ID">
                      {selectedAccount.meta_business_portfolio_id}
                    </Descriptions.Item>
                    <Descriptions.Item label="������ʽ">
                      {selectedAccount.onboarding_mode}
                    </Descriptions.Item>
                    <Descriptions.Item label="������Դ">
                      {selectedAccount.token_source}
                    </Descriptions.Item>
                    <Descriptions.Item label="Token ���€?>
                      <Space size={[6, 6]} wrap>
                        <Tag color={selectedAccount.has_access_token ? "success" : "default"}>
                          {selectedAccount.has_access_token ? "Access Token 已配�? : "Access Token ȱʧ"}
                        </Tag>
                        <Tag color={selectedAccount.has_verify_token ? "success" : "default"}>
                          {selectedAccount.has_verify_token ? "Verify Token 已配�? : "Verify Token ȱʧ"}
                        </Tag>
                        <Tag color={selectedAccount.has_app_secret ? "success" : "default"}>
                          {selectedAccount.has_app_secret ? "App Secret 已配�? : "App Secret ȱʧ"}
                        </Tag>
                      </Space>
                    </Descriptions.Item>
                    <Descriptions.Item label="��ʽ����">
                      <Tag color={getFormalActivationColor(selectedAccount)}>
                        {getFormalActivationLabel(selectedAccount)}
                      </Tag>
                    </Descriptions.Item>
                    <Descriptions.Item label="��������">
                      <Tag color={getReadinessColor(selectedAccount.ready_for_meta_activation)}>
                        {selectedAccount.ready_for_meta_activation ? "���������? : "�������?}
                      </Tag>
                    </Descriptions.Item>
                    <Descriptions.Item label="���� AI">
                      {typeof runtimeAiByAccountId.get(selectedAccount.account_id) === "boolean" ? (
                        <Space>
                          <Popconfirm
                            title="� AI �€�?
                            description={
                              runtimeAiByAccountId.get(selectedAccount.account_id)
                                ? "������������������������������� AI �����������������€�������������"
                                : "�€��������������?AI �����������������€�€������?
                            }
                            onConfirm={() =>
                              void handleToggleAccountAi(
                                selectedAccount.account_id,
                                !runtimeAiByAccountId.get(selectedAccount.account_id)
                              )
                            }
                            okText="�"
                            cancelText="ȡ��"
                          >
                            <Switch
                              checked={runtimeAiByAccountId.get(selectedAccount.account_id) ?? false}
                              checkedChildren="AI �€�?
                              unCheckedChildren="AI ����"
                              loading={pendingAction === `ai:${selectedAccount.account_id}`}
                            />
                          </Popconfirm>
                          <Tooltip title="����� AI �€���������������������?AI ����������">
                            <Badge
                              status={runtimeAiByAccountId.get(selectedAccount.account_id) ? "processing" : "default"}
                            />
                          </Tooltip>
                        </Space>
                      ) : (
                        <Space>
                          <Tag>����?/Tag>
                          <Button
                            size="small"
                            loading={pendingAction === `ai:${selectedAccount.account_id}`}
                            onClick={() =>
                              void handleToggleAccountAi(selectedAccount.account_id, true)
                            }
                          >
                            ����?AI
                          </Button>
                        </Space>
                      )}
                    </Descriptions.Item>
                    <Descriptions.Item label="Webhook">
                      {formatWebhookStatus(selectedAccount.webhook_subscription_status)}
                    </Descriptions.Item>
                    <Descriptions.Item label="�€������?>
                      {formatTimestamp(selectedAccount.webhook_last_verified_at)}
                    </Descriptions.Item>
                    <Descriptions.Item label="Webhook ����">
                      <Space direction="vertical" size={4}>
                        <Typography.Text>
                          �€������? {formatTimestamp(selectedAccount.webhook_last_event_received_at)}
                        </Typography.Text>
                        <Typography.Text>
                          �€������? {formatTimestamp(selectedAccount.webhook_last_message_received_at)}
                        </Typography.Text>
                        <Typography.Text>
                          �€������? {formatTimestamp(selectedAccount.webhook_last_status_update_at)}
                        </Typography.Text>
                        {selectedAccount.webhook_signature_failure_count > 0 ? (
                          <Typography.Text type="danger">
                            ǩ名ʧ败: {selectedAccount.webhook_signature_failure_count} �?
                          </Typography.Text>
                        ) : null}
                        {selectedAccount.webhook_runtime_error ? (
                          <Typography.Text type="danger" ellipsis>
                            ���������? {selectedAccount.webhook_runtime_error}
                          </Typography.Text>
                        ) : null}
                        {selectedAccount.webhook_last_verification_error ? (
                          <Typography.Text type="warning" ellipsis>
                            ��������: {selectedAccount.webhook_last_verification_error}
                          </Typography.Text>
                        ) : null}
                      </Space>
                    </Descriptions.Item>
                    <Descriptions.Item label="Webhook ���€?>
                      <Tag color={getReadinessColor(selectedAccount.ready_for_webhook_delivery)}>
                        {selectedAccount.ready_for_webhook_delivery ? "������? : "����?}
                      </Tag>
                    </Descriptions.Item>
                    <Descriptions.Item label="��������€?>
                      <Tag color={getReadinessColor(selectedAccount.ready_for_outbound_messages)}>
                        {selectedAccount.ready_for_outbound_messages ? "������? : "����?}
                      </Tag>
                    </Descriptions.Item>
                    <Descriptions.Item label="����?>
                      {selectedAccount.blocking_reasons.length ? (
                        <Space size={[6, 6]} wrap>
                          {selectedAccount.blocking_reasons.map((reason) => (
                            <Tag color="warning" key={reason}>
                              {reason}
                            </Tag>
                          ))}
                        </Space>
                      ) : (
                        <Tag color="success">�?/Tag>
                      )}
                    </Descriptions.Item>
                    <Descriptions.Item label="根·�?>
                      <Tag
                        color={
                          selectedAccount.has_root_webhook_routing_conflict ? "error" : "success"
                        }
                      >
                        {selectedAccount.has_root_webhook_routing_conflict ? "��ͻ" : "����"}
                      </Tag>
                    </Descriptions.Item>
                  </Descriptions>
                  <Typography.Text type="secondary">
                    ����������������?Webhook �����������������������������€������?Launch Readiness ������?
                  </Typography.Text>
                  {selectedAccount.has_root_webhook_routing_conflict ? (
                    <Typography.Text type="warning">
                      ������������������������?Webhook ������������������������€?
                    </Typography.Text>
                  ) : null}

                  <Space size={[8, 8]} wrap>
                    <Button
                      onClick={() =>
                        openProviderEventsPage({
                          account_id: selectedAccount.account_id,
                          waba_id: selectedAccount.waba_id,
                        })
                      }
                    >
                      ��������
                    </Button>
                    <Button
                      onClick={() =>
                        openWhatsAppStatsPage({
                          account_id: selectedAccount.account_id,
                          waba_id: selectedAccount.waba_id,
                        })
                      }
                    >
                      ���
                    </Button>
                    <Button
                      onClick={() =>
                        openAuditPage({
                          account_id: selectedAccount.account_id,
                          waba_id: selectedAccount.waba_id,
                          target_type: "whatsapp_business_account",
                          target_id: selectedAccount.waba_id,
                          limit: 50,
                        })
                      }
                    >
                      ���
                    </Button>
                    <Button
                      onClick={() =>
                        openSystemLogsPage({
                          account_id: selectedAccount.account_id,
                          source_kind: "provider",
                        })
                      }
                    >
                      ϵͳ��־
                    </Button>
                  </Space>

                  <Card size="small" title="Webhook ����">
                    <Space direction="vertical" size={12} style={{ width: "100%" }}>
                      <Input
                        placeholder="Callback URL"
                        value={webhookDrafts[selectedAccountKey]?.callback_url}
                        onChange={(event) =>
                          setWebhookDrafts((current) => ({
                            ...current,
                            [selectedAccountKey]: {
                              ...(current[selectedAccountKey] ?? buildWebhookDraft(selectedAccount)),
                              callback_url: event.target.value,
                            },
                          }))
                        }
                      />
                      <Input
                        placeholder="Verify Token"
                        value={webhookDrafts[selectedAccountKey]?.verify_token}
                        onChange={(event) =>
                          setWebhookDrafts((current) => ({
                            ...current,
                            [selectedAccountKey]: {
                              ...(current[selectedAccountKey] ?? buildWebhookDraft(selectedAccount)),
                              verify_token: event.target.value,
                            },
                          }))
                        }
                      />
                      <Input
                        placeholder="App ID"
                        value={webhookDrafts[selectedAccountKey]?.app_id}
                        onChange={(event) =>
                          setWebhookDrafts((current) => ({
                            ...current,
                            [selectedAccountKey]: {
                              ...(current[selectedAccountKey] ?? buildWebhookDraft(selectedAccount)),
                              app_id: event.target.value,
                            },
                          }))
                        }
                      />
                      <Button
                        loading={pendingAction === `webhook:${selectedAccountKey}`}
                        onClick={() => void handleSaveWebhook(selectedAccount)}
                        type="primary"
                        block
                      >
                        ���� Webhook
                      </Button>
                    </Space>
                  </Card>

                  <Card size="small" title="��������">
                    <Space direction="vertical" size={8} style={{ width: "100%" }}>
                      {linkedPhones.map((phone) => (
                        <Card key={phone.phone_number_id} size="small">
                          <Space direction="vertical" size={4} style={{ width: "100%" }}>
                            <Typography.Text strong>{phone.display_phone_number}</Typography.Text>
                            <Typography.Text type="secondary">{phone.phone_number_id}</Typography.Text>
                            <Space size={[6, 6]} wrap>
                              <Tag color={phone.is_registered ? "success" : "default"}>
                                {phone.is_registered ? "������? : "����?}
                              </Tag>
                              <Tag color={phone.is_active ? "processing" : "default"}>
                                {phone.is_active ? "���" : "�����"}
                              </Tag>
                              <Tag>{formatQuality(phone.quality_rating)}</Tag>
                            </Space>
                            <Space size={[8, 8]} wrap>
                              <Button
                                size="small"
                                onClick={() =>
                                  openProviderEventsPage({
                                    account_id: phone.account_id,
                                    waba_id: phone.waba_id,
                                    phone_number_id: phone.phone_number_id,
                                  })
                                }
                              >
                                ����
                              </Button>
                              <Button
                                size="small"
                                onClick={() =>
                                  openWhatsAppStatsPage({
                                    account_id: phone.account_id,
                                    waba_id: phone.waba_id,
                                    phone_number_id: phone.phone_number_id,
                                  })
                                }
                              >
                                ���
                              </Button>
                              <Button
                                size="small"
                                onClick={() =>
                                  openAuditPage({
                                    account_id: phone.account_id,
                                    waba_id: phone.waba_id,
                                    phone_number_id: phone.phone_number_id,
                                    target_type: "whatsapp_phone_number",
                                    target_id: phone.phone_number_id,
                                    limit: 50,
                                  })
                                }
                              >
                                ���
                              </Button>
                            </Space>
                          </Space>
                        </Card>
                      ))}
                      {!linkedPhones.length ? (
                        <Typography.Text type="secondary">��������</Typography.Text>
                      ) : null}
                    </Space>
                  </Card>
                </Space>
              ) : (
                <Typography.Text type="secondary">�€���������</Typography.Text>
              )}
            </Card>
          </Space>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={12} xs={24}>
          <Card title="����¼�� Meta ����">
            <Form
              layout="vertical"
              initialValues={{
                account_id: "brand-demo-cn",
                display_name: "Brand Demo CN",
                meta_business_portfolio_id: "portfolio-demo-cn",
                waba_id: "waba-demo-cn",
              }}
              onFinish={(values) => void handleCreateManualAccount(values)}
            >
              <Row gutter={12}>
                <Col span={12}>
                  <Form.Item label="���� ID" name="account_id" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="չʾ����" name="display_name" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="Business Portfolio ID" name="meta_business_portfolio_id" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="WABA ID" name="waba_id" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={24}>
                  <Form.Item label="Access Token" name="access_token" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="Verify Token" name="verify_token">
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="App Secret" name="app_secret">
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={24}>
                  <Form.Item label="��������" name="phone_numbers_text">
                    <Input.TextArea
                      rows={4}
                      placeholder="phone_number_id|display_phone_number|verified_name|quality|is_registered"
                    />
                  </Form.Item>
                </Col>
              </Row>
              <Button htmlType="submit" loading={pendingAction === "create-manual"} type="primary">
                ������������
              </Button>
            </Form>
          </Card>
        </Col>

        <Col lg={12} xs={24}>
          <Card title="Embedded Signup �?>
            <Form
              layout="vertical"
              initialValues={{
                account_id: "brand-signup-demo",
                display_name: "Brand Signup Demo",
                redirect_uri: "https://example.com/meta/embedded-signup/callback",
              }}
              onFinish={(values) => void handleCreateSignup(values)}
            >
              <Row gutter={12}>
                <Col span={12}>
                  <Form.Item label="���� ID" name="account_id" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="չʾ����" name="display_name" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={24}>
                  <Form.Item label="Redirect URI" name="redirect_uri" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={24}>
                  <Form.Item label="Webhook Callback URL" name="webhook_callback_url">
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="Webhook Verify Token" name="webhook_verify_token">
                    <Input />
                  </Form.Item>
                </Col>
                <Col span={12}>
                  <Form.Item label="Webhook App ID" name="webhook_app_id">
                    <Input />
                  </Form.Item>
                </Col>
              </Row>
              <Space direction="vertical" size={8} style={{ width: "100%" }}>
                <Button htmlType="submit" loading={pendingAction === "create-signup"} type="primary">
                  ���� Signup ����
                </Button>
              </Space>
            </Form>
          </Card>
        </Col>
      </Row>
    </Space>
  );
}


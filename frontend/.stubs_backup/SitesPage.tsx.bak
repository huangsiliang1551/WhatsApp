import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  Row,
  Select,
  Space,
  Statistic,
  Tag,
  Typography,
} from "antd";

import {
  createPlatformSite,
  listPlatformSites,
  type PlatformSite,
  type PlatformSiteCreatePayload,
} from "../services/api";
import { useAppStore } from "../stores/appStore";

type SiteStatusFilter = "ALL" | "active" | "paused" | "archived";

const INITIAL_VALUES: PlatformSiteCreatePayload = {
  account_id: undefined,
  site_key: "",
  domain: "",
  brand_name: "",
  default_language: "zh-CN",
  status: "active",
  logo_url: "",
};

const STATUS_OPTIONS: Array<{ label: string; value: SiteStatusFilter }> = [
  { label: "��������€?, value: "ALL" },
  { label: "active", value: "active" },
  { label: "paused", value: "paused" },
  { label: "archived", value: "archived" },
];

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

export function SitesPage(): JSX.Element {
  const [form] = Form.useForm<PlatformSiteCreatePayload>();
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openUsersPage = useAppStore((state) => state.openUsersPage);
  const sitesPagePrefill = useAppStore((state) => state.sitesPagePrefill);
  const clearSitesPagePrefill = useAppStore((state) => state.clearSitesPagePrefill);
  const setSitesPagePrefill = useAppStore((state) => state.setSitesPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);

  const [sites, setSites] = useState<PlatformSite[]>([]);
  const [selectedSiteId, setSelectedSiteId] = useState<string>("");
  const [pendingSelectedSiteKey, setPendingSelectedSiteKey] = useState<string | null>(null);
  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [statusFilter, setStatusFilter] = useState<SiteStatusFilter>("ALL");
  const [selectionLocked, setSelectionLocked] = useState(false);
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const [selectionWarning, setSelectionWarning] = useState<string | null>(null);

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!sitesPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === sitesPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = sitesPagePrefill.nonce;
    setAccountFilter(sitesPagePrefill.account_id ?? "ALL");
    setStatusFilter((sitesPagePrefill.status as SiteStatusFilter | undefined) ?? "ALL");
    setSelectedSiteId(sitesPagePrefill.selected_site_id ?? "");
    setPendingSelectedSiteKey(sitesPagePrefill.selected_site_key ?? null);
    setSelectionLocked(Boolean(sitesPagePrefill.selected_site_id || sitesPagePrefill.selected_site_key));
    setSelectionWarning(null);
    clearSitesPagePrefill();
  }, [clearSitesPagePrefill, sitesPagePrefill]);

  useEffect(() => {
    form.setFieldsValue({
      ...INITIAL_VALUES,
      account_id: accountFilter !== "ALL" ? accountFilter : undefined,
    });
  }, [accountFilter, form]);

  useEffect(() => {
    void loadSites();
  }, []);

  const filteredSites = useMemo(
    () =>
      sites.filter((site) => {
        if (accountFilter !== "ALL" && site.account_id !== accountFilter) {
          return false;
        }
        if (statusFilter !== "ALL" && site.status !== statusFilter) {
          return false;
        }
        return true;
      }),
    [accountFilter, sites, statusFilter]
  );

  useEffect(() => {
    if (!filteredSites.length) {
      setSelectedSiteId("");
      setPendingSelectedSiteKey(null);
      if (selectionLocked) {
        setSelectionLocked(false);
      }
      return;
    }

    if (selectedSiteId && filteredSites.some((site) => site.id === selectedSiteId)) {
      return;
    }

    if (pendingSelectedSiteKey) {
      const matchedSite = filteredSites.find((site) => site.site_key === pendingSelectedSiteKey);
      if (matchedSite) {
        setSelectedSiteId(matchedSite.id);
        setPendingSelectedSiteKey(null);
        setSelectionWarning(null);
        return;
      }
    }

    if (selectionLocked && (selectedSiteId || pendingSelectedSiteKey)) {
      setSelectionWarning("��������������������������€�����?);
      setSelectionLocked(false);
      setPendingSelectedSiteKey(null);
      return;
    }

    setSelectionWarning(null);
    setSelectedSiteId(filteredSites[0].id);
  }, [filteredSites, pendingSelectedSiteKey, selectedSiteId, selectionLocked]);

  // �����������������������������������������������������������������������

  async function loadSites(): Promise<void> {
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      setSites(await listPlatformSites());
      setNotice(`已ˢ�?${new Date().toLocaleString("zh-CN")}`);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "վ������ʧ��");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleSubmit(values: PlatformSiteCreatePayload): Promise<void> {
    setPendingAction("create");
    setError(null);
    setNotice(null);
    try {
      const created = await createPlatformSite({
        account_id: values.account_id?.trim() || undefined,
        site_key: values.site_key.trim(),
        domain: values.domain.trim(),
        brand_name: values.brand_name.trim(),
        default_language: values.default_language.trim(),
        status: values.status,
        logo_url: values.logo_url?.trim() || "",
      });
      setSelectionLocked(false);
      setPendingSelectedSiteKey(null);
      setSelectedSiteId(created.id);
      setNotice(`վ����������${created.brand_name}`);
      form.resetFields();
      form.setFieldsValue({
        ...INITIAL_VALUES,
        account_id: accountFilter !== "ALL" ? accountFilter : undefined,
      });
      await loadSites();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "վ������ʧ��");
      setPendingAction(null);
    }
  }

  const selectedSite = useMemo(
    () => filteredSites.find((site) => site.id === selectedSiteId) ?? null,
    [filteredSites, selectedSiteId]
  );

  const accountOptions = useMemo(() => {
    const values = new Set<string>(actorAccountIds);
    sites.forEach((site) => {
      if (site.account_id) {
        values.add(site.account_id);
      }
    });
    return Array.from(values).filter(Boolean).sort((left, right) => left.localeCompare(right, "zh-CN"));
  }, [actorAccountIds, sites]);

  const columns: ProColumns<PlatformSite>[] = [
    {
      title: "Ʒ��",
      key: "brand_name",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.brand_name}</Typography.Text>
          <Typography.Text type="secondary">{record.site_key}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "������Χ",
      render: (_, record) => record.account_id ?? "ȫ��",
    },
    {
      title: "����",
      dataIndex: "domain",
    },
    {
      title: "���",
      dataIndex: "default_language",
    },
    {
      title: "���€?,
      render: (_, record) => (
        <Tag color={record.status === "active" ? "success" : record.status === "paused" ? "warning" : "default"}>
          {record.status}
        </Tag>
      ),
    },
    {
      title: "����ʱ��",
      render: (_, record) => formatTimestamp(record.updated_at),
    },
  ];

  const activeCount = filteredSites.filter((site) => site.status === "active").length;
  const accountScopeCount = new Set(filteredSites.map((site) => site.account_id ?? "global")).size;
  const customScopedCount = filteredSites.filter((site) => Boolean(site.account_id)).length;

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {selectionWarning ? <Alert message={selectionWarning} showIcon type="warning" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}

      <Card>
        <Space align="center" size={[12, 12]} wrap>
                    <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={[
              { label: "ȫ������", value: "ALL" },
              ...accountOptions.map((item) => ({ label: item, value: item })),
            ]}
            onChange={(value) => {
              setSelectionLocked(false);
              setSelectionWarning(null);
              setAccountFilter(value);
            }}
          />
          <Select
            style={{ width: 160 }}
            value={statusFilter}
            options={STATUS_OPTIONS}
            onChange={(value) => {
              setSelectionLocked(false);
              setSelectionWarning(null);
              setStatusFilter(value);
            }}
          />
          <Button
            disabled={!selectedSite}
            onClick={() =>
              selectedSite
                ? openUsersPage({
                    account_id: selectedSite.account_id ?? undefined,
                    site_id: selectedSite.id,
                  })
                : undefined
            }
          >
            վ������
          </Button>
          <Button loading={loading} onClick={() => void loadSites()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="վ������" value={filteredSites.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="active վ��" value={activeCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="������Χ" value={accountScopeCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="账号级վ�? value={customScopedCount} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<PlatformSite>
            columns={columns}
            dataSource={filteredSites}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => {
                setSelectionLocked(false);
                setSelectionWarning(null);
                setPendingSelectedSiteKey(null);
                setSelectedSiteId(record.id);
              },
            })}
          />
        </Col>
        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card
              title="վ������"
              extra={
                selectedSite ? (
                  <Button
                    size="small"
                    onClick={() =>
                      openUsersPage({
                        account_id: selectedSite.account_id ?? undefined,
                        site_id: selectedSite.id,
                      })
                    }
                  >
                    վ������
                  </Button>
                ) : null
              }
            >
              {selectedSite ? (
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="brand_name">{selectedSite.brand_name}</Descriptions.Item>
                  <Descriptions.Item label="account_id">
                    {selectedSite.account_id ?? "ȫ��"}
                  </Descriptions.Item>
                  <Descriptions.Item label="site_key">{selectedSite.site_key}</Descriptions.Item>
                  <Descriptions.Item label="domain">{selectedSite.domain}</Descriptions.Item>
                  <Descriptions.Item label="default_language">
                    {selectedSite.default_language}
                  </Descriptions.Item>
                  <Descriptions.Item label="status">
                    <Tag
                      color={
                        selectedSite.status === "active"
                          ? "success"
                          : selectedSite.status === "paused"
                            ? "warning"
                            : "default"
                      }
                    >
                      {selectedSite.status}
                    </Tag>
                  </Descriptions.Item>
                  <Descriptions.Item label="logo_url">
                    {selectedSite.logo_url ?? "����"}
                  </Descriptions.Item>
                  <Descriptions.Item label="created_at">
                    {formatTimestamp(selectedSite.created_at)}
                  </Descriptions.Item>
                  <Descriptions.Item label="updated_at">
                    {formatTimestamp(selectedSite.updated_at)}
                  </Descriptions.Item>
                </Descriptions>
              ) : (
                <Typography.Text type="secondary">����վ��</Typography.Text>
              )}
            </Card>

            <Card title="����վ��">
              <Form<PlatformSiteCreatePayload>
                form={form}
                layout="vertical"
                onFinish={(values) => void handleSubmit(values)}
              >
                <Row gutter={12}>
                  <Col span={12}>
                    <Form.Item label="account_id" name="account_id">
                      <Select
                        allowClear
                        options={accountOptions
                          .map((item) => ({ label: item, value: item }))
                          .filter((item) => item.value !== "ALL")}
                      />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="site_key" name="site_key" rules={[{ required: true }]}>
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="domain" name="domain" rules={[{ required: true }]}>
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="brand_name" name="brand_name" rules={[{ required: true }]}>
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item
                      label="default_language"
                      name="default_language"
                      rules={[{ required: true }]}
                    >
                      <Input />
                    </Form.Item>
                  </Col>
                  <Col span={12}>
                    <Form.Item label="status" name="status" rules={[{ required: true }]}>
                      <Select
                        options={[
                          { label: "active", value: "active" },
                          { label: "paused", value: "paused" },
                          { label: "archived", value: "archived" },
                        ]}
                      />
                    </Form.Item>
                  </Col>
                  <Col span={24}>
                    <Form.Item label="logo_url" name="logo_url">
                      <Input />
                    </Form.Item>
                  </Col>
                </Row>
                <Button htmlType="submit" loading={pendingAction === "create"} type="primary" block>
                  ����վ��
                </Button>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>
    </Space>
  );
}


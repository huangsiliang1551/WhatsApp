import { useEffect, useMemo, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  List,
  Row,
  Select,
  Space,
  Statistic,
  Tabs,
  Tag,
  Typography,
} from "antd";

import {
  getSupportTicketStatusLabel,
  listPlatformMemberVerifications,
  listPlatformMemberWhatsAppBindings,
  listReviewQueue,
  listSupportTickets,
  submitReviewDecision,
  type PlatformMemberVerificationRequest,
  type PlatformMemberVerificationTransitionStatus,
  type PlatformMemberWhatsAppBindingRequest,
  type PlatformMemberWhatsAppBindingStatus,
  type ReviewDecisionPayload,
  type ReviewQueueItem,
  type SupportTicket,
  updatePlatformMemberVerificationStatus,
  updatePlatformMemberWhatsAppBindingStatus,
} from "../services/h5";
import { useAppStore } from "../stores/appStore";

type ReviewTabKey = "task_reviews" | "member_verifications" | "whatsapp_bindings";

type MemberVerificationFormValues = {
  status: PlatformMemberVerificationTransitionStatus;
  note?: string;
};

type WhatsAppBindingFormValues = {
  status: PlatformMemberWhatsAppBindingStatus;
  note?: string;
};

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function getPriorityTag(priority: ReviewQueueItem["priority"]): JSX.Element {
  return <Tag color={priority === "high" ? "error" : "default"}>{priority}</Tag>;
}

function getQueueStatusTag(status: ReviewQueueItem["queue_status"]): JSX.Element {
  if (status === "approved") return <Tag color="success">���€����</Tag>;
  if (status === "rejected") return <Tag color="error">已驳�?/Tag>;
  return <Tag color="processing">����?/Tag>;
}

function getVerificationStatusTag(status: PlatformMemberVerificationRequest["status"]): JSX.Element {
  if (status === "approved") return <Tag color="success">���€����</Tag>;
  if (status === "rejected") return <Tag color="error">已驳�?/Tag>;
  if (status === "under_review") return <Tag color="processing">审核�?/Tag>;
  return <Tag color="default">����?/Tag>;
}

function getBindingStatusTag(status: PlatformMemberWhatsAppBindingRequest["status"]): JSX.Element {
  if (status === "bound") return <Tag color="success">已绑�?/Tag>;
  if (status === "failed") return <Tag color="error">ʧ��</Tag>;
  return <Tag color="processing">����?/Tag>;
}

function getTicketStatusColor(status: string): string {
  if (status === "resolved") return "success";
  if (status === "closed" || status === "cancelled") return "default";
  if (status === "pending_user") return "warning";
  return "processing";
}

function getActiveQueueLabel(tab: ReviewTabKey): string {
  if (tab === "member_verifications") {
    return "��Ա��֤";
  }
  if (tab === "whatsapp_bindings") {
    return "WhatsApp ����";
  }
  return "��������";
}

function getVerificationActionOptions(
  item: PlatformMemberVerificationRequest,
): Array<{ label: string; value: PlatformMemberVerificationTransitionStatus }> {
  if (item.status === "pending") {
    return [
      { label: "进入审核�?, value: "under_review" },
      { label: "����ͨ��", value: "approved" },
      { label: "����", value: "rejected" },
    ];
  }
  if (item.status === "under_review") {
    return [
      { label: "����ͨ��", value: "approved" },
      { label: "����", value: "rejected" },
    ];
  }
  return [];
}

function getBindingActionOptions(
  item: PlatformMemberWhatsAppBindingRequest,
): Array<{ label: string; value: PlatformMemberWhatsAppBindingStatus }> {
  if (item.status === "pending") {
    return [
      { label: "���������?, value: "bound" },
      { label: "��������", value: "failed" },
    ];
  }
  if (item.status === "failed") {
    return [
      { label: "��������������?, value: "pending" },
      { label: "���������?, value: "bound" },
    ];
  }
  return [];
}

export function ReviewsPage(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const consoleAgentId = useAppStore((state) => state.consoleAgentId);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openCustomersPage = useAppStore((state) => state.openCustomersPage);
  const openUsersPage = useAppStore((state) => state.openUsersPage);

  const [activeTab, setActiveTab] = useState<ReviewTabKey>("task_reviews");
  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [taskItems, setTaskItems] = useState<ReviewQueueItem[]>([]);
  const [verificationItems, setVerificationItems] = useState<PlatformMemberVerificationRequest[]>([]);
  const [bindingItems, setBindingItems] = useState<PlatformMemberWhatsAppBindingRequest[]>([]);
  const [appeals, setAppeals] = useState<SupportTicket[]>([]);
  const [selectedTaskId, setSelectedTaskId] = useState<string>("");
  const [selectedVerificationId, setSelectedVerificationId] = useState<string>("");
  const [selectedBindingId, setSelectedBindingId] = useState<string>("");
  const [decisionNote, setDecisionNote] = useState("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    void loadPage();
  }, [activeTab, accountFilter]);

  useEffect(() => {
    if (!taskItems.length) {
      setSelectedTaskId("");
      return;
    }
    if (selectedTaskId && taskItems.some((item) => item.id === selectedTaskId)) {
      return;
    }
    setSelectedTaskId(taskItems[0].id);
  }, [selectedTaskId, taskItems]);

  useEffect(() => {
    if (!verificationItems.length) {
      setSelectedVerificationId("");
      return;
    }
    if (selectedVerificationId && verificationItems.some((item) => item.id === selectedVerificationId)) {
      return;
    }
    setSelectedVerificationId(verificationItems[0].id);
  }, [selectedVerificationId, verificationItems]);

  useEffect(() => {
    if (!bindingItems.length) {
      setSelectedBindingId("");
      return;
    }
    if (selectedBindingId && bindingItems.some((item) => item.id === selectedBindingId)) {
      return;
    }
    setSelectedBindingId(bindingItems[0].id);
  }, [selectedBindingId, bindingItems]);

  const selectedTaskItem = useMemo(
    () => taskItems.find((item) => item.id === selectedTaskId) ?? null,
    [selectedTaskId, taskItems],
  );
  const selectedVerificationItem = useMemo(
    () => verificationItems.find((item) => item.id === selectedVerificationId) ?? null,
    [selectedVerificationId, verificationItems],
  );
  const selectedBindingItem = useMemo(
    () => bindingItems.find((item) => item.id === selectedBindingId) ?? null,
    [selectedBindingId, bindingItems],
  );

  const accountOptions = useMemo(() => {
    const values = new Set(actorAccountIds);
    taskItems.forEach((item) => item.account_id && values.add(item.account_id));
    verificationItems.forEach((item) => item.accountId && values.add(item.accountId));
    bindingItems.forEach((item) => item.accountId && values.add(item.accountId));
    appeals.forEach((item) => item.account_id && values.add(item.account_id));
    return [
      { label: "ȫ������", value: "ALL" },
      ...Array.from(values)
        .filter(Boolean)
        .sort((left, right) => left.localeCompare(right, "zh-CN"))
        .map((value) => ({ label: value, value })),
    ];
  }, [actorAccountIds, appeals, bindingItems, taskItems, verificationItems]);

  async function loadPage(): Promise<void> {
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      const targetAccount = accountFilter !== "ALL" ? accountFilter : undefined;
      const appealPromise =
        activeTab === "task_reviews"
          ? listSupportTickets({ account_id: targetAccount, category: "task_appeal" })
          : Promise.resolve<SupportTicket[]>(appeals);

      if (activeTab === "member_verifications") {
        const [nextItems] = await Promise.all([
          listPlatformMemberVerifications({ account_id: targetAccount }),
        ]);
        setVerificationItems(nextItems);
      } else if (activeTab === "whatsapp_bindings") {
        const [nextItems] = await Promise.all([
          listPlatformMemberWhatsAppBindings({ account_id: targetAccount }),
        ]);
        setBindingItems(nextItems);
      } else {
        const [nextQueue, nextAppeals] = await Promise.all([
          listReviewQueue(targetAccount),
          appealPromise,
        ]);
        setTaskItems(nextQueue);
        setAppeals(nextAppeals);
      }

      setNotice(`已ˢ�?${new Date().toLocaleString("zh-CN")}`);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "审核ҳ加载ʧ�?);
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleTaskDecision(decision: "approved" | "rejected"): Promise<void> {
    if (!selectedTaskItem) {
      return;
    }
    setPendingAction(decision);
    setError(null);
    setNotice(null);
    try {
      const updated = await submitReviewDecision(selectedTaskItem.id, {
        decision,
        note: decisionNote.trim() || undefined,
        reviewer_id: consoleAgentId,
      });
      setDecisionNote("");
      setNotice(`${updated.title} ${decision}`);
      await loadPage();
      setSelectedTaskId(updated.id);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "��������ʧ��");
      setPendingAction(null);
    }
  }

  async function handleVerificationSubmit(values: MemberVerificationFormValues): Promise<void> {
    if (!selectedVerificationItem) {
      return;
    }
    if (values.status === "rejected" && !values.note?.trim()) {
      setError("����������������������������������€?);
      return;
    }
    setPendingAction("member_verification");
    setError(null);
    setNotice(null);
    try {
      await updatePlatformMemberVerificationStatus(selectedVerificationItem.id, {
        status: values.status,
        note: values.note?.trim() || undefined,
      });
      setNotice(`�������������€����������?{selectedVerificationItem.memberNo}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������€����������?);
      setPendingAction(null);
    }
  }

  async function handleBindingSubmit(values: WhatsAppBindingFormValues): Promise<void> {
    if (!selectedBindingItem) {
      return;
    }
    if (values.status === "failed" && !values.note?.trim()) {
      setError("��� WhatsApp ����������������������������€?);
      return;
    }
    setPendingAction("whatsapp_binding");
    setError(null);
    setNotice(null);
    try {
      await updatePlatformMemberWhatsAppBindingStatus(selectedBindingItem.id, {
        status: values.status,
        note: values.note?.trim() || undefined,
      });
      setNotice(`WhatsApp ��������€����������?{selectedBindingItem.memberNo}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "WhatsApp ��������€����������?);
      setPendingAction(null);
    }
  }

  const taskColumns: ProColumns<ReviewQueueItem>[] = [
    {
      title: "����",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.title}</Typography.Text>
          <Typography.Text type="secondary">{record.template_name}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "����",
      render: (_, record) => record.account_id,
    },
    {
      title: "���€?,
      render: (_, record) => (
        <Space size={[8, 8]} wrap>
          {getQueueStatusTag(record.queue_status)}
          {getPriorityTag(record.priority)}
        </Space>
      ),
    },
    {
      title: "����",
      render: (_, record) => `${record.wait_minutes} min`,
    },
  ];

  const verificationColumns: ProColumns<PlatformMemberVerificationRequest>[] = [
    { title: "����", dataIndex: "accountId" },
    { title: "会Ա�?, dataIndex: "memberNo" },
    {
      title: "��Ա",
      render: (_, record) => record.displayName ?? record.publicUserId,
    },
    { title: "��֤����", dataIndex: "requestType" },
    { title: "���€?, render: (_, record) => getVerificationStatusTag(record.status) },
  ];

  const bindingColumns: ProColumns<PlatformMemberWhatsAppBindingRequest>[] = [
    { title: "����", dataIndex: "accountId" },
    { title: "会Ա�?, dataIndex: "memberNo" },
    {
      title: "��Ա",
      render: (_, record) => record.displayName ?? record.publicUserId,
    },
    { title: "��������", dataIndex: "requestedPhoneNumber" },
    { title: "���€?, render: (_, record) => getBindingStatusTag(record.status) },
  ];

  const openAppealCount = appeals.filter((item) =>
    ["open", "in_progress", "pending_user"].includes(item.status),
  ).length;

  function renderTaskPanel(): JSX.Element {
    return (
      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<ReviewQueueItem>
            columns={taskColumns}
            dataSource={taskItems}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => setSelectedTaskId(record.id),
            })}
          />
        </Col>
        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="��������" extra={<Tag color="cyan">����</Tag>}>
              {selectedTaskItem ? (
                <Space direction="vertical" size={16} style={{ width: "100%" }}>
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="����">{selectedTaskItem.title}</Descriptions.Item>
                    <Descriptions.Item label="����">{selectedTaskItem.account_id}</Descriptions.Item>
                    <Descriptions.Item label="ģ��">{selectedTaskItem.template_name}</Descriptions.Item>
                    <Descriptions.Item label="��������€?>
                      <Space size={[8, 8]} wrap>
                        {getQueueStatusTag(selectedTaskItem.queue_status)}
                        {getPriorityTag(selectedTaskItem.priority)}
                      </Space>
                    </Descriptions.Item>
                    <Descriptions.Item label="����">{`${selectedTaskItem.wait_minutes} min`}</Descriptions.Item>
                    <Descriptions.Item label="�€������?>
                      {formatTimestamp(selectedTaskItem.submitted_at)}
                    </Descriptions.Item>
                    <Descriptions.Item label="������ע">
                      {selectedTaskItem.submission_note ?? "����"}
                    </Descriptions.Item>
                    <Descriptions.Item label="������ע">
                      {selectedTaskItem.review_note ?? "����"}
                    </Descriptions.Item>
                  </Descriptions>

                  <Input.TextArea
                    rows={4}
                    placeholder="������ע"
                    value={decisionNote}
                    onChange={(event) => setDecisionNote(event.target.value)}
                  />

                  <Space size={[8, 8]} wrap>
                    <Button
                      loading={pendingAction === "approved"}
                      onClick={() => void handleTaskDecision("approved")}
                      type="primary"
                    >
                      ͨ��
                    </Button>
                    <Button
                      danger
                      loading={pendingAction === "rejected"}
                      onClick={() => void handleTaskDecision("rejected")}
                    >
                      ����
                    </Button>
                    <Button
                      onClick={() =>
                        openAuditPage({
                          account_id: selectedTaskItem.account_id,
                          target_id: selectedTaskItem.id,
                          limit: 50,
                        })
                      }
                    >
                      ���
                    </Button>
                  </Space>
                </Space>
              ) : (
                <Typography.Text type="secondary">�������������</Typography.Text>
              )}
            </Card>

            <Card title="��������" extra={<Tag color="cyan">����</Tag>}>
              <List<SupportTicket>
                dataSource={appeals.slice(0, 6)}
                locale={{ emptyText: "������������" }}
                renderItem={(item) => (
                  <List.Item
                    actions={[
                      <Button
                        key={`${item.id}:audit`}
                        onClick={() =>
                          openAuditPage({
                            account_id: item.account_id,
                            target_id: item.id,
                            limit: 50,
                          })
                        }
                        size="small"
                      >
                        ���
                      </Button>,
                    ]}
                  >
                    <List.Item.Meta
                      title={
                        <Space size={[8, 8]} wrap>
                          <span>{item.subject}</span>
                          <Tag color={getTicketStatusColor(item.status)}>
                            {getSupportTicketStatusLabel(item.status)}
                          </Tag>
                          <Tag>{item.priority}</Tag>
                        </Space>
                      }
                      description={
                        <Space direction="vertical" size={0}>
                          <Typography.Text type="secondary">{item.account_id}</Typography.Text>
                          <Typography.Text type="secondary">
                            {formatTimestamp(item.updated_at)}
                          </Typography.Text>
                        </Space>
                      }
                    />
                  </List.Item>
                )}
              />
            </Card>
          </Space>
        </Col>
      </Row>
    );
  }

  function renderVerificationPanel(): JSX.Element {
    const options = selectedVerificationItem ? getVerificationActionOptions(selectedVerificationItem) : [];
    return (
      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<PlatformMemberVerificationRequest>
            columns={verificationColumns}
            dataSource={verificationItems}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => setSelectedVerificationId(record.id),
            })}
          />
        </Col>
        <Col lg={10} xs={24}>
          <Card title="��Ա��֤����" extra={<Tag color="blue">API</Tag>}>
            {selectedVerificationItem ? (
              <Space direction="vertical" size={16} style={{ width: "100%" }}>
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="会Ա�?>{selectedVerificationItem.memberNo}</Descriptions.Item>
                  <Descriptions.Item label="����">{selectedVerificationItem.accountId}</Descriptions.Item>
                  <Descriptions.Item label="��Ա">
                    {selectedVerificationItem.displayName ?? selectedVerificationItem.publicUserId}
                  </Descriptions.Item>
                  <Descriptions.Item label="���€?>
                    {getVerificationStatusTag(selectedVerificationItem.status)}
                  </Descriptions.Item>
                  <Descriptions.Item label="��֤����">
                    {selectedVerificationItem.requestType}
                  </Descriptions.Item>
                  <Descriptions.Item label="����ʱ��">
                    {formatTimestamp(selectedVerificationItem.createdAt)}
                  </Descriptions.Item>
                  <Descriptions.Item label="������ע">
                    {selectedVerificationItem.notes ?? "����"}
                  </Descriptions.Item>
                  <Descriptions.Item label="������ע">
                    {selectedVerificationItem.reviewNote ?? "����"}
                  </Descriptions.Item>
                </Descriptions>

                <Space size={[8, 8]} wrap>
                  <Button
                    onClick={() =>
                      openUsersPage({
                        account_id: selectedVerificationItem.accountId,
                        selected_user_id: selectedVerificationItem.userId,
                        search: selectedVerificationItem.publicUserId,
                      })
                    }
                    size="small"
                  >
                    用户�?                  </Button>
                  <Button
                    onClick={() =>
                      openCustomersPage({
                        account_id: selectedVerificationItem.accountId,
                        selected_profile_id: selectedVerificationItem.userId,
                        query: selectedVerificationItem.publicUserId,
                      })
                    }
                    size="small"
                  >
                    客户�?                  </Button>
                  <Button
                    onClick={() =>
                      openAuditPage({
                        account_id: selectedVerificationItem.accountId,
                        target_id: selectedVerificationItem.id,
                        limit: 50,
                      })
                    }
                    size="small"
                  >
                    ���
                  </Button>
                </Space>

                <Card size="small" title="��֤����">
                  <List
                    dataSource={selectedVerificationItem.documents}
                    locale={{ emptyText: "������֤����" }}
                    renderItem={(document) => (
                      <List.Item key={document.id}>
                        <List.Item.Meta
                          title={document.fileName}
                          description={
                            <Space direction="vertical" size={0}>
                              <Typography.Text type="secondary">
                                {document.storageKey ?? "���� storage key"}
                              </Typography.Text>
                              <Typography.Text type="secondary">
                                {formatTimestamp(document.createdAt)}
                              </Typography.Text>
                            </Space>
                          }
                        />
                      </List.Item>
                    )}
                  />
                </Card>

                {/* �����������������������������������������������������������������€?*/}
                {/* ��������������������������������������������������������������������������������������������������������������������?*/}
                {options.length > 0 ? (
                  <Form
                    key={selectedVerificationItem.id}
                    initialValues={{ status: options[0]?.value, note: "" }}
                    layout="vertical"
                    onFinish={(values) => void handleVerificationSubmit(values as MemberVerificationFormValues)}
                  >
                    <Form.Item label="����" name="status" rules={[{ required: true }]}>
                      <Select options={options} />
                    </Form.Item>
                    <Form.Item label="������ע" name="note">
                      <Input.TextArea rows={4} />
                    </Form.Item>
                    <Button
                      htmlType="submit"
                      loading={pendingAction === "member_verification"}
                      type="primary"
                    >
                      ������Ա��֤����
                    </Button>
                  </Form>
                ) : (
                  <Typography.Text type="secondary">�������������������������������������������€��€?/Typography.Text>
                )}
              </Space>
            ) : (
              <Typography.Text type="secondary">������Ա��֤��������</Typography.Text>
            )}
          </Card>
        </Col>
      </Row>
    );
  }

  function renderBindingPanel(): JSX.Element {
    const options = selectedBindingItem ? getBindingActionOptions(selectedBindingItem) : [];
    return (
      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<PlatformMemberWhatsAppBindingRequest>
            columns={bindingColumns}
            dataSource={bindingItems}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => setSelectedBindingId(record.id),
            })}
          />
        </Col>
        <Col lg={10} xs={24}>
          <Card title="WhatsApp ��������" extra={<Tag color="blue">API</Tag>}>
            {selectedBindingItem ? (
              <Space direction="vertical" size={16} style={{ width: "100%" }}>
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="会Ա�?>{selectedBindingItem.memberNo}</Descriptions.Item>
                  <Descriptions.Item label="����">{selectedBindingItem.accountId}</Descriptions.Item>
                  <Descriptions.Item label="��Ա">
                    {selectedBindingItem.displayName ?? selectedBindingItem.publicUserId}
                  </Descriptions.Item>
                  <Descriptions.Item label="���€?>
                    {getBindingStatusTag(selectedBindingItem.status)}
                  </Descriptions.Item>
                  <Descriptions.Item label="��������">
                    {selectedBindingItem.requestedPhoneNumber ?? "����"}
                  </Descriptions.Item>
                  <Descriptions.Item label="��������">{selectedBindingItem.startCount}</Descriptions.Item>
                  <Descriptions.Item label="�€�����������?>
                    {formatTimestamp(selectedBindingItem.lastStartedAt)}
                  </Descriptions.Item>
                  <Descriptions.Item label="ʧ��ԭ��">
                    {selectedBindingItem.lastError ?? "����"}
                  </Descriptions.Item>
                </Descriptions>

                <Space size={[8, 8]} wrap>
                  <Button
                    onClick={() =>
                      openUsersPage({
                        account_id: selectedBindingItem.accountId,
                        selected_user_id: selectedBindingItem.userId,
                        search: selectedBindingItem.publicUserId,
                      })
                    }
                    size="small"
                  >
                    用户�?                  </Button>
                  <Button
                    onClick={() =>
                      openCustomersPage({
                        account_id: selectedBindingItem.accountId,
                        selected_profile_id: selectedBindingItem.userId,
                        query: selectedBindingItem.publicUserId,
                      })
                    }
                    size="small"
                  >
                    客户�?                  </Button>
                  <Button
                    onClick={() =>
                      openAuditPage({
                        account_id: selectedBindingItem.accountId,
                        target_id: selectedBindingItem.id,
                        limit: 50,
                      })
                    }
                    size="small"
                  >
                    ���
                  </Button>
                </Space>

                {options.length > 0 ? (
                  <Form
                    key={selectedBindingItem.id}
                    initialValues={{ status: options[0]?.value, note: "" }}
                    layout="vertical"
                    onFinish={(values) => void handleBindingSubmit(values as WhatsAppBindingFormValues)}
                  >
                    <Form.Item label="����" name="status" rules={[{ required: true }]}>
                      <Select options={options} />
                    </Form.Item>
                    <Form.Item label="������ע" name="note">
                      <Input.TextArea rows={4} />
                    </Form.Item>
                    <Button
                      htmlType="submit"
                      loading={pendingAction === "whatsapp_binding"}
                      type="primary"
                    >
                      ����� WhatsApp ��������€?                    </Button>
                  </Form>
                ) : (
                  <Typography.Text type="secondary">����� WhatsApp ���������������������������������€��€?/Typography.Text>
                )}
              </Space>
            ) : (
              <Typography.Text type="secondary">���� WhatsApp ������������</Typography.Text>
            )}
          </Card>
        </Col>
      </Row>
    );
  }

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={accountOptions}
            onChange={setAccountFilter}
          />
          <Button loading={loading} onClick={() => void loadPage()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Card>
        <Tabs
          activeKey={activeTab}
          items={[
            { key: "task_reviews", label: "��������" },
            { key: "member_verifications", label: "��Ա��֤" },
            { key: "whatsapp_bindings", label: "WhatsApp ����" },
          ]}
          onChange={(value) => setActiveTab(value as ReviewTabKey)}
        />
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title={`${getActiveQueueLabel(activeTab)}��������`}
              value={
                activeTab === "member_verifications"
                  ? verificationItems.length
                  : activeTab === "whatsapp_bindings"
                    ? bindingItems.length
                    : taskItems.length
              }
            />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic
              title="��������"
              value={
                activeTab === "task_reviews"
                  ? taskItems.filter((item) => item.priority === "high").length
                  : 0
              }
            />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��������" value={appeals.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��������" value={openAppealCount} />
          </Card>
        </Col>
      </Row>

      {activeTab === "member_verifications"
        ? renderVerificationPanel()
        : activeTab === "whatsapp_bindings"
          ? renderBindingPanel()
          : renderTaskPanel()}
    </Space>
  );
}


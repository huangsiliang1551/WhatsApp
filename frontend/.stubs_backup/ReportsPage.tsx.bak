import { useEffect, useMemo, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Row,
  Select,
  Space,
  Statistic,
  Table,
  Tag,
  Typography,
} from "antd";

import { getReportCenterSnapshot } from "../services/operations";
import { useAppStore } from "../stores/appStore";
import type {
  ReportCenterDailyRow,
  ReportCenterSnapshot,
  ReportTemplateOption,
} from "../types/operations";

function formatDate(value: string): string {
  return new Date(value).toLocaleDateString("zh-CN");
}

export function ReportsPage(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openTemplatePage = useAppStore((state) => state.openTemplatePage);
  const openWhatsAppStatsPage = useAppStore((state) => state.openWhatsAppStatsPage);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [templateId, setTemplateId] = useState<string>("ALL");
  const [snapshot, setSnapshot] = useState<ReportCenterSnapshot | null>(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const accountOptions = useMemo<string[]>(() => {
    const values = new Set<string>();
    actorAccountIds.forEach((item) => item && values.add(item));
    snapshot?.daily_rows.forEach((item) => item.account_id && values.add(item.account_id));
    snapshot?.template_options.forEach((item) => item.account_id && values.add(item.account_id));
    if (snapshot?.template_analytics?.account_id) {
      values.add(snapshot.template_analytics.account_id);
    }
    return Array.from(values).sort((left, right) => left.localeCompare(right, "zh-CN"));
  }, [actorAccountIds, snapshot]);

  const templateOptions = useMemo<ReportTemplateOption[]>(
    () =>
      (snapshot?.template_options ?? []).filter((item) =>
        accountFilter === "ALL" ? true : item.account_id === accountFilter
      ),
    [accountFilter, snapshot]
  );

  const selectedTemplate = useMemo(
    () => templateOptions.find((item) => item.template_id === templateId) ?? null,
    [templateId, templateOptions]
  );
  const selectedTemplateAccountId =
    selectedTemplate?.account_id ?? snapshot?.template_analytics?.account_id ?? undefined;
  const effectiveAccountId =
    accountFilter !== "ALL" ? accountFilter : selectedTemplateAccountId ?? undefined;

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (templateId === "ALL") {
      return;
    }
    if (templateOptions.some((item) => item.template_id === templateId)) {
      return;
    }
    setTemplateId("ALL");
  }, [templateId, templateOptions]);

  useEffect(() => {
    void loadSnapshot();
  }, [accountFilter, templateId]);

  async function loadSnapshot(): Promise<void> {
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      setSnapshot(
        await getReportCenterSnapshot(
          accountFilter !== "ALL" ? accountFilter : undefined,
          templateId !== "ALL" ? templateId : undefined
        )
      );
      setNotice(`��ˢ�� ${new Date().toLocaleString("zh-CN")}`);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "������������ʧ��");
    } finally {
      setLoading(false);
    }
  }

  const columns: ProColumns<ReportCenterDailyRow>[] = [
    { title: "����", render: (_, record) => formatDate(record.date) },
    { title: "��Դ", render: (_, record) => <Tag>{record.source_kind}</Tag> },
    { title: "����", dataIndex: "account_id" },
    { title: "����", dataIndex: "label" },
    { title: "��վ", render: (_, record) => record.inbound_count ?? "-" },
    { title: "��վ", render: (_, record) => record.outbound_count ?? "-" },
    { title: "����", dataIndex: "delivered_count" },
    { title: "����", dataIndex: "read_count" },
    { title: "ʧ��", dataIndex: "failed_count" },
    { title: "����", render: (_, record) => record.estimated_cost.toFixed(2) },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}

      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={[
              { label: "ȫ������", value: "ALL" },
              ...accountOptions.map((item) => ({ label: item, value: item })),
            ]}
            onChange={(value) => {
              setAccountFilter(value);
              setTemplateId("ALL");
            }}
          />
          <Select
            style={{ width: 280 }}
            value={templateId}
            options={[
              { label: "ȫ��ģ��", value: "ALL" },
              ...templateOptions.map((item) => ({
                label: `${item.name} / ${item.language}`,
                value: item.template_id,
              })),
            ]}
            onChange={setTemplateId}
          />
          <Button loading={loading} onClick={() => void loadSnapshot()} type="primary">
            ˢ��
          </Button>
          <Button
            disabled={!effectiveAccountId && templateId === "ALL"}
            onClick={() =>
              openTemplatePage({
                account_id: selectedTemplateAccountId ?? effectiveAccountId,
                selected_template_id: templateId !== "ALL" ? templateId : undefined,
              })
            }
          >
            ģ��
          </Button>
          <Button
            disabled={!effectiveAccountId}
            onClick={() =>
              openWhatsAppStatsPage({
                account_id: effectiveAccountId,
              })
            }
          >
            ͳ��
          </Button>
          <Button
            onClick={() =>
              openAuditPage({
                account_id: selectedTemplateAccountId ?? effectiveAccountId,
                target_type: templateId !== "ALL" ? "message_template" : undefined,
                target_id: templateId !== "ALL" ? templateId : undefined,
                limit: 50,
              })
            }
          >
            ����
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        {(snapshot?.kpis ?? []).map((item) => (
          <Col key={item.key} lg={8} md={12} xs={24}>
            <Card extra={<Tag color="blue">API</Tag>} loading={loading}>
              <Statistic title={item.label} value={item.value as string | number} />
              <Typography.Text type="secondary">{item.detail}</Typography.Text>
            </Card>
          </Col>
        ))}
      </Row>

      <ProTable<ReportCenterDailyRow>
        columns={columns}
        dataSource={snapshot?.daily_rows ?? []}
        loading={loading}
        options={false}
        pagination={{ pageSize: 10 }}
        rowKey={(record) => `${record.source_kind}:${record.account_id}:${record.date}:${record.label}`}
        search={false}
        toolBarRender={false}
      />

      <Card extra={<Tag color="blue">API</Tag>} title="ģ������">
        {snapshot?.template_analytics ? (
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Descriptions bordered column={2} size="small">
              <Descriptions.Item label="ģ��">{snapshot.template_analytics.template_name}</Descriptions.Item>
              <Descriptions.Item label="����">{snapshot.template_analytics.account_id}</Descriptions.Item>
              <Descriptions.Item label="����">{snapshot.template_analytics.language}</Descriptions.Item>
              <Descriptions.Item label="����">{snapshot.template_analytics.category}</Descriptions.Item>
              <Descriptions.Item label="����">{snapshot.template_analytics.send_count}</Descriptions.Item>
              <Descriptions.Item label="����">{snapshot.template_analytics.delivered_count}</Descriptions.Item>
              <Descriptions.Item label="����">{snapshot.template_analytics.read_count}</Descriptions.Item>
              <Descriptions.Item label="ʧ��">{snapshot.template_analytics.failed_count}</Descriptions.Item>
              <Descriptions.Item label="Ԥ������">
                {snapshot.template_analytics.estimated_cost.toFixed(2)}
              </Descriptions.Item>
            </Descriptions>
            <Table
              columns={[
                { title: "������", dataIndex: "error_code" },
                { title: "ʧ������", dataIndex: "failed_count" },
              ]}
              dataSource={snapshot.template_analytics.failure_reasons}
              pagination={false}
              rowKey={(record) => record.error_code}
              size="small"
            />
          </Space>
        ) : (
          <Typography.Text type="secondary">δѡ��ģ��</Typography.Text>
        )}
      </Card>
    </Space>
  );
}

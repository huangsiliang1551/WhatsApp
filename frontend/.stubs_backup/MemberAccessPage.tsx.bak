import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  List,
  Row,
  Select,
  Space,
  Statistic,
  Table,
  Tag,
  Typography,
  type TableColumnsType,
} from "antd";

import {
  clearMemberAccessBinding,
  getMemberAccessSnapshot,
  resetMemberAccessBinding,
  saveMemberAccessBinding,
} from "../services/memberAccess";
import { primaryConsoleRoutes } from "../routes/consoleRoutes";
import { useAppStore } from "../stores/appStore";
import type {
  MemberAccessBindingPatch,
  MemberAccessBindingView,
  MemberAccessSnapshot,
} from "../types/memberAccess";
import type { RolePermissionResource } from "../types/operations";

type BindingFormValues = {
  role_key?: string;
  scope: "global" | "account";
  account_scope: string[];
  page_scope: string[];
  access_reason: string;
};

function formatTimestamp(value: string): string {
  return new Date(value).toLocaleString("zh-CN");
}

function getSessionStatusTag(status: MemberAccessBindingView["session_status"]): JSX.Element {
  if (status === "active") return <Tag color="success">����</Tag>;
  if (status === "idle") return <Tag color="warning">����</Tag>;
  if (status === "revoked") return <Tag color="error">已下�?/Tag>;
  return <Tag>����</Tag>;
}

function getResultTag(binding: MemberAccessBindingView): JSX.Element {
  if (binding.access_result === "active") return <Tag color="success">已生�?/Tag>;
  if (binding.access_result === "review") return <Tag color="warning">����?/Tag>;
  return <Tag color="error">����</Tag>;
}

function getPolicyTag(status: MemberAccessBindingView["access_policy_status"]): JSX.Element {
  if (status === "enforced") return <Tag color="success">基线已生�?/Tag>;
  if (status === "partial") return <Tag color="processing">����������Ч</Tag>;
  if (status === "review") return <Tag color="warning">���������?/Tag>;
  return <Tag>��������</Tag>;
}

function getScopeLabel(scope: MemberAccessBindingView["scope"]): string {
  return scope === "global" ? "ȫ��" : "����";
}

function getLoginModeLabel(mode: MemberAccessBindingView["session_login_mode"]): string {
  if (mode === "sso") return "��������";
  if (mode === "password") return "仅密�?;
  return mode;
}

function getSourceTag(source: "hybrid" | "mock"): JSX.Element {
  return <Tag color={source === "hybrid" ? "cyan" : "gold"}>{source === "hybrid" ? "����" : "ģ��"}</Tag>;
}

function buildPageScopeOptions(snapshot: MemberAccessSnapshot | null): string[] {
  const values = new Set<string>();
  primaryConsoleRoutes.forEach((route) => values.add(route.navLabel));
  snapshot?.roles.forEach((role) => role.page_scope.forEach((scope) => values.add(scope)));
  snapshot?.bindings.forEach((binding) => binding.page_scope.forEach((scope) => values.add(scope)));
  return Array.from(values).sort((left, right) => left.localeCompare(right, "zh-CN"));
}

export function MemberAccessPage(): JSX.Element {
  const [form] = Form.useForm<BindingFormValues>();
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const setActivePageRaw = useAppStore((state) => state.setActivePage);
  const openMembersPage = useAppStore((state) => state.openMembersPage);
  const openRolesPage = useAppStore((state) => state.openRolesPage);
  const openAccessControlPage = useAppStore((state) => state.openAccessControlPage);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openIdentitySyncPage = useAppStore((state) => state.openIdentitySyncPage);
  const memberAccessPagePrefill = useAppStore((state) => state.memberAccessPagePrefill);
  const clearMemberAccessPagePrefill = useAppStore((state) => state.clearMemberAccessPagePrefill);
  const setMemberAccessPagePrefill = useAppStore((state) => state.setMemberAccessPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);
  const loadRequestIdRef = useRef(0);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [roleFilter, setRoleFilter] = useState<string>("ALL");
  const [search, setSearch] = useState<string>("");
  const [snapshot, setSnapshot] = useState<MemberAccessSnapshot | null>(null);
  const [selectedBindingId, setSelectedBindingId] = useState<string>("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const setActivePage = (page: "members" | "roles" | "access_control"): void => {
    if (page === "members") {
      openMembersPage({
        account_id:
          selectedBinding?.member_account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
        selected_member_key: selectedBinding
          ? `${selectedBinding.member_account_id ?? "global"}:${selectedBinding.agent_id}`
          : undefined,
      });
      return;
    }
    if (page === "roles") {
      openRolesPage({
        account_id:
          selectedBinding?.member_account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
        selected_role_key:
          selectedBinding?.role_key ?? (roleFilter !== "ALL" ? roleFilter : undefined),
      });
      return;
    }
    if (page === "access_control") {
      openAccessControlPage({
        account_id:
          selectedBinding?.member_account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
      });
      return;
    }
    setActivePageRaw(page);
  };

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!memberAccessPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === memberAccessPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = memberAccessPagePrefill.nonce;
    setAccountFilter(memberAccessPagePrefill.account_id ?? "ALL");
    setRoleFilter(memberAccessPagePrefill.role_key ?? "ALL");
    setSearch(memberAccessPagePrefill.search ?? "");
    setSelectedBindingId(memberAccessPagePrefill.selected_binding_id ?? "");
    clearMemberAccessPagePrefill();
  }, [clearMemberAccessPagePrefill, memberAccessPagePrefill]);

  useEffect(() => {
    void loadPage();
  }, [accountFilter]);

  const filteredBindings = useMemo(() => {
    const keyword = search.trim().toLowerCase();
    return (snapshot?.bindings ?? []).filter((binding) => {
      if (roleFilter !== "ALL" && binding.role_key !== roleFilter) {
        return false;
      }
      if (!keyword) {
        return true;
      }
      return [binding.display_name, binding.agent_id, binding.email ?? "", binding.role_name ?? ""]
        .join(" ")
        .toLowerCase()
        .includes(keyword);
    });
  }, [roleFilter, search, snapshot]);

  useEffect(() => {
    if (!filteredBindings.length) {
      setSelectedBindingId("");
      return;
    }
    if (selectedBindingId && filteredBindings.some((item) => item.binding_id === selectedBindingId)) {
      return;
    }
    setSelectedBindingId(filteredBindings[0].binding_id);
  }, [filteredBindings, selectedBindingId]);

  const selectedBinding = useMemo(
    () => filteredBindings.find((item) => item.binding_id === selectedBindingId) ?? null,
    [filteredBindings, selectedBindingId]
  );

  const selectedRole = useMemo(
    () =>
      selectedBinding?.role_key
        ? snapshot?.roles.find((role) => role.role_key === selectedBinding.role_key) ?? null
        : null,
    [selectedBinding, snapshot]
  );

  useEffect(() => {
    if (!selectedBinding) {
      form.resetFields();
      return;
    }
    form.setFieldsValue({
      role_key: selectedBinding.role_key ?? undefined,
      scope: selectedBinding.scope,
      account_scope: [...selectedBinding.account_scope],
      page_scope: [...selectedBinding.page_scope],
      access_reason: selectedBinding.access_result_reason,
    });
  }, [form, selectedBinding]);

  useEffect(() => {
    setMemberAccessPagePrefill({
      account_id: accountFilter,
      role_key: roleFilter !== "ALL" ? roleFilter : undefined,
      search: search || undefined,
      selected_binding_id: selectedBindingId || undefined,
    });
  }, [
    accountFilter,
    roleFilter,
    search,
    selectedBindingId,
    setMemberAccessPagePrefill,
  ]);

  async function loadPage(): Promise<void> {
    const requestId = ++loadRequestIdRef.current;
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      const nextSnapshot = await getMemberAccessSnapshot(
        accountFilter !== "ALL" ? accountFilter : undefined
      );
      if (requestId !== loadRequestIdRef.current) {
        return;
      }
      setSnapshot(nextSnapshot);
      setNotice(`已ˢ�?${formatTimestamp(nextSnapshot.generated_at)}`);
    } catch (loadError) {
      if (requestId !== loadRequestIdRef.current) {
        return;
      }
      setError(loadError instanceof Error ? loadError.message : "��Ա��Ȩ����ʧ��");
    } finally {
      if (requestId === loadRequestIdRef.current) {
        setLoading(false);
        setPendingAction(null);
      }
    }
  }

  async function handleSave(values: BindingFormValues): Promise<void> {
    if (!selectedBinding || !values.role_key) {
      return;
    }
    const normalizedAccountScope =
      values.scope === "account"
        ? values.account_scope.length > 0
          ? values.account_scope
          : selectedBinding.member_account_id
            ? [selectedBinding.member_account_id]
            : accountFilter !== "ALL"
              ? [accountFilter]
              : []
        : values.account_scope;
    const payload: MemberAccessBindingPatch = {
      agent_id: selectedBinding.agent_id,
      account_id: selectedBinding.member_account_id,
      role_key: values.role_key,
      scope: values.scope,
      account_scope: normalizedAccountScope,
      page_scope: values.page_scope,
      access_reason: values.access_reason,
    };
    setPendingAction(`save:${selectedBinding.binding_id}`);
    setError(null);
    setNotice(null);
    try {
      await saveMemberAccessBinding(payload);
      setNotice(`��Ա��Ȩ��������${selectedBinding.display_name}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "��Ա��Ȩ����ʧ��");
      setPendingAction(null);
    }
  }

  async function handleReset(): Promise<void> {
    if (!selectedBinding) {
      return;
    }
    setPendingAction(`reset:${selectedBinding.binding_id}`);
    setError(null);
    setNotice(null);
    try {
      await resetMemberAccessBinding(selectedBinding.agent_id, selectedBinding.member_account_id);
      setNotice(`�������������${selectedBinding.display_name}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "��Ȩ����ʧ��");
      setPendingAction(null);
    }
  }

  async function handleClear(): Promise<void> {
    if (!selectedBinding) {
      return;
    }
    setPendingAction(`clear:${selectedBinding.binding_id}`);
    setError(null);
    setNotice(null);
    try {
      await clearMemberAccessBinding(selectedBinding.agent_id, selectedBinding.member_account_id);
      setNotice(`�������������${selectedBinding.display_name}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "��ɫ����ʧ��");
      setPendingAction(null);
    }
  }

  const accountOptions = useMemo(() => {
    const values = new Set<string>(actorAccountIds);
    snapshot?.account_ids.forEach((item) => values.add(item));
    return [
      { label: "ȫ������", value: "ALL" },
      ...Array.from(values)
        .filter(Boolean)
        .sort((left, right) => left.localeCompare(right, "zh-CN"))
        .map((value) => ({ label: value, value })),
    ];
  }, [actorAccountIds, snapshot]);

  const roleOptions = useMemo(
    () => [
      { label: "ȫ����ɫ", value: "ALL" },
      ...(snapshot?.roles ?? []).map((role) => ({
        label: role.name,
        value: role.role_key,
      })),
    ],
    [snapshot]
  );

  const bindingColumns: ProColumns<MemberAccessBindingView>[] = [
    {
      title: "��Ա",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.display_name}</Typography.Text>
          <Typography.Text type="secondary">{record.agent_id}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "��ɫ",
      render: (_, record) => (
        <Space size={[8, 8]} wrap>
          <Tag>{record.role_name ?? "����?}</Tag>
          {record.is_override ? <Tag color="gold">����</Tag> : <Tag>����</Tag>}
          {getSourceTag(record.source)}
        </Space>
      ),
    },
    {
      title: "������Χ",
      render: (_, record) => (
        <Typography.Text>{record.account_scope.length ? record.account_scope.join(", ") : "�?}</Typography.Text>
      ),
    },
    {
      title: "����",
      render: (_, record) => getSessionStatusTag(record.session_status),
    },
    {
      title: "����",
      render: (_, record) => getResultTag(record),
    },
  ];

  const permissionColumns: TableColumnsType<RolePermissionResource> = [
    { title: "��Դ", dataIndex: "label", key: "label" },
    { title: "查看", key: "view", render: (_, record) => (record.actions.view ? "�? : "�?) },
    { title: "编辑", key: "edit", render: (_, record) => (record.actions.edit ? "�? : "�?) },
    { title: "分配", key: "assign", render: (_, record) => (record.actions.assign ? "�? : "�?) },
    { title: "审核", key: "approve", render: (_, record) => (record.actions.approve ? "�? : "�?) },
    { title: "导出", key: "export", render: (_, record) => (record.actions.export ? "�? : "�?) },
  ];

  const activeBindingCount =
    snapshot?.bindings.filter((item) => item.access_result === "active").length ?? 0;
  const reviewBindingCount =
    snapshot?.bindings.filter((item) => item.access_result === "review").length ?? 0;
  const overrideCount = snapshot?.bindings.filter((item) => item.is_override).length ?? 0;
  const unboundCount = snapshot?.bindings.filter((item) => item.role_key === null).length ?? 0;
  const pageScopeOptions = buildPageScopeOptions(snapshot);

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      {snapshot?.warnings.map((item) => (
        <Alert key={item} message={item} showIcon type="warning" />
      ))}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select onChange={setAccountFilter} options={accountOptions} style={{ width: 220 }} value={accountFilter} />
          <Select onChange={setRoleFilter} options={roleOptions} style={{ width: 180 }} value={roleFilter} />
          <Input.Search
            allowClear
            onChange={(event) => setSearch(event.target.value)}
            placeholder="���������� / agent / �"
            style={{ width: 260 }}
            value={search}
          />
          <Button onClick={() => setActivePage("members")}>��Ա</Button>
          <Button onClick={() => setActivePage("roles")}>��ɫ</Button>
          <Button onClick={() => setActivePage("access_control")}>��������</Button>
          <Button
            onClick={() =>
              openIdentitySyncPage({
                account_id:
                  selectedBinding?.member_account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
              })
            }
          >
            ������
          </Button>
          <Button
            onClick={() =>
              openAuditPage({
                account_id:
                  selectedBinding?.member_account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
                limit: 50,
              })
            }
          >
            ���
          </Button>
          <Button loading={loading} onClick={() => void loadPage()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��Ա��Ȩ" value={snapshot?.bindings.length ?? 0} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="已生�? value={activeBindingCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="����? value={reviewBindingCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="����� / ����? value={`${overrideCount} / ${unboundCount}`} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��ɫ����" value={snapshot?.roles.length ?? 0} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="������Χ" value={snapshot?.account_ids.length ?? 0} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={13} xs={24}>
          <ProTable<MemberAccessBindingView>
            columns={bindingColumns}
            dataSource={filteredBindings}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey="binding_id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => setSelectedBindingId(record.binding_id),
            })}
          />
        </Col>

        <Col lg={11} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="��Ȩ����">
              {selectedBinding ? (
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="��Ա">{selectedBinding.display_name}</Descriptions.Item>
                  <Descriptions.Item label="��ϯ ID">{selectedBinding.agent_id}</Descriptions.Item>
                  <Descriptions.Item label="�">{selectedBinding.email ?? "�����"}</Descriptions.Item>
                  <Descriptions.Item label="����">{selectedBinding.member_account_id ?? "ȫ��"}</Descriptions.Item>
                  <Descriptions.Item label="��ǰ��ɫ">
                    <Space size={[8, 8]} wrap>
                      <Tag>{selectedBinding.role_name ?? "����?}</Tag>
                      <Tag>{getScopeLabel(selectedBinding.scope)}</Tag>
                      {getSourceTag(selectedBinding.source)}
                    </Space>
                  </Descriptions.Item>
                  <Descriptions.Item label="��������">
                    <Space size={[8, 8]} wrap>
                      {selectedBinding.role_labels.length ? (
                        selectedBinding.role_labels.map((label) => (
                          <Tag key={`${selectedBinding.agent_id}:${label}`}>{label}</Tag>
                        ))
                      ) : (
                        <Typography.Text type="secondary">����</Typography.Text>
                      )}
                    </Space>
                  </Descriptions.Item>
                  <Descriptions.Item label="������Χ">
                    {selectedBinding.account_scope.length ? selectedBinding.account_scope.join(", ") : "�?}
                  </Descriptions.Item>
                  <Descriptions.Item label="ҳ����Χ">
                    {selectedBinding.page_scope.length ? selectedBinding.page_scope.join(", ") : "�?}
                  </Descriptions.Item>
                  <Descriptions.Item label="��������">
                    <Space direction="vertical" size={4}>
                      {getResultTag(selectedBinding)}
                      <Typography.Text type="secondary">{selectedBinding.access_result_reason}</Typography.Text>
                    </Space>
                  </Descriptions.Item>
                  <Descriptions.Item label="��������">
                    <Space direction="vertical" size={4}>
                      {getPolicyTag(selectedBinding.access_policy_status)}
                      <Typography.Text type="secondary">{selectedBinding.access_policy_reason}</Typography.Text>
                    </Space>
                  </Descriptions.Item>
                  <Descriptions.Item label="��̨����">
                    <Space size={[8, 8]} wrap>
                      {getSessionStatusTag(selectedBinding.session_status)}
                      <Tag>{getLoginModeLabel(selectedBinding.session_login_mode)}</Tag>
                      <Tag color={selectedBinding.session_mfa_verified ? "success" : "warning"}>
                        {selectedBinding.session_mfa_verified ? "������? : "����?}
                      </Tag>
                    </Space>
                  </Descriptions.Item>
                </Descriptions>
              ) : (
                <Typography.Text type="secondary">������Ա</Typography.Text>
              )}
            </Card>

            <Card title="��������">
              <Form<BindingFormValues> form={form} layout="vertical" onFinish={(values) => void handleSave(values)}>
                <Form.Item label="��ɫ" name="role_key" rules={[{ required: true }]}>
                  <Select
                    options={(snapshot?.roles ?? []).map((role) => ({
                      label: role.name,
                      value: role.role_key,
                    }))}
                    placeholder="ѡ����ɫ"
                  />
                </Form.Item>
                <Form.Item label="作用�? name="scope" rules={[{ required: true }]}>
                  <Select
                    options={[
                      { label: "账号�?, value: "account" },
                      { label: "ȫ局�?, value: "global" },
                    ]}
                  />
                </Form.Item>
                <Form.Item label="������Χ" name="account_scope">
                  <Select
                    allowClear
                    mode="multiple"
                    options={accountOptions.filter((item) => item.value !== "ALL")}
                    placeholder="�����������������������"
                  />
                </Form.Item>
                <Form.Item label="ҳ����Χ" name="page_scope">
                  <Select
                    allowClear
                    mode="multiple"
                    options={pageScopeOptions.map((item) => ({ label: item, value: item }))}
                    placeholder="�����������������������"
                  />
                </Form.Item>
                <Form.Item label="����ԭ��" name="access_reason" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Space style={{ width: "100%", justifyContent: "space-between" }} wrap>
                  <Button
                    danger
                    disabled={!selectedBinding}
                    loading={pendingAction === `clear:${selectedBinding?.binding_id ?? ""}`}
                    onClick={() => void handleClear()}
                  >
                    ������ɫ
                  </Button>
                  <Space>
                    <Button
                      disabled={!selectedBinding}
                      loading={pendingAction === `reset:${selectedBinding?.binding_id ?? ""}`}
                      onClick={() => void handleReset()}
                    >
                      ��������
                    </Button>
                    <Button
                      disabled={!selectedBinding}
                      htmlType="submit"
                      loading={pendingAction === `save:${selectedBinding?.binding_id ?? ""}`}
                      type="primary"
                    >
                      ��������
                    </Button>
                  </Space>
                </Space>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <Card title="�������������">
            {selectedRole ? (
              <Table<RolePermissionResource>
                columns={permissionColumns}
                dataSource={selectedRole.permissions}
                pagination={false}
                rowKey="resource_key"
                size="small"
              />
            ) : (
              <Typography.Text type="secondary">�����������������?/Typography.Text>
            )}
          </Card>
        </Col>
        <Col lg={10} xs={24}>
          <Card title="�€������?>
            <List
              dataSource={snapshot?.activities ?? []}
              locale={{ emptyText: "��������" }}
              renderItem={(item) => (
                <List.Item>
                  <List.Item.Meta
                    description={
                      <Space direction="vertical" size={0}>
                        <Typography.Text>{item.summary}</Typography.Text>
                        <Typography.Text type="secondary">
                          {`${item.account_id ?? "ȫ��"} / ${formatTimestamp(item.occurred_at)}`}
                        </Typography.Text>
                      </Space>
                    }
                    title={
                      <Space size={[8, 8]} wrap>
                        <span>{item.title}</span>
                        <Tag color={item.level === "warning" ? "warning" : "processing"}>
                          {item.level === "warning" ? "��ע" : "��¼"}
                        </Tag>
                        {getSourceTag(item.source)}
                      </Space>
                    }
                  />
                </List.Item>
              )}
            />
          </Card>
        </Col>
      </Row>
    </Space>
  );
}


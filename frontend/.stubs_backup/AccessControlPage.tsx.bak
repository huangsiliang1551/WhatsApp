import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  InputNumber,
  List,
  Row,
  Select,
  Space,
  Statistic,
  Switch,
  Tag,
  Typography,
} from "antd";

import {
  applyAccessBaseline,
  createAccessPolicy,
  getAccessControlSnapshot,
  revokeAdminSession,
} from "../services/accessControl";
import { listMemberDirectory, listRoleDefinitions } from "../services/operations";
import { useAppStore } from "../stores/appStore";
import type {
  AccessControlSnapshot,
  AccessPolicyCreatePayload,
  AccessPolicyItem,
  AccessSecurityEvent,
  AdminSessionItem,
} from "../types/accessControl";
import type { MemberDirectoryItem, RoleDefinition } from "../types/operations";

type PolicyFormValues = AccessPolicyCreatePayload;

function formatTimestamp(value: string): string {
  return new Date(value).toLocaleString("zh-CN");
}

function getPolicyStatusTag(status: AccessPolicyItem["effective_status"]): JSX.Element {
  if (status === "enforced") return <Tag color="success">已生�?/Tag>;
  if (status === "partial") return <Tag color="processing">������Ч</Tag>;
  return <Tag color="warning">待收�?/Tag>;
}

function getSessionStatusTag(status: AdminSessionItem["status"]): JSX.Element {
  if (status === "active") return <Tag color="success">����</Tag>;
  if (status === "idle") return <Tag color="warning">����</Tag>;
  return <Tag>已下�?/Tag>;
}

function getEventLevelTag(level: AccessSecurityEvent["level"]): JSX.Element {
  if (level === "critical") return <Tag color="error">��������</Tag>;
  if (level === "warning") return <Tag color="warning">��ע</Tag>;
  return <Tag color="processing">����</Tag>;
}

function getAccountLabel(accountId: string | null): string {
  return accountId ?? "ȫ��";
}

function getLoginModeLabel(mode: AccessPolicyItem["login_mode"] | AdminSessionItem["login_mode"]): string {
  if (mode === "mixed") return "����";
  if (mode === "sso") return "��������";
  if (mode === "sso_first") return "�������������";
  if (mode === "password") return "仅密�?;
  return mode;
}

function getSourceTag(source: "hybrid" | "mock"): JSX.Element {
  return <Tag color={source === "hybrid" ? "cyan" : "gold"}>{source === "hybrid" ? "����" : "ģ��"}</Tag>;
}

export function AccessControlPage(): JSX.Element {
  const [form] = Form.useForm<PolicyFormValues>();
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openIdentitySyncPage = useAppStore((state) => state.openIdentitySyncPage);
  const openUsersPage = useAppStore((state) => state.openUsersPage);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openEvidencePage = useAppStore((state) => state.openEvidencePage);
  const openRolesPage = useAppStore((state) => state.openRolesPage);
  const openMembersPage = useAppStore((state) => state.openMembersPage);
  const openSecuritySettingsPage = useAppStore((state) => state.openSecuritySettingsPage);
  const accessControlPagePrefill = useAppStore((state) => state.accessControlPagePrefill);
  const clearAccessControlPagePrefill = useAppStore((state) => state.clearAccessControlPagePrefill);
  const setAccessControlPagePrefill = useAppStore((state) => state.setAccessControlPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);
  const loadRequestIdRef = useRef(0);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [snapshot, setSnapshot] = useState<AccessControlSnapshot | null>(null);
  const [roles, setRoles] = useState<RoleDefinition[]>([]);
  const [members, setMembers] = useState<MemberDirectoryItem[]>([]);
  const [selectedPolicyId, setSelectedPolicyId] = useState<string>("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const setActivePage = (page: "identity_sync"): void => {
    if (page === "identity_sync") {
      openIdentitySyncPage({
        account_id:
          selectedPolicy?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
      });
    }
  };

  const selectedPolicy = useMemo(
    () => snapshot?.policies.find((item) => item.policy_id === selectedPolicyId) ?? null,
    [selectedPolicyId, snapshot]
  );

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!accessControlPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === accessControlPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = accessControlPagePrefill.nonce;
    setAccountFilter(accessControlPagePrefill.account_id ?? "ALL");
    setSelectedPolicyId(accessControlPagePrefill.selected_policy_id ?? "");
    clearAccessControlPagePrefill();
  }, [accessControlPagePrefill, clearAccessControlPagePrefill]);

  useEffect(() => {
    void loadPage();
  }, [accountFilter]);

  useEffect(() => {
    form.setFieldsValue({
      account_id: accountFilter !== "ALL" ? accountFilter : undefined,
    });
  }, [accountFilter, form]);

  useEffect(() => {
    if (!snapshot?.policies.length) {
      setSelectedPolicyId("");
      return;
    }

    if (selectedPolicyId && snapshot.policies.some((item) => item.policy_id === selectedPolicyId)) {
      return;
    }

    setSelectedPolicyId(snapshot.policies[0].policy_id);
  }, [selectedPolicyId, snapshot]);

  useEffect(() => {
    setAccessControlPagePrefill({
      account_id: accountFilter,
      selected_policy_id: selectedPolicyId || undefined,
    });
  }, [accountFilter, selectedPolicyId, setAccessControlPagePrefill]);

  async function loadPage(): Promise<void> {
    const requestId = ++loadRequestIdRef.current;
    setLoading(true);
    setError(null);
    setNotice(null);

    const targetAccount = accountFilter !== "ALL" ? accountFilter : undefined;
    const [snapshotResult, rolesResult, membersResult] = await Promise.allSettled([
      getAccessControlSnapshot(targetAccount),
      listRoleDefinitions(targetAccount),
      listMemberDirectory(targetAccount),
    ]);

    if (snapshotResult.status !== "fulfilled") {
      if (requestId !== loadRequestIdRef.current) {
        return;
      }
      setError(
        snapshotResult.reason instanceof Error ? snapshotResult.reason.message : "������������ʧ��"
      );
      setPendingAction(null);
      setLoading(false);
      return;
    }

    if (requestId !== loadRequestIdRef.current) {
      return;
    }
    setSnapshot(snapshotResult.value);
    setRoles(rolesResult.status === "fulfilled" ? rolesResult.value : []);
    setMembers(membersResult.status === "fulfilled" ? membersResult.value : []);
    setPendingAction(null);
    setLoading(false);

    if (membersResult.status !== "fulfilled") {
      setNotice("������������?);
      return;
    }

    setNotice(`已ˢ�?${formatTimestamp(snapshotResult.value.generated_at)}`);
  }

  async function handleApplyBaseline(policyId: string): Promise<void> {
    setPendingAction(`baseline:${policyId}`);
    setError(null);
    setNotice(null);
    try {
      const updated = await applyAccessBaseline(policyId);
      setNotice(`��Ӧ��������${getAccountLabel(updated.account_id)}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "Ӧ������ʧ��");
      setPendingAction(null);
    }
  }

  async function handleRevokeSession(sessionId: string): Promise<void> {
    setPendingAction(`session:${sessionId}`);
    setError(null);
    setNotice(null);
    try {
      const updated = await revokeAdminSession(sessionId);
      setNotice(`��������${updated.display_name}`);
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������̨����ʧ��");
      setPendingAction(null);
    }
  }

  async function handleCreatePolicy(values: PolicyFormValues): Promise<void> {
    setPendingAction("create-policy");
    setError(null);
    setNotice(null);
    try {
      const created = await createAccessPolicy(values);
      setNotice(`������������${getAccountLabel(created.account_id)}`);
      form.resetFields();
      form.setFieldsValue({
        account_id: accountFilter !== "ALL" ? accountFilter : undefined,
        login_mode: "mixed",
        mfa_required: true,
        session_timeout_minutes: 480,
        ip_allowlist_enabled: false,
        audit_export_enabled: true,
        webhook_signature_enforced: true,
        effective_reason: "",
      });
      await loadPage();
      setSelectedPolicyId(created.policy_id);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������ʧ��");
      setPendingAction(null);
    }
  }

  const accountOptions = useMemo(() => {
    const values = new Set<string>(actorAccountIds);
    snapshot?.policies.forEach((item) => {
      if (item.account_id) values.add(item.account_id);
    });
    members.forEach((item) => {
      if (item.account_id) values.add(item.account_id);
    });
    return [
      { label: "ȫ������", value: "ALL" },
      ...Array.from(values).map((value) => ({ label: value, value })),
    ];
  }, [actorAccountIds, members, snapshot]);

  const policyColumns: ProColumns<AccessPolicyItem>[] = [
    {
      title: "����",
      render: (_, record) => getAccountLabel(record.account_id),
    },
    {
      title: "��¼",
      dataIndex: "login_mode",
      render: (_, record) => <Tag>{getLoginModeLabel(record.login_mode)}</Tag>,
    },
    {
      title: "˫����֤",
      render: (_, record) => (
        <Tag color={record.mfa_required ? "success" : "warning"}>
          {record.mfa_required ? "�����" : "�€?}
        </Tag>
      ),
    },
    {
      title: "����",
      render: (_, record) => `${record.session_timeout_minutes} ����`,
    },
    {
      title: "IP",
      render: (_, record) => (record.ip_allowlist_enabled ? "������? : "�€�?),
    },
    {
      title: "����",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Space size={[8, 8]} wrap>
            {getPolicyStatusTag(record.effective_status)}
            {getSourceTag(record.source)}
          </Space>
          <Typography.Text type="secondary">{record.effective_reason}</Typography.Text>
        </Space>
      ),
    },
  ];

  const sessionColumns: ProColumns<AdminSessionItem>[] = [
    {
      title: "��Ա",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.display_name}</Typography.Text>
          <Typography.Text type="secondary">{record.role_name}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "����",
      render: (_, record) => getAccountLabel(record.account_id),
    },
    {
      title: "��¼",
      render: (_, record) => (
        <Space size={[8, 8]} wrap>
          <Tag>{getLoginModeLabel(record.login_mode)}</Tag>
          <Tag color={record.mfa_verified ? "success" : "warning"}>
            {record.mfa_verified ? "������? : "����?}
          </Tag>
        </Space>
      ),
    },
    {
      title: "���",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <span>{record.device_label}</span>
          <Typography.Text type="secondary">{record.ip_address}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "���€?,
      render: (_, record) => (
        <Space size={[8, 8]} wrap>
          {getSessionStatusTag(record.status)}
          {getSourceTag(record.source)}
        </Space>
      ),
    },
    {
      title: "�€������?,
      render: (_, record) => formatTimestamp(record.last_seen_at),
    },
    {
      title: "����",
      render: (_, record) => (
        <Button
          danger
          disabled={record.status === "revoked"}
          loading={pendingAction === `session:${record.session_id}`}
          onClick={() => void handleRevokeSession(record.session_id)}
          size="small"
        >
          ǿ������
        </Button>
      ),
    },
  ];

  const activeSessionCount =
    snapshot?.sessions.filter((item) => item.status !== "revoked").length ?? 0;
  const enforcedPolicyCount =
    snapshot?.policies.filter((item) => item.effective_status === "enforced").length ?? 0;
  const mfaPolicyCount = snapshot?.policies.filter((item) => item.mfa_required).length ?? 0;
  const ipWhitelistCount =
    snapshot?.policies.filter((item) => item.ip_allowlist_enabled).length ?? 0;
  const criticalEventCount =
    snapshot?.events.filter((item) => item.level === "critical").length ?? 0;
  const warningEventCount =
    snapshot?.events.filter((item) => item.level === "warning").length ?? 0;

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            onChange={setAccountFilter}
            options={accountOptions}
            style={{ width: 220 }}
            value={accountFilter}
          />
          <Button
            onClick={() =>
              openUsersPage({
                account_id:
                  selectedPolicy?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
              })
            }
            type="default"
          >
            ����
          </Button>
          <Button
            onClick={() =>
              openRolesPage({
                account_id:
                  selectedPolicy?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
              })
            }
            type="default"
          >
            ��ɫ
          </Button>
          <Button
            onClick={() =>
              openMembersPage({
                account_id:
                  selectedPolicy?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
              })
            }
            type="default"
          >
            ��Ա
          </Button>
          <Button
            onClick={() =>
              openSecuritySettingsPage({
                account_id:
                  selectedPolicy?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
              })
            }
            type="default"
          >
            ��ȫ����
          </Button>
          <Button onClick={() => setActivePage("identity_sync")} type="default">
            ������
          </Button>
          <Button
            onClick={() =>
              openEvidencePage({
                account_id:
                  selectedPolicy?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
                source_kind: "audit",
              })
            }
          >
            ��������
          </Button>
          <Button
            onClick={() =>
              openAuditPage({
                account_id:
                  selectedPolicy?.account_id ?? (accountFilter !== "ALL" ? accountFilter : undefined),
                limit: 50,
              })
            }
          >
            ���
          </Button>
          <Button loading={loading} onClick={() => void loadPage()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��������" value={snapshot?.policies.length ?? 0} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="已生Ч策�? value={enforcedPolicyCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="˫����֤����" value={mfaPolicyCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="IP 白名�? value={ipWhitelistCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��̨����" value={activeSessionCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="���������? value={criticalEventCount} valueStyle={{ color: criticalEventCount > 0 ? "#cf1322" : undefined }} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="��ע����" value={warningEventCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="角ɫ�? value={roles.length} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<AccessPolicyItem>
            columns={policyColumns}
            dataSource={snapshot?.policies ?? []}
            loading={loading}
            options={false}
            pagination={{ pageSize: 6 }}
            rowKey="policy_id"
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => setSelectedPolicyId(record.policy_id),
            })}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card
              extra={
                selectedPolicy ? (
                  <Button
                    loading={pendingAction === `baseline:${selectedPolicy.policy_id}`}
                    onClick={() => void handleApplyBaseline(selectedPolicy.policy_id)}
                    type="primary"
                  >
                    Ӧ������
                  </Button>
                ) : null
              }
              title="��������"
            >
              {selectedPolicy ? (
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="����">
                    {getAccountLabel(selectedPolicy.account_id)}
                  </Descriptions.Item>
                  <Descriptions.Item label="��Χ">
                    {selectedPolicy.scope === "global" ? "ȫ��" : "����"}
                  </Descriptions.Item>
                  <Descriptions.Item label="��¼">
                    {getLoginModeLabel(selectedPolicy.login_mode)}
                  </Descriptions.Item>
                  <Descriptions.Item label="����">
                    <Space direction="vertical" size={4}>
                      <Space size={[8, 8]} wrap>
                        {getPolicyStatusTag(selectedPolicy.effective_status)}
                        {getSourceTag(selectedPolicy.source)}
                      </Space>
                      <Typography.Text type="secondary">
                        {selectedPolicy.effective_reason}
                      </Typography.Text>
                    </Space>
                  </Descriptions.Item>
                  <Descriptions.Item label="˫����֤">
                    {selectedPolicy.mfa_required ? "�����" : "�€?}
                  </Descriptions.Item>
                  <Descriptions.Item label="IP 白名�?>
                    {selectedPolicy.ip_allowlist_enabled ? "�€�? : "�����"}
                  </Descriptions.Item>
                  <Descriptions.Item label="Webhook ǩ��">
                    {selectedPolicy.webhook_signature_enforced ? "ǿ��" : "����"}
                  </Descriptions.Item>
                  <Descriptions.Item label="����ʱ��">
                    {formatTimestamp(selectedPolicy.updated_at)}
                  </Descriptions.Item>
                </Descriptions>
              ) : (
                <Typography.Text type="secondary">��������</Typography.Text>
              )}
            </Card>

            <Card title="��������">
              <Form<PolicyFormValues>
                form={form}
                initialValues={{
                  login_mode: "mixed",
                  mfa_required: true,
                  session_timeout_minutes: 480,
                  ip_allowlist_enabled: false,
                  audit_export_enabled: true,
                  webhook_signature_enforced: true,
                  effective_reason: "",
                }}
                layout="vertical"
                onFinish={(values) => void handleCreatePolicy(values)}
              >
                <Form.Item label="����" name="account_id">
                  <Select
                    allowClear
                    options={accountOptions.filter((item) => item.value !== "ALL")}
                  />
                </Form.Item>
                <Form.Item label="��¼��ʽ" name="login_mode" rules={[{ required: true }]}>
                  <Select
                    options={[
                      { label: "����", value: "mixed" },
                      { label: "������€���", value: "sso" },
                      { label: "仅密�?, value: "password" },
                    ]}
                  />
                </Form.Item>
                <Form.Item
                  label="����ʱ��"
                  name="session_timeout_minutes"
                  rules={[{ required: true }]}
                >
                  <InputNumber min={30} step={30} style={{ width: "100%" }} />
                </Form.Item>
                <Form.Item label="����ԭ��" name="effective_reason" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Space size={16} wrap>
                  <Form.Item label="ǿ��˫����֤" name="mfa_required" valuePropName="checked">
                    <Switch />
                  </Form.Item>
                  <Form.Item
                    label="IP 白名�?
                    name="ip_allowlist_enabled"
                    valuePropName="checked"
                  >
                    <Switch />
                  </Form.Item>
                  <Form.Item
                    label="��������"
                    name="audit_export_enabled"
                    valuePropName="checked"
                  >
                    <Switch />
                  </Form.Item>
                  <Form.Item
                    label="ǩ��У��"
                    name="webhook_signature_enforced"
                    valuePropName="checked"
                  >
                    <Switch />
                  </Form.Item>
                </Space>
                <Button
                  block
                  htmlType="submit"
                  loading={pendingAction === "create-policy"}
                  type="primary"
                >
                  ��������
                </Button>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<AdminSessionItem>
            columns={sessionColumns}
            dataSource={snapshot?.sessions ?? []}
            loading={loading}
            options={false}
            pagination={{ pageSize: 6 }}
            rowKey="session_id"
            search={false}
            toolBarRender={false}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
           <Card title="ȫ������" extra={snapshot ? getPolicyStatusTag(snapshot.global_settings.mfa_required ? "enforced" : "partial") : null}>
              <Descriptions bordered column={1} size="small">
                <Descriptions.Item label="��¼">
                  {snapshot ? getLoginModeLabel(snapshot.global_settings.login_mode) : "����"}
                </Descriptions.Item>
                <Descriptions.Item label="˫����֤">
                  {snapshot?.global_settings.mfa_required ? "ǿ��" : "����"}
                </Descriptions.Item>
                <Descriptions.Item label="����ʱ��">
                  {snapshot?.global_settings.session_timeout_minutes ?? 0} ����
                </Descriptions.Item>
                <Descriptions.Item label="IP 白名�?>
                  {snapshot?.global_settings.ip_allowlist_enabled ? "�€�? : "�����"}
                </Descriptions.Item>
                <Descriptions.Item label="Webhook ǩ��">
                  {snapshot?.global_settings.webhook_signature_enforced ? "ǿ��" : "����"}
                </Descriptions.Item>
                <Descriptions.Item label="角ɫ�?>{roles.length}</Descriptions.Item>
                <Descriptions.Item label="成Ա�?>{members.length}</Descriptions.Item>
                <Descriptions.Item label="覆盖�?>
                  <Space direction="vertical" size={4}>
                    <Typography.Text>
                      ������Ч: {enforcedPolicyCount} / {snapshot?.policies.length ?? 0}
                    </Typography.Text>
                    <Typography.Text>
                      ˫����֤: {mfaPolicyCount} / {snapshot?.policies.length ?? 0}
                    </Typography.Text>
                    <Typography.Text>
                      IP 白名�? {ipWhitelistCount} / {snapshot?.policies.length ?? 0}
                    </Typography.Text>
                  </Space>
                </Descriptions.Item>
              </Descriptions>
            </Card>

            <Card title="�€������?>
              <List
                dataSource={snapshot?.events ?? []}
                locale={{ emptyText: "��������" }}
                renderItem={(item) => (
                  <List.Item
                    actions={[
                      <Button
                        key={`${item.event_id}:audit`}
                        onClick={() =>
                          openAuditPage({
                            account_id: item.account_id ?? undefined,
                            limit: 50,
                          })
                        }
                        type="link"
                      >
                        ���
                      </Button>,
                    ]}
                  >
                    <List.Item.Meta
                      description={
                        <Space direction="vertical" size={0}>
                          <Typography.Text>{item.summary}</Typography.Text>
                          <Typography.Text type="secondary">
                            {`${getAccountLabel(item.account_id)} �� ${formatTimestamp(item.occurred_at)}`}
                          </Typography.Text>
                        </Space>
                      }
                      title={
                        <Space size={[8, 8]} wrap>
                          <span>{item.title}</span>
                          {getEventLevelTag(item.level)}
                          {getSourceTag(item.source)}
                        </Space>
                      }
                    />
                  </List.Item>
                )}
              />
            </Card>
          </Space>
        </Col>
      </Row>
    </Space>
  );
}


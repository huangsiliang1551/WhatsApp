import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Row,
  Select,
  Space,
  Statistic,
  Table,
  Tag,
  Typography,
} from "antd";

import {
  listMetaWebhookSubscriptions,
  listProviderStatusBuffer,
  replayProviderStatusBuffer,
  type MetaWebhookRuntimeStatus,
  type MetaWebhookSubscriptionStatus,
  type MetaWebhookSubscriptionView,
  type ProviderStatusBufferEntry,
  type ProviderStatusBufferListResponse,
} from "../services/api";
import { useAppStore } from "../stores/appStore";

type ReplayFilter = "ALL" | "pending" | "replayed";
type RuntimeFilter = "ALL" | MetaWebhookRuntimeStatus;

type ProviderEventsState = {
  provider: ProviderStatusBufferListResponse | null;
  subscriptions: MetaWebhookSubscriptionView[];
};

const EMPTY_STATE: ProviderEventsState = {
  provider: null,
  subscriptions: [],
};

function formatTimestamp(value: string | null | undefined): string {
  if (!value) return "-";
  return new Date(value).toLocaleString("zh-CN");
}

function getReplayColor(replayState: string): string {
  if (replayState === "replayed") return "success";
  if (replayState === "pending") return "warning";
  return "default";
}

function getWebhookStatusColor(status: MetaWebhookSubscriptionStatus): string {
  if (status === "subscribed" || status === "remote_subscribed") return "success";
  if (status === "remote_pending" || status === "pending") return "warning";
  return "default";
}

function getRuntimeStatusColor(status: MetaWebhookRuntimeStatus): string {
  if (status === "healthy") return "success";
  if (status === "verification_pending" || status === "pending") return "warning";
  if (status === "signature_failed" || status === "payload_invalid") return "error";
  return "default";
}

export function ProviderEventsPage(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const providerEventsPagePrefill = useAppStore((state) => state.providerEventsPagePrefill);
  const clearProviderEventsPagePrefill = useAppStore(
    (state) => state.clearProviderEventsPagePrefill
  );
  const setProviderEventsPagePrefill = useAppStore(
    (state) => state.setProviderEventsPagePrefill
  );
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const openEvidencePage = useAppStore((state) => state.openEvidencePage);
  const lastAppliedPrefillNonce = useRef<number | null>(null);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [providerNameFilter, setProviderNameFilter] = useState<string>("");
  const [providerMessageIdFilter, setProviderMessageIdFilter] = useState<string>("");
  const [externalStatusFilter, setExternalStatusFilter] = useState<string>("");
  const [wabaFilter, setWabaFilter] = useState<string>("");
  const [phoneNumberFilter, setPhoneNumberFilter] = useState<string>("");
  const [replayFilter, setReplayFilter] = useState<ReplayFilter>("pending");
  const [runtimeFilter, setRuntimeFilter] = useState<RuntimeFilter>("ALL");
  const [state, setState] = useState<ProviderEventsState>(EMPTY_STATE);
  const [selectedEventId, setSelectedEventId] = useState("");
  const [selectedSubscriptionId, setSelectedSubscriptionId] = useState("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);

  const providerItems = state.provider?.items ?? [];
  const selectedEvent = useMemo(
    () => providerItems.find((item) => item.id === selectedEventId) ?? null,
    [providerItems, selectedEventId]
  );
  const selectedSubscription = useMemo(
    () => state.subscriptions.find((item) => item.id === selectedSubscriptionId) ?? null,
    [selectedSubscriptionId, state.subscriptions]
  );

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!providerEventsPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === providerEventsPagePrefill.nonce) {
      return;
    }

    lastAppliedPrefillNonce.current = providerEventsPagePrefill.nonce;
    setAccountFilter(providerEventsPagePrefill.account_id ?? "ALL");
    setProviderNameFilter(providerEventsPagePrefill.provider_name ?? "");
    setProviderMessageIdFilter(providerEventsPagePrefill.provider_message_id ?? "");
    setExternalStatusFilter(providerEventsPagePrefill.external_status ?? "");
    setWabaFilter(providerEventsPagePrefill.waba_id ?? "");
    setPhoneNumberFilter(providerEventsPagePrefill.phone_number_id ?? "");
    setReplayFilter(providerEventsPagePrefill.replay_state ?? "pending");
    setRuntimeFilter(
      (providerEventsPagePrefill.webhook_runtime_status as RuntimeFilter | undefined) ?? "ALL"
    );
    clearProviderEventsPagePrefill();
  }, [clearProviderEventsPagePrefill, providerEventsPagePrefill]);

  useEffect(() => {
    setProviderEventsPagePrefill({
      account_id: accountFilter,
      provider_name: providerNameFilter,
      provider_message_id: providerMessageIdFilter,
      external_status: externalStatusFilter,
      replay_state: replayFilter === "ALL" ? undefined : replayFilter,
      waba_id: wabaFilter,
      phone_number_id: phoneNumberFilter,
      webhook_runtime_status: runtimeFilter === "ALL" ? undefined : runtimeFilter,
    });
  }, [
    accountFilter,
    externalStatusFilter,
    phoneNumberFilter,
    providerMessageIdFilter,
    providerNameFilter,
    replayFilter,
    runtimeFilter,
    setProviderEventsPagePrefill,
    wabaFilter,
  ]);

  useEffect(() => {
    void loadPage();
  }, [
    accountFilter,
    externalStatusFilter,
    phoneNumberFilter,
    providerMessageIdFilter,
    providerNameFilter,
    replayFilter,
    runtimeFilter,
    wabaFilter,
  ]);

  useEffect(() => {
    if (!providerItems.length) {
      setSelectedEventId("");
      return;
    }
    if (selectedEventId && providerItems.some((item) => item.id === selectedEventId)) {
      return;
    }
    setSelectedEventId(providerItems[0].id);
  }, [providerItems, selectedEventId]);

  useEffect(() => {
    if (!state.subscriptions.length) {
      setSelectedSubscriptionId("");
      return;
    }
    if (
      selectedSubscriptionId &&
      state.subscriptions.some((item) => item.id === selectedSubscriptionId)
    ) {
      return;
    }
    setSelectedSubscriptionId(state.subscriptions[0].id);
  }, [selectedSubscriptionId, state.subscriptions]);

  async function loadPage(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      const [provider, subscriptions] = await Promise.all([
        listProviderStatusBuffer({
          account_id: accountFilter !== "ALL" ? accountFilter : undefined,
          provider_name: providerNameFilter || undefined,
          provider_message_id: providerMessageIdFilter || undefined,
          external_status: externalStatusFilter || undefined,
          replay_state: replayFilter !== "ALL" ? replayFilter : undefined,
          waba_id: wabaFilter || undefined,
          phone_number_id: phoneNumberFilter || undefined,
          limit: 100,
        }),
        listMetaWebhookSubscriptions({
          account_id: accountFilter !== "ALL" ? accountFilter : undefined,
          waba_id: wabaFilter || undefined,
          webhook_runtime_status: runtimeFilter !== "ALL" ? runtimeFilter : undefined,
        }),
      ]);

      setState({ provider, subscriptions });
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "������������ʧ��");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleReplay(record: ProviderStatusBufferEntry): Promise<void> {
    setPendingAction(`replay:${record.id}`);
    setError(null);
    try {
      await replayProviderStatusBuffer({
        account_id: record.account_id,
        provider_name: record.provider_name,
        provider_message_id: record.provider_message_id,
        external_status: record.external_status,
        waba_id: record.waba_id ?? undefined,
        phone_number_id: record.phone_number_id ?? undefined,
        limit: 1,
      });
      await loadPage();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "״̬����ʧ��");
      setPendingAction(null);
    }
  }

  const webhookAnomalyCount = useMemo(
    () =>
      state.subscriptions.filter(
        (item) =>
          item.webhook_runtime_status !== "healthy" &&
          item.webhook_runtime_status !== "pending"
      ).length,
    [state.subscriptions]
  );

  const signatureFailureTotal = useMemo(
    () =>
      state.subscriptions.reduce(
        (total, item) => total + item.webhook_signature_failure_count,
        0
      ),
    [state.subscriptions]
  );

  const providerColumns: ProColumns<ProviderStatusBufferEntry>[] = [
    {
      title: "����",
      dataIndex: "account_id",
    },
    {
      title: "ͨ��",
      dataIndex: "provider_name",
    },
    {
      title: "����״̬",
      dataIndex: "external_status",
    },
    {
      title: "����״̬",
      render: (_, record) => (
        <Tag color={getReplayColor(record.replay_state)}>{record.replay_state}</Tag>
      ),
    },
    {
      title: "��Ϣ ID",
      dataIndex: "provider_message_id",
      ellipsis: true,
    },
    {
      title: "����ʱ��",
      render: (_, record) => formatTimestamp(record.occurred_at ?? record.last_seen_at),
    },
    {
      title: "����",
      render: (_, record) =>
        record.replay_state === "pending" ? (
          <Button
            size="small"
            loading={pendingAction === `replay:${record.id}`}
            onClick={() => void handleReplay(record)}
          >
            ����
          </Button>
        ) : null,
    },
  ];

  const subscriptionColumns: ProColumns<MetaWebhookSubscriptionView>[] = [
    {
      title: "����",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.account_display_name}</Typography.Text>
          <Typography.Text type="secondary">{record.account_id}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "WABA",
      dataIndex: "waba_id",
      ellipsis: true,
    },
    {
      title: "����״̬",
      render: (_, record) => (
        <Tag color={getWebhookStatusColor(record.status)}>{record.status}</Tag>
      ),
    },
    {
      title: "����̬",
      render: (_, record) => (
        <Tag color={getRuntimeStatusColor(record.webhook_runtime_status)}>
          {record.webhook_runtime_status}
        </Tag>
      ),
    },
    {
      title: "��������",
      render: (_, record) => formatTimestamp(record.webhook_last_event_received_at),
    },
    {
      title: "ǩ��ʧ��",
      dataIndex: "webhook_signature_failure_count",
    },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 180 }}
            value={accountFilter}
            options={[
              { label: "ȫ������", value: "ALL" },
              ...actorAccountIds.map((item) => ({ label: item, value: item })),
            ]}
            onChange={setAccountFilter}
          />
          <Select
            style={{ width: 160 }}
            value={replayFilter}
            options={[
              { label: "ȫ������״̬", value: "ALL" },
              { label: "������", value: "pending" },
              { label: "������", value: "replayed" },
            ]}
            onChange={(value) => setReplayFilter(value)}
          />
          <Select
            style={{ width: 180 }}
            value={runtimeFilter}
            options={[
              { label: "ȫ�� Webhook ����̬", value: "ALL" },
              { label: "healthy", value: "healthy" },
              { label: "pending", value: "pending" },
              { label: "verification_pending", value: "verification_pending" },
              { label: "signature_failed", value: "signature_failed" },
              { label: "payload_invalid", value: "payload_invalid" },
            ]}
            onChange={(value) => setRuntimeFilter(value)}
          />
          <Button
            onClick={() =>
              openEvidencePage({
                account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                source_kind: "provider",
              })
            }
          >
            ֤������
          </Button>
          <Button loading={loading} onClick={() => void loadPage()} type="primary">
            ˢ��
          </Button>
        </Space>
        <Space size={[12, 12]} wrap style={{ marginTop: 12 }}>
          <Select
            allowClear
            placeholder="ͨ��"
            style={{ width: 180 }}
            value={providerNameFilter || undefined}
            onChange={(value) => setProviderNameFilter(value ?? "")}
            options={Array.from(new Set(providerItems.map((item) => item.provider_name))).map((item) => ({
              label: item,
              value: item,
            }))}
          />
          <Select
            allowClear
            placeholder="����״̬"
            style={{ width: 180 }}
            value={externalStatusFilter || undefined}
            onChange={(value) => setExternalStatusFilter(value ?? "")}
            options={Array.from(new Set(providerItems.map((item) => item.external_status))).map((item) => ({
              label: item,
              value: item,
            }))}
          />
          <Select
            allowClear
            placeholder="WABA"
            style={{ width: 220 }}
            value={wabaFilter || undefined}
            onChange={(value) => setWabaFilter(value ?? "")}
            options={Array.from(
              new Set(
                [
                  ...providerItems.map((item) => item.waba_id).filter(Boolean),
                  ...state.subscriptions.map((item) => item.waba_id),
                ] as string[]
              )
            ).map((item) => ({ label: item, value: item }))}
          />
          <Select
            allowClear
            placeholder="����"
            style={{ width: 220 }}
            value={phoneNumberFilter || undefined}
            onChange={(value) => setPhoneNumberFilter(value ?? "")}
            options={Array.from(
              new Set(providerItems.map((item) => item.phone_number_id).filter(Boolean) as string[])
            ).map((item) => ({ label: item, value: item }))}
          />
          <Select
            allowClear
            showSearch
            placeholder="��Ϣ ID"
            style={{ width: 260 }}
            value={providerMessageIdFilter || undefined}
            onChange={(value) => setProviderMessageIdFilter(value ?? "")}
            options={Array.from(
              new Set(providerItems.map((item) => item.provider_message_id))
            ).map((item) => ({ label: item, value: item }))}
          />
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="״̬����" value={state.provider?.returned_count ?? 0} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="������" value={state.provider?.pending_count ?? 0} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="Webhook ����" value={state.subscriptions.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}>
            <Statistic title="ǩ��ʧ��" value={signatureFailureTotal} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <Card title="ͨ��״̬����">
            <ProTable<ProviderStatusBufferEntry>
              columns={providerColumns}
              dataSource={providerItems}
              loading={loading}
              options={false}
              pagination={{ pageSize: 8 }}
              rowKey="id"
              search={false}
              toolBarRender={false}
              onRow={(record) => ({
                onClick: () => setSelectedEventId(record.id),
              })}
            />
          </Card>
        </Col>
        <Col lg={10} xs={24}>
          <Card title="��������">
            {selectedEvent ? (
              <Space direction="vertical" size={16} style={{ width: "100%" }}>
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="����">{selectedEvent.account_id}</Descriptions.Item>
                  <Descriptions.Item label="ͨ��">{selectedEvent.provider_name}</Descriptions.Item>
                  <Descriptions.Item label="WABA">{selectedEvent.waba_id ?? "-"}</Descriptions.Item>
                  <Descriptions.Item label="����">{selectedEvent.phone_number_id ?? "-"}</Descriptions.Item>
                  <Descriptions.Item label="��Ϣ ID">
                    {selectedEvent.provider_message_id}
                  </Descriptions.Item>
                  <Descriptions.Item label="����״̬">
                    {selectedEvent.external_status}
                  </Descriptions.Item>
                  <Descriptions.Item label="����״̬">
                    <Tag color={getReplayColor(selectedEvent.replay_state)}>
                      {selectedEvent.replay_state}
                    </Tag>
                  </Descriptions.Item>
                  <Descriptions.Item label="����ʱ��">
                    {formatTimestamp(selectedEvent.occurred_at)}
                  </Descriptions.Item>
                  <Descriptions.Item label="����д��">
                    {formatTimestamp(selectedEvent.first_seen_at)}
                  </Descriptions.Item>
                  <Descriptions.Item label="����д��">
                    {formatTimestamp(selectedEvent.last_seen_at)}
                  </Descriptions.Item>
                  <Descriptions.Item label="��������">{selectedEvent.seen_count}</Descriptions.Item>
                  <Descriptions.Item label="������ʱ��">
                    {selectedEvent.pending_age_seconds}s
                  </Descriptions.Item>
                  <Descriptions.Item label="������">
                    {selectedEvent.error_code ?? "-"}
                  </Descriptions.Item>
                  <Descriptions.Item label="��������">
                    {selectedEvent.replay_error ?? "-"}
                  </Descriptions.Item>
                </Descriptions>
                <Space wrap>
                  {selectedEvent.replay_state === "pending" ? (
                    <Button
                      loading={pendingAction === `replay:${selectedEvent.id}`}
                      onClick={() => void handleReplay(selectedEvent)}
                      type="primary"
                    >
                      ������ǰ����
                    </Button>
                  ) : null}
                  <Button
                    onClick={() =>
                      openAuditPage({
                        account_id: selectedEvent.account_id,
                        limit: 50,
                      })
                    }
                  >
                    ����
                  </Button>
                </Space>
              </Space>
            ) : (
              <Typography.Text type="secondary">��������</Typography.Text>
            )}
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <Card
            title="Webhook ����"
            extra={<Tag color={webhookAnomalyCount > 0 ? "error" : "success"}>{`���� ${webhookAnomalyCount}`}</Tag>}
          >
            <ProTable<MetaWebhookSubscriptionView>
              columns={subscriptionColumns}
              dataSource={state.subscriptions}
              loading={loading}
              options={false}
              pagination={{ pageSize: 8 }}
              rowKey="id"
              search={false}
              toolBarRender={false}
              onRow={(record) => ({
                onClick: () => setSelectedSubscriptionId(record.id),
              })}
            />
          </Card>
        </Col>
        <Col lg={10} xs={24}>
          <Card title="��������">
            {selectedSubscription ? (
              <Table<{
                key: string;
                label: string;
                value: string | number | JSX.Element;
              }>
                columns={[
                  { title: "����", dataIndex: "label", width: 140 },
                  { title: "ֵ", dataIndex: "value" },
                ]}
                dataSource={[
                  { key: "account", label: "����", value: selectedSubscription.account_display_name },
                  { key: "account-id", label: "account_id", value: selectedSubscription.account_id },
                  { key: "waba", label: "WABA", value: selectedSubscription.waba_id },
                  { key: "callback", label: "������ַ", value: selectedSubscription.callback_url },
                  { key: "verify-path", label: "У��·��", value: selectedSubscription.webhook_verify_path },
                  { key: "receive-path", label: "����·��", value: selectedSubscription.webhook_receive_path },
                  {
                    key: "status",
                    label: "����״̬",
                    value: (
                      <Tag color={getWebhookStatusColor(selectedSubscription.status)}>
                        {selectedSubscription.status}
                      </Tag>
                    ),
                  },
                  {
                    key: "runtime",
                    label: "����̬",
                    value: (
                      <Tag color={getRuntimeStatusColor(selectedSubscription.webhook_runtime_status)}>
                        {selectedSubscription.webhook_runtime_status}
                      </Tag>
                    ),
                  },
                  {
                    key: "verify-status",
                    label: "У��״̬",
                    value: selectedSubscription.webhook_verification_status,
                  },
                  {
                    key: "last-event",
                    label: "��������",
                    value: formatTimestamp(selectedSubscription.webhook_last_event_received_at),
                  },
                  {
                    key: "last-message",
                    label: "������Ϣ",
                    value: formatTimestamp(selectedSubscription.webhook_last_message_received_at),
                  },
                  {
                    key: "last-status",
                    label: "����״̬����",
                    value: formatTimestamp(selectedSubscription.webhook_last_status_update_at),
                  },
                  {
                    key: "signature-failed",
                    label: "ǩ��ʧ����",
                    value: selectedSubscription.webhook_signature_failure_count,
                  },
                  {
                    key: "runtime-error",
                    label: "��������",
                    value: selectedSubscription.webhook_runtime_error ?? "-",
                  },
                ]}
                pagination={false}
                rowKey="key"
                size="small"
              />
            ) : (
              <Typography.Text type="secondary">��������</Typography.Text>
            )}
          </Card>
        </Col>
      </Row>
    </Space>
  );
}

import { useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Input,
  Row,
  Select,
  Space,
  Statistic,
  Tag,
  Typography,
} from "antd";

import {
  assignConversation,
  getConversationAiStatus,
  listAgentWorkloads,
  listConversations,
  listRuntimeAgents,
  setConversationManagementMode,
  type AgentWorkload,
  type ConversationAiStatus,
  type ConversationSummary,
  type ManagementMode,
  type RuntimeAgent,
} from "../services/api";
import {
  resolveCustomerProfileSummaryByConversation,
} from "../services/operations";
import { useMemberStatus } from "../hooks/useMemberStatus";
import { useAppStore } from "../stores/appStore";
import type { CustomerProfileSummary } from "../types/operations";

type ManagementModeFilter = "all" | ManagementMode;
type HandoverRecommendationFilter = "all" | "recommended" | "normal";

function formatTimestamp(value: string | null): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function formatManagementMode(mode: string): string {
  if (mode === "ai_managed") return "AI ���";
  if (mode === "human_managed") return "��������";
  if (mode === "paused") return "��ͣ";
  return mode;
}

function formatAiDecision(status: ConversationAiStatus | null): string {
  if (!status) return "加载�?;
  if (status.effective_ai_enabled) return "�€����������AI �����";
  if (status.primary_blocking_reason) {
    return `�€����������AI ����� / ${status.primary_blocking_reason.message}`;
  }
  if (status.blocking_reasons.length > 0) {
    return `�€����������AI ����� / ${status.blocking_reasons[0].message}`;
  }
  return "�€����������AI �����";
}

function getManagementModeColor(mode: string): string {
  if (mode === "ai_managed") return "processing";
  if (mode === "human_managed") return "warning";
  if (mode === "paused") return "default";
  return "default";
}

function getStatusLabel(status: RuntimeAgent["status"]): string {
  if (status === "online") return "����";
  if (status === "busy") return "���";
  if (status === "away") return "����";
  return "����";
}

function getStatusColor(status: RuntimeAgent["status"]): string {
  if (status === "online") return "success";
  if (status === "busy") return "warning";
  if (status === "away") return "processing";
  return "default";
}

function getHandoverRecommendationColor(recommended: boolean): string {
  return recommended ? "volcano" : "default";
}

function getVerificationStatusColor(status: string): string {
  if (status === "approved") return "success";
  if (status === "rejected") return "error";
  if (status === "submitted" || status === "under_review") return "processing";
  return "default";
}

function getBindingStatusColor(status: string): string {
  if (status === "bound" || status === "approved") return "success";
  if (status === "failed" || status === "rejected") return "error";
  if (status === "submitted" || status === "pending" || status === "verifying") return "processing";
  return "default";
}

function formatHandoverRecommendation(recommended: boolean): string {
  return recommended ? "���������? : "�€�����?;
}

function matchesSearch(conversation: ConversationSummary, keyword: string): boolean {
  if (!keyword.trim()) return true;
  const content = [
    conversation.account_id,
    conversation.conversation_id,
    conversation.customer_id,
    conversation.assigned_agent_name ?? "",
    conversation.latest_intent_name ?? "",
    conversation.last_message_preview ?? "",
    conversation.latest_handover_reason ?? "",
  ]
    .join(" ")
    .toLowerCase();
  return content.includes(keyword.trim().toLowerCase());
}

export function AssignmentsPage(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const consoleAgentId = useAppStore((state) => state.consoleAgentId);
  const openCustomersPage = useAppStore((state) => state.openCustomersPage);
  const openWorkspacePage = useAppStore((state) => state.openWorkspacePage);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [managementModeFilter, setManagementModeFilter] =
    useState<ManagementModeFilter>("all");
  const [handoverRecommendationFilter, setHandoverRecommendationFilter] =
    useState<HandoverRecommendationFilter>("all");
  const [assignedAgentFilter, setAssignedAgentFilter] = useState<string>("ALL");
  const [search, setSearch] = useState("");
  const [conversations, setConversations] = useState<ConversationSummary[]>([]);
  const [agents, setAgents] = useState<RuntimeAgent[]>([]);
  const [workloads, setWorkloads] = useState<AgentWorkload[]>([]);
  const [selectedConversationKey, setSelectedConversationKey] = useState("");
  const [assignAgentId, setAssignAgentId] = useState("");
  const [actionReason, setActionReason] = useState("");
  const [aiStatus, setAiStatus] = useState<ConversationAiStatus | null>(null);
  const {
    memberStatus,
    memberStatusLoading,
    memberStatusError,
    latestVerification,
    latestBinding,
    loadMemberStatus,
    resetMemberStatus,
  } = useMemberStatus();
  const [resolvedCustomerProfile, setResolvedCustomerProfile] =
    useState<CustomerProfileSummary | null>(null);
  const [loading, setLoading] = useState(false);
  const [detailLoading, setDetailLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const accountOptions = useMemo(() => {
    const values = new Set<string>();
    actorAccountIds.forEach((item) => item && values.add(item));
    conversations.forEach((item) => values.add(item.account_id));
    agents.forEach((item) => item.account_id && values.add(item.account_id));
    return Array.from(values).sort();
  }, [actorAccountIds, conversations, agents]);

  const workloadMap = useMemo(
    () => new Map(workloads.map((item) => [item.agent_id, item])),
    [workloads]
  );

  const filteredConversations = useMemo(() => {
    return conversations.filter((conversation) => {
      if (
        assignedAgentFilter !== "ALL" &&
        (conversation.assigned_agent_id ?? "__unassigned__") !== assignedAgentFilter
      ) {
        return false;
      }
      return matchesSearch(conversation, search);
    });
  }, [assignedAgentFilter, conversations, search]);

  const selectedConversation = useMemo(
    () =>
      filteredConversations.find(
        (item) => `${item.account_id}:${item.conversation_id}` === selectedConversationKey
      ) ?? null,
    [filteredConversations, selectedConversationKey]
  );

  const assignableAgents = useMemo(() => {
    if (!selectedConversation) return [];
    return agents.filter(
      (agent) =>
        agent.is_active &&
        (agent.account_id === null || agent.account_id === selectedConversation.account_id)
    );
  }, [agents, selectedConversation]);

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    void loadScope();
  }, [accountFilter, handoverRecommendationFilter, managementModeFilter]);

  useEffect(() => {
    if (!filteredConversations.length) {
      setSelectedConversationKey("");
      return;
    }
    if (
      selectedConversationKey &&
      filteredConversations.some(
        (item) => `${item.account_id}:${item.conversation_id}` === selectedConversationKey
      )
    ) {
      return;
    }
    setSelectedConversationKey(
      `${filteredConversations[0].account_id}:${filteredConversations[0].conversation_id}`
    );
  }, [filteredConversations, selectedConversationKey]);

  useEffect(() => {
    if (!selectedConversation) {
      setAiStatus(null);
      setAssignAgentId("");
      return;
    }
    setAssignAgentId(selectedConversation.assigned_agent_id ?? "");
    void loadAiStatus(selectedConversation.account_id, selectedConversation.conversation_id);
  }, [selectedConversation]);

  useEffect(() => {
    if (!selectedConversation) {
      setResolvedCustomerProfile(null);
      resetMemberStatus();
      return;
    }
    void loadConversationCustomerContext(selectedConversation);
  }, [
    selectedConversation?.account_id,
    selectedConversation?.conversation_id,
    selectedConversation?.customer_id,
  ]);

  async function loadScope(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      const params =
        accountFilter !== "ALL" ||
        managementModeFilter !== "all" ||
        handoverRecommendationFilter !== "all"
          ? {
              account_id: accountFilter !== "ALL" ? accountFilter : undefined,
              management_mode:
                managementModeFilter !== "all" ? managementModeFilter : undefined,
              latest_handover_recommended:
                handoverRecommendationFilter === "all"
                  ? undefined
                  : handoverRecommendationFilter === "recommended",
            }
          : undefined;

      const [nextConversations, nextAgents, nextWorkloads] = await Promise.all([
        listConversations(params),
        listRuntimeAgents(undefined, accountFilter !== "ALL" ? accountFilter : undefined),
        listAgentWorkloads(undefined, accountFilter !== "ALL" ? accountFilter : undefined),
      ]);
      setConversations(nextConversations);
      setAgents(nextAgents);
      setWorkloads(nextWorkloads);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "����������������ʧ��");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function loadAiStatus(accountId: string, conversationId: string): Promise<void> {
    setDetailLoading(true);
    try {
      setAiStatus(await getConversationAiStatus(accountId, conversationId));
    } catch (loadError) {
      setAiStatus(null);
      setError(loadError instanceof Error ? loadError.message : "AI ���€����������?);
    } finally {
      setDetailLoading(false);
    }
  }

  async function loadConversationCustomerContext(
    conversation: ConversationSummary
  ): Promise<void> {
    try {
      const profile = await resolveCustomerProfileSummaryByConversation({
        account_id: conversation.account_id,
        customer_id: conversation.customer_id,
      });
      setResolvedCustomerProfile(profile);

      if (profile) {
        await loadMemberStatus(profile);
      } else {
        resetMemberStatus();
      }
    } catch (loadError) {
      setResolvedCustomerProfile(null);
      resetMemberStatus();
    }
  }

  async function handleAssignConversation(): Promise<void> {
    if (!selectedConversation || !assignAgentId) return;
    setPendingAction("assign");
    setError(null);
    setNotice(null);
    try {
      await assignConversation(selectedConversation.account_id, selectedConversation.conversation_id, {
        agent_id: assignAgentId,
        assigned_by_agent_id: consoleAgentId,
        reason: actionReason.trim() || undefined,
      });
      setNotice("会话分配已更�?);
      await loadScope();
      await loadAiStatus(selectedConversation.account_id, selectedConversation.conversation_id);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "��������ʧ��");
      setPendingAction(null);
    }
  }

  async function handleManagementModeChange(mode: ManagementMode): Promise<void> {
    if (!selectedConversation) return;
    setPendingAction(`mode:${mode}`);
    setError(null);
    setNotice(null);
    try {
      await setConversationManagementMode(
        selectedConversation.account_id,
        selectedConversation.conversation_id,
        {
          management_mode: mode,
          agent_id: assignAgentId || selectedConversation.assigned_agent_id || undefined,
          reason: actionReason.trim() || undefined,
        }
      );
      setNotice(`������������������${formatManagementMode(mode)}`);
      await loadScope();
      await loadAiStatus(selectedConversation.account_id, selectedConversation.conversation_id);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "����ģʽ����ʧ��");
      setPendingAction(null);
    }
  }

  function handleOpenWorkspace(): void {
    if (!selectedConversation) return;
    openWorkspacePage({
      accountId: selectedConversation.account_id,
      conversationKey: selectedConversation.conversation_id,
      handoverMode: handoverRecommendationFilter,
      managementMode: managementModeFilter,
      search: search.trim() || undefined,
    });
  }

  const columns: ProColumns<ConversationSummary>[] = [
    {
      title: "���� / ����",
      key: "conversation",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.customer_id}</Typography.Text>
          <Typography.Text type="secondary">{record.conversation_id}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "����",
      dataIndex: "account_id",
    },
    {
      title: "����",
      render: (_, record) => record.assigned_agent_name ?? "����?,
    },
    {
      title: "ģʽ",
      render: (_, record) => (
        <Tag color={getManagementModeColor(record.management_mode)}>
          {formatManagementMode(record.management_mode)}
        </Tag>
      ),
    },
    {
      title: "������",
      render: (_, record) => (
        <Tag color={getHandoverRecommendationColor(record.latest_handover_recommended)}>
          {formatHandoverRecommendation(record.latest_handover_recommended)}
        </Tag>
      ),
    },
    {
      title: "AI",
      render: (_, record) => (
        <Tag color={record.ai_enabled ? "processing" : "default"}>
          {record.ai_enabled ? "AI �€�? : "AI �����"}
        </Tag>
      ),
    },
    {
      title: "�€������?,
      render: (_, record) => record.last_message_preview ?? "����",
    },
  ];



  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}

      <Card>
        <Space align="center" size={[12, 12]} wrap>
                    <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={[
              { label: "ȫ������", value: "ALL" },
              ...accountOptions.map((item) => ({ label: item, value: item })),
            ]}
            onChange={setAccountFilter}
          />
          <Select
            style={{ width: 180 }}
            value={managementModeFilter}
            options={[
              { label: "ȫ��ģʽ", value: "all" },
              { label: "AI ���", value: "ai_managed" },
              { label: "��������", value: "human_managed" },
              { label: "��ͣ", value: "paused" },
            ]}
            onChange={(value) => setManagementModeFilter(value)}
          />
          <Select
            style={{ width: 180 }}
            value={handoverRecommendationFilter}
            options={[
              { label: "�����������", value: "all" },
              { label: "������ת����", value: "recommended" },
              { label: "仅普ͨ会�?, value: "normal" },
            ]}
            onChange={(value) => setHandoverRecommendationFilter(value)}
          />
          <Select
            style={{ width: 220 }}
            value={assignedAgentFilter}
            options={[
              { label: "ȫ����ϯ", value: "ALL" },
              { label: "����?, value: "__unassigned__" },
              ...agents.map((item) => ({
                label: item.display_name,
                value: item.agent_id,
              })),
            ]}
            onChange={setAssignedAgentFilter}
          />
          <Input.Search
            allowClear
            style={{ width: 260 }}
            placeholder="�������� / ���� / ��ͼ"
            value={search}
            onChange={(event) => setSearch(event.target.value)}
          />
          <Button loading={loading} onClick={() => void loadScope()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={8} xs={24}>
          <Card>
            <Statistic
              title="待分�?
              value={filteredConversations.filter((item) => !item.assigned_agent_id).length}
              valueStyle={{ color: "var(--ant-color-warning, #faad14)" }}
            />
          </Card>
        </Col>
        <Col lg={6} md={8} xs={24}>
          <Card>
            <Statistic
              title="已分�?
              value={filteredConversations.filter((item) => item.assigned_agent_id).length}
            />
          </Card>
        </Col>
        <Col lg={6} md={8} xs={24}>
          <Card>
            <Statistic
              title="������ϯ"
              value={agents.filter((item) => item.status === "online" && item.is_active).length}
              valueStyle={{ color: "var(--ant-color-success, #52c41a)" }}
            />
          </Card>
        </Col>
        <Col lg={6} md={8} xs={24}>
          <Card>
            <Statistic
              title="���������?
              value={
                filteredConversations.filter((item) => item.latest_handover_recommended).length
              }
              valueStyle={{ color: "var(--ant-color-warning, #faad14)" }}
            />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<ConversationSummary>
            columns={columns}
            dataSource={filteredConversations}
            loading={loading}
            options={false}
            pagination={{ pageSize: 8 }}
            rowKey={(record) => `${record.account_id}:${record.conversation_id}`}
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () =>
                setSelectedConversationKey(`${record.account_id}:${record.conversation_id}`),
            })}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="��������" loading={detailLoading}>
              {selectedConversation ? (
                <Space direction="vertical" size={16} style={{ width: "100%" }}>
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="����">
                      {selectedConversation.account_id}
                    </Descriptions.Item>
                    <Descriptions.Item label="����">
                      {selectedConversation.conversation_id}
                    </Descriptions.Item>
                    <Descriptions.Item label="����">
                      {selectedConversation.customer_id}
                    </Descriptions.Item>
                    <Descriptions.Item label="��ǰ����">
                      {selectedConversation.assigned_agent_name ?? "����?}
                    </Descriptions.Item>
                    <Descriptions.Item label="����ģʽ">
                      <Tag color={getManagementModeColor(selectedConversation.management_mode)}>
                        {formatManagementMode(selectedConversation.management_mode)}
                      </Tag>
                    </Descriptions.Item>
                    <Descriptions.Item label="������">
                      <Tag
                        color={getHandoverRecommendationColor(
                          selectedConversation.latest_handover_recommended
                        )}
                      >
                        {formatHandoverRecommendation(
                          selectedConversation.latest_handover_recommended
                        )}
                      </Tag>
                    </Descriptions.Item>
                    <Descriptions.Item label="AI ��Ч">
                      {formatAiDecision(aiStatus)}
                    </Descriptions.Item>
                    <Descriptions.Item label="�€���������?>
                      {formatTimestamp(selectedConversation.last_message_at)}
                    </Descriptions.Item>
                    <Descriptions.Item label="��������">
                      {selectedConversation.latest_handover_reason ?? "����"}
                    </Descriptions.Item>
                  </Descriptions>

                  <Space direction="vertical" size={12} style={{ width: "100%" }}>
                    <Select
                      value={assignAgentId || undefined}
                      placeholder="ѡ����ϯ"
                      options={[
                        ...assignableAgents.map((agent) => {
                          const workload = workloadMap.get(agent.agent_id);
                          return {
                            label: `${agent.display_name} / ${getStatusLabel(agent.status)} / ${
                              workload?.assigned_open_conversations ?? 0
                            } open`,
                            value: agent.agent_id,
                          };
                        }),
                      ]}
                      onChange={setAssignAgentId}
                    />
                    <Input.TextArea
                      rows={3}
                      placeholder="������ע"
                      value={actionReason}
                      onChange={(event) => setActionReason(event.target.value)}
                    />
                    <Space size={[8, 8]} wrap>
                      <Button
                        loading={pendingAction === "assign"}
                        onClick={() => void handleAssignConversation()}
                        type="primary"
                      >
                        {selectedConversation?.assigned_agent_id ? "����������" : "������"}
                      </Button>
                      {selectedConversation?.assigned_agent_id ? (
                        <Button
                          danger
                          disabled={pendingAction !== null}
                          onClick={() => {
                            setAssignAgentId("");
                            void handleAssignConversation();
                          }}
                        >
                          ȡ������
                        </Button>
                      ) : null}
                      <Button
                        loading={pendingAction === "mode:human_managed"}
                        onClick={() => void handleManagementModeChange("human_managed")}
                      >
                        ��������
                      </Button>
                      <Button
                        loading={pendingAction === "mode:ai_managed"}
                        onClick={() => void handleManagementModeChange("ai_managed")}
                      >
                        ��� AI
                      </Button>
                      <Button
                        loading={pendingAction === "mode:paused"}
                        onClick={() => void handleManagementModeChange("paused")}
                      >
                        ��ͣ����
                      </Button>
                      <Button
                        onClick={() =>
                          openCustomersPage({
                            account_id: selectedConversation.account_id,
                            selected_profile_id: resolvedCustomerProfile?.id,
                            query:
                              resolvedCustomerProfile?.public_user_id ??
                              selectedConversation.customer_id,
                          })
                        }
                      >
                        客户�?                      </Button>
                      <Button onClick={handleOpenWorkspace}>打开工作�?/Button>
                    </Space>
                  </Space>
                  {memberStatusError ? (
                    <Alert message={memberStatusError} showIcon type="warning" />
                  ) : null}
                  <Row gutter={[16, 16]}>
                    <Col lg={12} xs={24}>
                      <Card size="small" title="�������������€? extra={<Tag color="blue">API</Tag>}>
                        <Space direction="vertical" size={12} style={{ width: "100%" }}>
                          {memberStatusLoading ? (
                            <Typography.Text type="secondary">加载�?/Typography.Text>
                          ) : latestVerification ? (
                            <>
                              <Descriptions bordered column={1} size="small">
                                <Descriptions.Item label="���€?>
                                  <Tag color={getVerificationStatusColor(latestVerification.status)}>
                                    {latestVerification.status}
                                  </Tag>
                                </Descriptions.Item>
                                <Descriptions.Item label="��֤����">
                                  {latestVerification.requestType}
                                </Descriptions.Item>
                                <Descriptions.Item label="������ע">
                                  {latestVerification.reviewNote ?? latestVerification.notes ?? "����"}
                                </Descriptions.Item>
                                <Descriptions.Item label="�€�����������?>
                                  {formatTimestamp(latestVerification.updatedAt)}
                                </Descriptions.Item>
                              </Descriptions>
                              <Typography.Text type="secondary">
                                认֤记¼ {memberStatus?.verificationRequests.length ?? 0} �?                              </Typography.Text>
                            </>
                          ) : resolvedCustomerProfile ? (
                            <Typography.Text type="secondary">������Ա��֤��¼</Typography.Text>
                          ) : (
                            <Typography.Text type="secondary">
                              ��������������������������
                            </Typography.Text>
                          )}
                        </Space>
                      </Card>
                    </Col>
                    <Col lg={12} xs={24}>
                      <Card size="small" title="WhatsApp ��������€? extra={<Tag color="blue">API</Tag>}>
                        <Space direction="vertical" size={12} style={{ width: "100%" }}>
                          {memberStatusLoading ? (
                            <Typography.Text type="secondary">加载�?/Typography.Text>
                          ) : latestBinding ? (
                            <>
                              <Descriptions bordered column={1} size="small">
                                <Descriptions.Item label="���€?>
                                  <Tag color={getBindingStatusColor(latestBinding.status)}>
                                    {latestBinding.status}
                                  </Tag>
                                </Descriptions.Item>
                                <Descriptions.Item label="��������">
                                  {latestBinding.requestedPhoneNumber ?? "����"}
                                </Descriptions.Item>
                                <Descriptions.Item label="ʧ��ԭ��">
                                  {latestBinding.lastError ?? "����"}
                                </Descriptions.Item>
                                <Descriptions.Item label="�€�����������?>
                                  {formatTimestamp(latestBinding.updatedAt)}
                                </Descriptions.Item>
                              </Descriptions>
                              <Typography.Text type="secondary">
                                绑定记¼ {memberStatus?.bindingRequests.length ?? 0} �?                              </Typography.Text>
                            </>
                          ) : resolvedCustomerProfile ? (
                            <Typography.Text type="secondary">���� WhatsApp ������¼</Typography.Text>
                          ) : (
                            <Typography.Text type="secondary">
                              ��������������������������
                            </Typography.Text>
                          )}
                        </Space>
                      </Card>
                    </Col>
                  </Row>
                </Space>
              ) : (
                <Typography.Text type="secondary">��������</Typography.Text>
              )}
            </Card>

            <Card title="��ϯ����">
              <Space direction="vertical" size={12} style={{ width: "100%" }}>
                {assignableAgents.length > 0 ? (
                  assignableAgents.map((agent) => {
                    const workload = workloadMap.get(agent.agent_id);
                    return (
                      <Card key={agent.agent_id} size="small">
                        <Space style={{ justifyContent: "space-between", width: "100%" }} wrap>
                          <Space direction="vertical" size={0}>
                            <Typography.Text strong>{agent.display_name}</Typography.Text>
                            <Typography.Text type="secondary">{agent.agent_id}</Typography.Text>
                          </Space>
                          <Space size={[6, 6]} wrap>
                            <Tag color={getStatusColor(agent.status)}>{agent.status}</Tag>
                            <Tag>{`${workload?.assigned_open_conversations ?? 0} open`}</Tag>
                            <Tag>{`${workload?.assigned_total_conversations ?? 0} total`}</Tag>
                          </Space>
                        </Space>
                      </Card>
                    );
                  })
                ) : (
                  <Typography.Text type="secondary">��������������?/Typography.Text>
                )}
              </Space>
            </Card>
          </Space>
        </Col>
      </Row>
    </Space>
  );
}


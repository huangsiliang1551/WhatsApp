import { useCallback, useEffect, useMemo, useRef, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  Modal,
  Row,
  Select,
  Space,
  Statistic,
  Tag,
  Typography,
  message,
} from "antd";

import { BatchActionBar, type BatchAction } from "../components/BatchActionBar";
import { useAppStore } from "../stores/appStore";
import {
  createTemplateDraft,
  getTemplateStatsSummary,
  listMediaAssets,
  listMessageTemplates,
  listMetaAccounts,
  listTemplateDailyStats,
  listTemplateSendLogs,
  rebuildTemplateStats,
  sendTemplateMessage,
  submitTemplate,
  syncTemplates,
  updateTemplateDraft,
  updateTemplateStatus,
  type MediaAssetView,
  type MessageTemplateView,
  type MetaWabaAccount,
  type TemplateCategory,
  type TemplateSendLogView,
  type TemplateSendStatus,
  type TemplateStatsDailyRow,
  type TemplateStatsSummary,
  type TemplateStatus,
} from "../services/api";

type TemplateFilters = {
  account_id: string;
  waba_id: string;
  status: "ALL" | TemplateStatus;
  language: string;
};

type DraftFormValues = {
  account_id: string;
  waba_id?: string;
  name: string;
  language: string;
  category: TemplateCategory;
  header_text?: string;
  header_media_asset_id?: string;
  header_media_handle?: string;
  body_text: string;
  footer_text?: string;
  sample_variables_text?: string;
};

type StatusFormValues = {
  status: TemplateStatus;
  meta_template_id?: string;
  rejected_reason?: string;
};

type SendFormValues = {
  account_id: string;
  conversation_id: string;
  phone_number_id?: string;
  agent_id?: string;
  idempotency_key?: string;
  variables_text?: string;
};

type SyncFormValues = {
  account_id: string;
  waba_id: string;
  import_missing?: boolean;
};

const TEMPLATE_CATEGORY_OPTIONS = [
  { value: "UTILITY", label: "֪ͨ����" },
  { value: "MARKETING", label: "Ӫ��" },
  { value: "AUTHENTICATION", label: "��֤" },
] as const;

const TEMPLATE_STATUS_OPTIONS = [
  { value: "DRAFT", label: "���" },
  { value: "PENDING", label: "����? },
  { value: "APPROVED", label: "����ͨ��" },
  { value: "REJECTED", label: "��������" },
  { value: "DISABLED", label: "已ͣ�? },
  { value: "PAUSED", label: "已暂�? },
] as const;

const TEMPLATE_SEND_STATUS_OPTIONS = [
  { value: "QUEUED", label: "已入�? },
  { value: "SENT", label: "已发�? },
  { value: "DELIVERED", label: "���€����" },
  { value: "READ", label: "���" },
  { value: "FAILED", label: "���€�����? },
] as const;

const EMPTY_STATS: TemplateStatsSummary = {
  send_count: 0,
  delivered_count: 0,
  delivery_rate: 0,
  read_count: 0,
  read_rate: 0,
  read_rate_by_send: 0,
  failed_count: 0,
  billable_count: 0,
  estimated_cost: 0,
  estimated_cost_status: "not_applicable",
  estimated_cost_note: null,
};

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function formatLanguage(value: string): string {
  return value.replace("_", "-").toUpperCase();
}

function formatPercent(value: number): string {
  return `${(value * 100).toFixed(1)}%`;
}

function formatOptional(value: string | null | undefined, fallback = "����"): string {
  return value?.trim() ? value : fallback;
}

function formatCategory(category: TemplateCategory): string {
  if (category === "UTILITY") return "֪ͨ����";
  if (category === "MARKETING") return "Ӫ��";
  return "��֤";
}

function formatStatus(status: TemplateStatus): string {
  if (status === "APPROVED") return "����ͨ��";
  if (status === "PENDING") return "����?;
  if (status === "REJECTED") return "��������";
  if (status === "DRAFT") return "���";
  if (status === "DISABLED") return "已ͣ�?;
  return "已暂�?;
}

function formatSendStatus(status: TemplateSendStatus): string {
  const matched = TEMPLATE_SEND_STATUS_OPTIONS.find((item) => item.value === status);
  return matched?.label ?? status;
}

function getStatusColor(status: TemplateStatus): string {
  if (status === "APPROVED") return "success";
  if (status === "REJECTED") return "error";
  if (status === "PENDING") return "processing";
  if (status === "PAUSED") return "warning";
  return "default";
}

function getSendStatusColor(status: TemplateSendStatus): string {
  if (status === "FAILED") return "error";
  if (status === "READ" || status === "DELIVERED") return "success";
  if (status === "SENT") return "processing";
  return "default";
}

function parseVariables(text: string): Record<string, string> {
  const variables: Record<string, string> = {};
  const lines = text
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean);

  lines.forEach((line) => {
    const separator = line.indexOf("=");
    if (separator <= 0) {
      throw new Error("变量格ʽ必须�?key=value");
    }
    const key = line.slice(0, separator).trim();
    const value = line.slice(separator + 1).trim();
    variables[key] = value;
  });

  return variables;
}

function stringifyVariables(variables: Record<string, string>): string {
  return Object.entries(variables)
    .map(([key, value]) => `${key}=${value}`)
    .join("\n");
}

export function TemplatePage(): JSX.Element {
  const openWorkspacePage = useAppStore((state) => state.openWorkspacePage);
  const openAuditPage = useAppStore((state) => state.openAuditPage);
  const templatePagePrefill = useAppStore((state) => state.templatePagePrefill);
  const clearTemplatePagePrefill = useAppStore((state) => state.clearTemplatePagePrefill);
  const setTemplatePagePrefill = useAppStore((state) => state.setTemplatePagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);

  const [accounts, setAccounts] = useState<MetaWabaAccount[]>([]);
  const [templates, setTemplates] = useState<MessageTemplateView[]>([]);
  const [mediaAssets, setMediaAssets] = useState<MediaAssetView[]>([]);
  const [dailyStats, setDailyStats] = useState<TemplateStatsDailyRow[]>([]);
  const [sendLogs, setSendLogs] = useState<TemplateSendLogView[]>([]);
  const [statsSummary, setStatsSummary] = useState<TemplateStatsSummary>(EMPTY_STATS);
  const [filters, setFilters] = useState<TemplateFilters>({
    account_id: "ALL",
    waba_id: "ALL",
    status: "ALL",
    language: "",
  });
  const [selectedTemplateId, setSelectedTemplateId] = useState<string>("");
  const [selectedRowKeys, setSelectedRowKeys] = useState<React.Key[]>([]);
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const [templateSelectionLocked, setTemplateSelectionLocked] = useState(false);

  const selectedTemplate = useMemo(
    () => templates.find((item) => item.template_id === selectedTemplateId) ?? null,
    [selectedTemplateId, templates]
  );

  const accountOptions = useMemo(
    () => Array.from(new Set(accounts.map((item) => item.account_id))).sort(),
    [accounts]
  );

  const wabaOptions = useMemo(() => {
    const items = accounts.filter((item) => filters.account_id === "ALL" || item.account_id === filters.account_id);
    return Array.from(new Set(items.map((item) => item.waba_id))).sort();
  }, [accounts, filters.account_id]);

  const headerMediaOptions = useMemo(() => {
    if (!selectedTemplate) return [];
    return mediaAssets
      .filter((item) => item.account_id === selectedTemplate.account_id && item.is_active)
      .map((item) => ({
        label: `${item.name} / ${item.asset_type}`,
        value: item.asset_id,
      }));
  }, [mediaAssets, selectedTemplate]);

  useEffect(() => {
    void refreshData();
  }, [filters.account_id, filters.waba_id, filters.status, filters.language]);

  useEffect(() => {
    if (!templatePagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === templatePagePrefill.nonce) {
      return;
    }

    lastAppliedPrefillNonce.current = templatePagePrefill.nonce;
    setFilters({
      account_id: templatePagePrefill.account_id ?? "ALL",
      waba_id: templatePagePrefill.waba_id ?? "ALL",
      status: templatePagePrefill.status ?? "ALL",
      language: templatePagePrefill.language ?? "",
    });
    setTemplateSelectionLocked(Boolean(templatePagePrefill.selected_template_id));
    setSelectedTemplateId(templatePagePrefill.selected_template_id ?? "");
    clearTemplatePagePrefill();
  }, [clearTemplatePagePrefill, templatePagePrefill]);

  useEffect(() => {
    if (!templates.length) {
      if (!templateSelectionLocked) {
        setSelectedTemplateId("");
      }
      return;
    }
    if (selectedTemplateId && templates.some((item) => item.template_id === selectedTemplateId)) {
      return;
    }
    if (templateSelectionLocked && selectedTemplateId) {
      return;
    }
    setSelectedTemplateId(templates[0].template_id);
  }, [selectedTemplateId, templateSelectionLocked, templates]);

  useEffect(() => {
    setTemplatePagePrefill({
      account_id: filters.account_id,
      waba_id: filters.waba_id,
      status: filters.status,
      language: filters.language || undefined,
      selected_template_id: selectedTemplateId || undefined,
    });
  }, [
    filters.account_id,
    filters.language,
    filters.status,
    filters.waba_id,
    selectedTemplateId,
    setTemplatePagePrefill,
  ]);

  async function refreshData(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      const accountId = filters.account_id !== "ALL" ? filters.account_id : undefined;
      const wabaId = filters.waba_id !== "ALL" ? filters.waba_id : undefined;
      const status = filters.status !== "ALL" ? filters.status : undefined;
      const language = filters.language.trim() || undefined;

      const [nextAccounts, nextTemplates, nextMediaAssets, nextSummary, nextDailyStats, nextSendLogs] =
        await Promise.all([
          listMetaAccounts(),
          listMessageTemplates(accountId, wabaId, { status, language }),
          listMediaAssets(accountId ? { account_id: accountId, is_active: true } : { is_active: true }),
          getTemplateStatsSummary({
            account_id: accountId,
            waba_id: wabaId,
            language,
          }),
          listTemplateDailyStats({
            account_id: accountId,
            waba_id: wabaId,
            language,
          }),
          listTemplateSendLogs({
            account_id: accountId,
            waba_id: wabaId,
            limit: 20,
          }),
        ]);

      setAccounts(nextAccounts);
      setTemplates(nextTemplates);
      setMediaAssets(nextMediaAssets);
      setStatsSummary(nextSummary);
      setDailyStats(nextDailyStats);
      setSendLogs(nextSendLogs);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "ģ板ҳ加载ʧ�?);
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  // ��������
  const handleBatchDelete = useCallback(async (ids: string[]) => {
    await Promise.allSettled(ids.map((id) => updateTemplateStatus(id, { status: "DISABLED" })));
    message.success(`������?${ids.length} �����`);
    setSelectedRowKeys([]);
    await refreshData();
  }, [refreshData]);

  const handleBatchSubmit = useCallback(async (ids: string[]) => {
    let success = 0;
    for (const id of ids) {
      try { await submitTemplate(id); success++; } catch { /* ����ʧ������ */ }
    }
    message.success(`������?${success}/${ids.length} �����`);
    setSelectedRowKeys([]);
    await refreshData();
  }, [refreshData]);

  const batchActions: BatchAction[] = [
    { key: "batch-delete", label: "����ɾ��", danger: true, onClick: handleBatchDelete },
    { key: "batch-submit", label: "������������", onClick: handleBatchSubmit },
  ];

  async function handleCreateDraft(values: DraftFormValues): Promise<void> {
    setPendingAction("create-draft");
    setError(null);
    try {
      await createTemplateDraft({
        account_id: values.account_id.trim(),
        waba_id: values.waba_id?.trim() || undefined,
        name: values.name.trim(),
        language: values.language.trim(),
        category: values.category,
        header_text: values.header_text?.trim() || undefined,
        header_media_asset_id: values.header_media_asset_id || undefined,
        header_media_handle: values.header_media_handle?.trim() || undefined,
        body_text: values.body_text.trim(),
        footer_text: values.footer_text?.trim() || undefined,
        sample_variables: parseVariables(values.sample_variables_text ?? ""),
      });
      await refreshData();
      setNotice("��������������?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������������");
      setPendingAction(null);
    }
  }

  async function handleUpdateDraft(values: DraftFormValues): Promise<void> {
    if (!selectedTemplate) return;
    setPendingAction("update-draft");
    setError(null);
    try {
      await updateTemplateDraft(selectedTemplate.template_id, {
        waba_id: values.waba_id?.trim() || undefined,
        name: values.name.trim(),
        language: values.language.trim(),
        category: values.category,
        header_text: values.header_text?.trim() || undefined,
        header_media_asset_id: values.header_media_asset_id || undefined,
        header_media_handle: values.header_media_handle?.trim() || undefined,
        body_text: values.body_text.trim(),
        footer_text: values.footer_text?.trim() || undefined,
        sample_variables: parseVariables(values.sample_variables_text ?? ""),
      });
      await refreshData();
      setNotice("��������������?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������������");
      setPendingAction(null);
    }
  }

  async function handleUpdateStatus(values: StatusFormValues): Promise<void> {
    if (!selectedTemplate) return;
    setPendingAction("update-status");
    setError(null);
    try {
      await updateTemplateStatus(selectedTemplate.template_id, {
        status: values.status,
        meta_template_id: values.meta_template_id?.trim() || undefined,
        rejected_reason: values.rejected_reason?.trim() || undefined,
      });
      await refreshData();
      setNotice("��������€���������");
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������€�����?);
      setPendingAction(null);
    }
  }

  async function handleSubmitTemplate(): Promise<void> {
    if (!selectedTemplate) return;
    setPendingAction("submit-template");
    setError(null);
    try {
      await submitTemplate(selectedTemplate.template_id);
      await refreshData();
      setNotice("ģ板已提�?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "����ģ��ʧ��");
      setPendingAction(null);
    }
  }

  async function handleSyncTemplates(values: SyncFormValues): Promise<void> {
    setPendingAction("sync-templates");
    setError(null);
    try {
      await syncTemplates({
        account_id: values.account_id.trim(),
        waba_id: values.waba_id.trim(),
        import_missing: values.import_missing ?? true,
      });
      await refreshData();
      setNotice("��������������?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "�������������");
      setPendingAction(null);
    }
  }

  async function handleSendTemplate(values: SendFormValues): Promise<void> {
    if (!selectedTemplate) return;
    setPendingAction("send-template");
    setError(null);
    try {
      await sendTemplateMessage(selectedTemplate.template_id, {
        account_id: values.account_id.trim(),
        conversation_id: values.conversation_id.trim(),
        phone_number_id: values.phone_number_id?.trim() || undefined,
        agent_id: values.agent_id?.trim() || undefined,
        idempotency_key: values.idempotency_key?.trim() || undefined,
        variables: parseVariables(values.variables_text ?? ""),
      });
      await refreshData();
      setNotice("ģ板消Ϣ已发�?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "���€����������?);
      setPendingAction(null);
    }
  }

  async function handleRebuildStats(): Promise<void> {
    setPendingAction("rebuild-stats");
    setError(null);
    try {
      await rebuildTemplateStats({
        account_id: filters.account_id !== "ALL" ? filters.account_id : undefined,
        waba_id: filters.waba_id !== "ALL" ? filters.waba_id : undefined,
      });
      await refreshData();
      setNotice("��������������?);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������������");
      setPendingAction(null);
    }
  }

  const templateColumns: ProColumns<MessageTemplateView>[] = [
    {
      title: "ģ��",
      key: "template",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.name}</Typography.Text>
          <Typography.Text type="secondary">{`${record.account_id} / ${record.waba_id ?? "�?WABA"}`}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "��� / �����",
      render: (_, record) => `${formatLanguage(record.language)} / ${formatCategory(record.category)}`,
    },
    {
      title: "���€?,
      render: (_, record) => <Tag color={getStatusColor(record.status)}>{formatStatus(record.status)}</Tag>,
    },
    {
      title: "ͷ������",
      render: (_, record) => formatOptional(record.header_media_asset_name ?? record.header_media_asset_id),
    },
    {
      title: "����ʱ��",
      dataIndex: "updated_at",
      renderText: (value) => formatTimestamp(value),
    },
  ];

  const dailyColumns: ProColumns<TemplateStatsDailyRow>[] = [
    { title: "����", dataIndex: "date" },
    { title: "ģ��", dataIndex: "template_name" },
    { title: "����", dataIndex: "account_id" },
    { title: "WABA", render: (_, record) => record.waba_id ?? "����" },
    { title: "���€?, dataIndex: "send_count" },
    { title: "送达�?, render: (_, record) => formatPercent(record.delivery_rate) },
    { title: "����?, render: (_, record) => formatPercent(record.read_rate_by_send) },
    { title: "ʧ��", dataIndex: "failed_count" },
  ];

  const logColumns: ProColumns<TemplateSendLogView>[] = [
    {
      title: "ģ��",
      render: (_, record) => record.template_name ?? record.template_id ?? "��������",
    },
    { title: "����", dataIndex: "account_id" },
    { title: "����", render: (_, record) => record.external_conversation_id ?? record.conversation_id ?? "����" },
    {
      title: "���€?,
      render: (_, record) => <Tag color={getSendStatusColor(record.status)}>{formatSendStatus(record.status)}</Tag>,
    },
    { title: "����� ID", render: (_, record) => record.phone_number_id ?? "��������" },
    { title: "ʱ��", render: (_, record) => formatTimestamp(record.sent_at ?? record.created_at) },
    {
      title: "����",
      render: (_, record) => (
        <Space size={[8, 8]} wrap>
          {record.external_conversation_id ? (
            <Button
              size="small"
              onClick={() =>
                openWorkspacePage({
                  accountId: record.account_id,
                  conversationKey: `${record.account_id}:${record.external_conversation_id}`,
                  phoneNumberId: record.phone_number_id ?? undefined,
                })
              }
            >
              ��������
            </Button>
          ) : null}
          <Button
            size="small"
            onClick={() =>
              openAuditPage({
                account_id: record.account_id,
                phone_number_id: record.phone_number_id ?? undefined,
                target_type: "message_template",
                target_id: record.template_id ?? undefined,
                limit: 50,
              })
            }
          >
            ���
          </Button>
        </Space>
      ),
    },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={filters.account_id}
            options={[
              { label: "ȫ������", value: "ALL" },
              ...accountOptions.map((item) => ({ label: item, value: item })),
            ]}
            onChange={(value) => {
              setTemplateSelectionLocked(false);
              setFilters((current) => ({ ...current, account_id: value, waba_id: "ALL" }));
            }}
          />
          <Select
            style={{ width: 220 }}
            value={filters.waba_id}
            options={[
              { label: "ȫ�� WABA", value: "ALL" },
              ...wabaOptions.map((item) => ({ label: item, value: item })),
            ]}
            onChange={(value) => {
              setTemplateSelectionLocked(false);
              setFilters((current) => ({ ...current, waba_id: value }));
            }}
          />
          <Select
            style={{ width: 180 }}
            value={filters.status}
            options={[
              { label: "��������€?, value: "ALL" },
              ...TEMPLATE_STATUS_OPTIONS.map((item) => ({
                label: item.label,
                value: item.value,
              })),
            ]}
            onChange={(value) => {
              setTemplateSelectionLocked(false);
              setFilters((current) => ({ ...current, status: value }));
            }}
          />
          <Input
            style={{ width: 180 }}
            placeholder="������ zh_CN"
            value={filters.language}
            onChange={(event) => {
              setTemplateSelectionLocked(false);
              setFilters((current) => ({ ...current, language: event.target.value }));
            }}
          />
          <Button loading={loading} onClick={() => void refreshData()} type="primary">
            ˢ��
          </Button>
          <Button loading={pendingAction === "rebuild-stats"} onClick={() => void handleRebuildStats()}>
            ��������
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="���€��€����" value={statsSummary.send_count} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="送达�? value={formatPercent(statsSummary.delivery_rate)} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="����? value={formatPercent(statsSummary.read_rate_by_send)} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="ʧ败�? value={statsSummary.failed_count} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          {selectedRowKeys.length > 0 ? (
            <BatchActionBar
              actions={batchActions}
              selectedIds={selectedRowKeys.map(String)}
              onClearSelection={() => setSelectedRowKeys([])}
            />
          ) : null}
          <ProTable<MessageTemplateView>
            columns={templateColumns}
            dataSource={templates}
            loading={loading}
            options={false}
            pagination={{
              defaultPageSize: 20,
              pageSizeOptions: [20, 50, 100],
              showSizeChanger: true,
            }}
            scroll={{ y: 600 }}
            rowKey="template_id"
            search={false}
            toolBarRender={false}
            rowSelection={{
              selectedRowKeys,
              onChange: (keys) => setSelectedRowKeys(keys),
            }}
            onRow={(record) => ({
              onClick: () => {
                setTemplateSelectionLocked(false);
                setSelectedTemplateId(record.template_id);
              },
            })}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="ģ������">
              {templateSelectionLocked && selectedTemplateId && !selectedTemplate ? (
                <Alert message="��������������������������€�����? showIcon type="warning" />
              ) : null}
              {selectedTemplate ? (
                <Space direction="vertical" size={12} style={{ width: "100%" }}>
                  <Descriptions bordered column={1} size="small">
                    <Descriptions.Item label="ģ��">{selectedTemplate.name}</Descriptions.Item>
                    <Descriptions.Item label="����">{selectedTemplate.account_id}</Descriptions.Item>
                    <Descriptions.Item label="WABA">{selectedTemplate.waba_id ?? "����"}</Descriptions.Item>
                    <Descriptions.Item label="���€?>
                      <Tag color={getStatusColor(selectedTemplate.status)}>
                        {formatStatus(selectedTemplate.status)}
                      </Tag>
                      {selectedTemplate.status === "REJECTED" && selectedTemplate.rejected_reason ? (
                        <Typography.Text type="danger" style={{ fontSize: 12, marginLeft: 8 }}>
                          {selectedTemplate.rejected_reason}
                        </Typography.Text>
                      ) : null}
                    </Descriptions.Item>
                    <Descriptions.Item label="���">{formatLanguage(selectedTemplate.language)}</Descriptions.Item>
                    <Descriptions.Item label="����">{formatCategory(selectedTemplate.category)}</Descriptions.Item>
                    <Descriptions.Item label="ͷ������">
                      {formatOptional(selectedTemplate.header_media_asset_name ?? selectedTemplate.header_media_asset_id)}
                    </Descriptions.Item>
                    <Descriptions.Item label="����">{selectedTemplate.body_text}</Descriptions.Item>
                    {Object.keys(selectedTemplate.sample_variables).length > 0 ? (
                      <Descriptions.Item label="��������">
                        <Typography.Paragraph style={{ marginBottom: 0 }}>
                          {Object.entries(selectedTemplate.sample_variables).reduce(
                            (text, [key, value]) => text.replace(new RegExp(`{{${key}}}`, "g"), value),
                            selectedTemplate.body_text
                          )}
                        </Typography.Paragraph>
                      </Descriptions.Item>
                    ) : null}
                    <Descriptions.Item label="�€������?>
                      {formatTimestamp(selectedTemplate.last_synced_at)}
                    </Descriptions.Item>
                  </Descriptions>
                </Space>
              ) : (
                <Typography.Text type="secondary">�€���������</Typography.Text>
              )}
            </Card>

            <Card title="��������">
              {selectedTemplate ? (
                <Form
                  layout="vertical"
                  onFinish={(values) => void handleUpdateDraft(values)}
                  initialValues={{
                    account_id: selectedTemplate.account_id,
                    waba_id: selectedTemplate.waba_id ?? undefined,
                    name: selectedTemplate.name,
                    language: selectedTemplate.language,
                    category: selectedTemplate.category,
                    header_text: selectedTemplate.header_text ?? "",
                    header_media_asset_id: selectedTemplate.header_media_asset_id ?? undefined,
                    header_media_handle: selectedTemplate.header_media_handle ?? "",
                    body_text: selectedTemplate.body_text,
                    footer_text: selectedTemplate.footer_text ?? "",
                    sample_variables_text: stringifyVariables(selectedTemplate.sample_variables),
                  }}
                  key={selectedTemplate.template_id}
                >
                  <Form.Item label="����" name="name" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                  <Form.Item label="���" name="language" rules={[{ required: true }]}>
                    <Input />
                  </Form.Item>
                  <Form.Item label="����" name="category" rules={[{ required: true }]}>
                    <Select
                      options={TEMPLATE_CATEGORY_OPTIONS.map((item) => ({
                        label: item.label,
                        value: item.value,
                      }))}
                    />
                  </Form.Item>
                  <Form.Item label="ͷ������" name="header_text">
                    <Input />
                  </Form.Item>
                  <Form.Item label="ͷ������" name="header_media_asset_id">
                    <Select allowClear options={headerMediaOptions} />
                  </Form.Item>
                  <Form.Item label="����" name="body_text" rules={[{ required: true }]}>
                    <Input.TextArea rows={4} />
                  </Form.Item>
                  <Form.Item label="ҳ��" name="footer_text">
                    <Input />
                  </Form.Item>
                  <Form.Item label="����" name="sample_variables_text">
                    <Input.TextArea rows={4} placeholder="customer_name=����" />
                  </Form.Item>
                  <Button htmlType="submit" loading={pendingAction === "update-draft"} type="primary" block>
                    ��������
                  </Button>
                </Form>
              ) : (
                <Typography.Text type="secondary">暂无ѡ中ģ板�?/Typography.Text>
              )}
            </Card>
          </Space>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={8} xs={24}>
          <Card title="��������">
            <Form
              layout="vertical"
              initialValues={{
                account_id: accountOptions[0] ?? "demo-account-cn",
                language: "zh_CN",
                category: "UTILITY",
                name: "order_update_cn",
                body_text: "�������{{customer_name}}���������?{{order_id}} ������������������€?,
                sample_variables_text: "customer_name=����\norder_id=SO-10001",
              }}
              onFinish={(values) => void handleCreateDraft(values)}
            >
              <Form.Item label="����" name="account_id" rules={[{ required: true }]}>
                <Select options={accountOptions.map((item) => ({ label: item, value: item }))} />
              </Form.Item>
              <Form.Item label="WABA" name="waba_id">
                <Input />
              </Form.Item>
              <Form.Item label="����" name="name" rules={[{ required: true }]}>
                <Input />
              </Form.Item>
              <Form.Item label="���" name="language" rules={[{ required: true }]}>
                <Input />
              </Form.Item>
              <Form.Item label="����" name="category" rules={[{ required: true }]}>
                <Select
                  options={TEMPLATE_CATEGORY_OPTIONS.map((item) => ({
                    label: item.label,
                    value: item.value,
                  }))}
                />
              </Form.Item>
              <Form.Item label="����" name="body_text" rules={[{ required: true }]}>
                <Input.TextArea rows={4} />
              </Form.Item>
              <Form.Item label="����" name="sample_variables_text">
                <Input.TextArea rows={4} />
              </Form.Item>
              <Button htmlType="submit" loading={pendingAction === "create-draft"} type="primary" block>
                ��������
              </Button>
            </Form>
          </Card>
        </Col>

        <Col lg={8} xs={24}>
          <Card title="��������€�����?>
            <Space direction="vertical" size={16} style={{ width: "100%" }}>
              <Typography.Text type="secondary">
                ���������������������������������������������������€?
              </Typography.Text>
              <Form
                layout="vertical"
                onFinish={(values) => void handleUpdateStatus(values)}
                initialValues={{
                  status: selectedTemplate?.status ?? "DRAFT",
                  meta_template_id: selectedTemplate?.meta_template_id ?? "",
                  rejected_reason: selectedTemplate?.rejected_reason ?? "",
                }}
                key={selectedTemplate?.template_id ? `status-${selectedTemplate.template_id}` : "status-empty"}
              >
                <Form.Item label="���€? name="status" rules={[{ required: true }]}>
                  <Select
                    options={TEMPLATE_STATUS_OPTIONS.map((item) => ({
                      label: item.label,
                      value: item.value,
                    }))}
                  />
                </Form.Item>
                <Form.Item label="Meta ģ�� ID" name="meta_template_id">
                  <Input />
                </Form.Item>
                <Form.Item label="����ԭ��" name="rejected_reason">
                  <Input.TextArea rows={3} />
                </Form.Item>
                <Space size={[8, 8]} wrap>
                  <Button
                    htmlType="submit"
                    disabled={!selectedTemplate}
                    loading={pendingAction === "update-status"}
                    type="primary"
                  >
                    ��������€?
                  </Button>
                  <Button
                    disabled={!selectedTemplate}
                    loading={pendingAction === "submit-template"}
                    onClick={() => void handleSubmitTemplate()}
                  >
                    ��������
                  </Button>
                </Space>
              </Form>

              <Form
                layout="vertical"
                initialValues={{
                  account_id: accountOptions[0] ?? "demo-account-cn",
                  import_missing: true,
                }}
                onFinish={(values) => void handleSyncTemplates(values)}
              >
                <Form.Item label="����" name="account_id" rules={[{ required: true }]}>
                  <Select options={accountOptions.map((item) => ({ label: item, value: item }))} />
                </Form.Item>
                <Form.Item label="WABA" name="waba_id" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="����ȱʧģ��" name="import_missing">
                  <Select
                    options={[
                      { label: "�?, value: true },
                      { label: "�?, value: false },
                    ]}
                  />
                </Form.Item>
                <Button htmlType="submit" loading={pendingAction === "sync-templates"} block>
                  ��������
                </Button>
              </Form>
            </Space>
          </Card>
        </Col>

        <Col lg={8} xs={24}>
          <Card title="��������€�����?>
            <Space direction="vertical" size={12} style={{ width: "100%" }}>
              <Typography.Text type="secondary">
                ������€���������������������������€�������������?ID �����������������������������?ID �����������?ID�?
              </Typography.Text>
              <Typography.Text type="secondary">
                `conversation_id` ����������������€?
              </Typography.Text>
              <Form
                layout="vertical"
                onFinish={(values) => void handleSendTemplate(values)}
                initialValues={{
                  account_id: selectedTemplate?.account_id ?? accountOptions[0] ?? "demo-account-cn",
                  agent_id: "agent-cn-console",
                  variables_text: selectedTemplate ? stringifyVariables(selectedTemplate.sample_variables) : "",
                }}
                key={selectedTemplate?.template_id ? `send-${selectedTemplate.template_id}` : "send-empty"}
              >
                <Form.Item label="����" name="account_id" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="�������� ID" name="conversation_id" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="���� ID" name="phone_number_id">
                  <Input />
                </Form.Item>
                <Form.Item label="��ϯ ID" name="agent_id">
                  <Input />
                </Form.Item>
                <Form.Item label="幂等�? name="idempotency_key">
                  <Input />
                </Form.Item>
                <Form.Item label="����" name="variables_text">
                  <Input.TextArea rows={4} />
                </Form.Item>
                <Button
                  htmlType="submit"
                  disabled={!selectedTemplate}
                  loading={pendingAction === "send-template"}
                  type="primary"
                  block
                >
                  ���€����������?
                </Button>
              </Form>
            </Space>
          </Card>
        </Col>
      </Row>

      <Card title="��������">
        <ProTable<TemplateStatsDailyRow>
          columns={dailyColumns}
          dataSource={dailyStats}
          loading={loading}
          options={false}
          pagination={{ pageSize: 20 }}
          rowKey={(record) => `${record.date}:${record.account_id}:${record.template_name}`}
          search={false}
          toolBarRender={false}
          scroll={{ y: 400 }}
        />
      </Card>

      <Card title="���€�����?>
        <Typography.Paragraph type="secondary">
          ���€����������������������������������������?
        </Typography.Paragraph>
        <ProTable<TemplateSendLogView>
          columns={logColumns}
          dataSource={sendLogs}
          loading={loading}
          options={false}
          pagination={{ pageSize: 20 }}
          rowKey="id"
          search={false}
          toolBarRender={false}
          scroll={{ y: 400 }}
        />
      </Card>
    </Space>
  );
}


import { useEffect, useMemo, useState, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  Form,
  Input,
  Row,
  Select,
  Space,
  Statistic,
  Tag,
  Typography,
} from "antd";

import { createRiskProfile, getRiskCenterSnapshot, updateRiskProfileStatus } from "../services/operations";
import { useAppStore } from "../stores/appStore";
import type { RiskCaseItem, RiskCenterSnapshot, RiskProfileCreatePayload, RiskProfileItem } from "../types/operations";

type RiskFormValues = {
  account_id?: string;
  target_type: RiskProfileItem["target_type"];
  target_value: string;
  display_name: string;
  status: RiskProfileItem["status"];
  reason: string;
};

function getStatusColor(status: RiskProfileItem["status"]): string {
  if (status === "blocklist") return "error";
  if (status === "watchlist") return "warning";
  return "success";
}

function getStatusLabel(status: RiskProfileItem["status"]): string {
  if (status === "blocklist") return "黑名�?;
  if (status === "watchlist") return "��������";
  return "白名�?;
}

function formatTimestamp(value: string | null): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

export function RiskCenterPage(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const [form] = Form.useForm<RiskFormValues>();
  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [snapshot, setSnapshot] = useState<RiskCenterSnapshot | null>(null);
  const [selectedProfileId, setSelectedProfileId] = useState<string>("");
  const [loading, setLoading] = useState(false);
  const [pendingAction, setPendingAction] = useState<string | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);

  const selectedProfile = useMemo(
    () => snapshot?.profiles.find((item) => item.id === selectedProfileId) ?? null,
    [selectedProfileId, snapshot]
  );

  const allowCount = useMemo(
    () => snapshot?.profiles.filter((item) => item.status === "allow").length ?? 0,
    [snapshot]
  );
  const watchCount = useMemo(
    () => snapshot?.profiles.filter((item) => item.status === "watchlist").length ?? 0,
    [snapshot]
  );
  const blockCount = useMemo(
    () => snapshot?.profiles.filter((item) => item.status === "blocklist").length ?? 0,
    [snapshot]
  );
  const openCaseCount = useMemo(
    () => snapshot?.cases.filter((item) => item.status !== "closed").length ?? 0,
    [snapshot]
  );

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    void loadSnapshot();
  }, [accountFilter]);

  useEffect(() => {
    if (!snapshot?.profiles.length) {
      setSelectedProfileId("");
      return;
    }
    if (selectedProfileId && snapshot.profiles.some((item) => item.id === selectedProfileId)) {
      return;
    }
    setSelectedProfileId(snapshot.profiles[0].id);
  }, [selectedProfileId, snapshot]);

  useEffect(() => {
    form.setFieldValue("account_id", accountFilter !== "ALL" ? accountFilter : undefined);
  }, [accountFilter, form]);

  async function loadSnapshot(): Promise<void> {
    setLoading(true);
    setError(null);
    try {
      setSnapshot(await getRiskCenterSnapshot(accountFilter !== "ALL" ? accountFilter : undefined));
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "������������������");
    } finally {
      setLoading(false);
      setPendingAction(null);
    }
  }

  async function handleCreate(values: RiskFormValues): Promise<void> {
    setPendingAction("create");
    setError(null);
    setNotice(null);
    try {
      const payload: RiskProfileCreatePayload = {
        account_id: values.account_id?.trim() || null,
        target_type: values.target_type,
        target_value: values.target_value.trim(),
        display_name: values.display_name.trim(),
        status: values.status,
        reason: values.reason.trim(),
      };
      const created = await createRiskProfile(payload);
      setNotice(`����������������${created.display_name}`);
      form.resetFields();
      form.setFieldsValue({
        account_id: accountFilter !== "ALL" ? accountFilter : undefined,
        target_type: "customer",
        status: "watchlist",
      });
      await loadSnapshot();
      setSelectedProfileId(created.id);
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "������������ʧ��");
      setPendingAction(null);
    }
  }

  async function handleStatusChange(
    profile: RiskProfileItem,
    status: RiskProfileItem["status"]
  ): Promise<void> {
    setPendingAction(`${profile.id}:${status}`);
    setError(null);
    setNotice(null);
    try {
      await updateRiskProfileStatus(profile.id, status);
      setNotice(`��������€����������?{profile.display_name}`);
      await loadSnapshot();
    } catch (actionError) {
      setError(actionError instanceof Error ? actionError.message : "��������€����������?);
      setPendingAction(null);
    }
  }

  const profileColumns: ProColumns<RiskProfileItem>[] = [
    { title: "����", render: (_, record) => record.account_id ?? "ȫ��" },
    { title: "����", render: (_, record) => `${record.target_type} / ${record.target_value}` },
    { title: "����", dataIndex: "display_name" },
    {
      title: "���€?,
      render: (_, record) => (
        <Tag color={getStatusColor(record.status)}>{getStatusLabel(record.status)}</Tag>
      ),
    },
    { title: "7 天命�?, dataIndex: "hit_count_7d" },
    { title: "ԭ��", dataIndex: "reason", ellipsis: true },
  ];

  const caseColumns: ProColumns<RiskCaseItem>[] = [
    { title: "����", render: (_, record) => record.account_id ?? "ȫ��" },
    {
      title: "����",
      render: (_, record) => (
        <Tag
          color={
            record.severity === "high"
              ? "error"
              : record.severity === "medium"
                ? "warning"
                : "default"
          }
        >
          {record.severity}
        </Tag>
      ),
    },
    { title: "����", dataIndex: "category" },
    { title: "����", dataIndex: "target_value" },
    { title: "���", dataIndex: "summary", ellipsis: true },
    { title: "���€?, dataIndex: "status" },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}

      <Card>
        <Space align="center" size={[12, 12]} wrap>
                    <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={[
              { label: "ȫ������", value: "ALL" },
              ...actorAccountIds.map((item) => ({ label: item, value: item })),
            ]}
            onChange={setAccountFilter}
          />
          <Button loading={loading} onClick={() => void loadSnapshot()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}><Statistic title="��������" value={snapshot?.profiles.length ?? 0} /></Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}><Statistic title="白名�? value={allowCount} /></Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}><Statistic title="��������" value={watchCount} /></Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card loading={loading}><Statistic title="黑名�? value={blockCount} /></Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <Card title="��������">
            <ProTable<RiskProfileItem>
              columns={profileColumns}
              dataSource={snapshot?.profiles ?? []}
              loading={loading}
              options={false}
              pagination={{ pageSize: 8 }}
              rowKey="id"
              search={false}
              toolBarRender={false}
              onRow={(record) => ({
                onClick: () => setSelectedProfileId(record.id),
              })}
              expandable={{
                expandedRowRender: (record) => (
                  <Space size={[8, 8]} wrap>
                    <Button
                      size="small"
                      loading={pendingAction === `${record.id}:allow`}
                      onClick={() => void handleStatusChange(record, "allow")}
                    >
                      设Ϊ白名�?                    </Button>
                    <Button
                      size="small"
                      loading={pendingAction === `${record.id}:watchlist`}
                      onClick={() => void handleStatusChange(record, "watchlist")}
                    >
                      ��Ϊ��������
                    </Button>
                    <Button
                      danger
                      size="small"
                      loading={pendingAction === `${record.id}:blocklist`}
                      onClick={() => void handleStatusChange(record, "blocklist")}
                    >
                      设Ϊ黑名�?                    </Button>
                  </Space>
                ),
              }}
            />
          </Card>
        </Col>
        <Col lg={10} xs={24}>
          <Space direction="vertical" size={16} style={{ width: "100%" }}>
            <Card title="��������" extra={selectedProfile ? <Tag color="gold">ģ��</Tag> : null}>
              {selectedProfile ? (
                <Descriptions bordered column={1} size="small">
                  <Descriptions.Item label="����">{selectedProfile.account_id ?? "ȫ��"}</Descriptions.Item>
                  <Descriptions.Item label="��������">{selectedProfile.target_type}</Descriptions.Item>
                  <Descriptions.Item label="对象�?>{selectedProfile.target_value}</Descriptions.Item>
                  <Descriptions.Item label="��ʾ����">{selectedProfile.display_name}</Descriptions.Item>
                  <Descriptions.Item label="���€?>
                    <Tag color={getStatusColor(selectedProfile.status)}>
                      {getStatusLabel(selectedProfile.status)}
                    </Tag>
                  </Descriptions.Item>
                  <Descriptions.Item label="7 天命�?>{selectedProfile.hit_count_7d}</Descriptions.Item>
                  <Descriptions.Item label="�€������?>
                    {formatTimestamp(selectedProfile.last_hit_at)}
                  </Descriptions.Item>
                  <Descriptions.Item label="ԭ��">{selectedProfile.reason}</Descriptions.Item>
                </Descriptions>
              ) : (
                <Typography.Text type="secondary">��������</Typography.Text>
              )}
            </Card>

            <Card title="��������" extra={<Tag color="gold">ģ��</Tag>}>
              <Form<RiskFormValues>
                form={form}
                layout="vertical"
                initialValues={{
                  account_id: accountFilter !== "ALL" ? accountFilter : undefined,
                  target_type: "customer",
                  status: "watchlist",
                }}
                onFinish={(values) => void handleCreate(values)}
              >
                <Form.Item label="����" name="account_id">
                  <Select
                    allowClear
                    options={actorAccountIds.map((item) => ({ label: item, value: item }))}
                    placeholder="ѡ������"
                  />
                </Form.Item>
                <Form.Item label="��������" name="target_type" rules={[{ required: true }]}>
                  <Select
                    options={[
                      { label: "����", value: "customer" },
                      { label: "手机�?, value: "phone" },
                      { label: "WA ID", value: "wa_id" },
                      { label: "关键�?, value: "keyword" },
                    ]}
                  />
                </Form.Item>
                <Form.Item label="对象�? name="target_value" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="��ʾ����" name="display_name" rules={[{ required: true }]}>
                  <Input />
                </Form.Item>
                <Form.Item label="���€? name="status" rules={[{ required: true }]}>
                  <Select
                    options={[
                      { label: "白名�?, value: "allow" },
                      { label: "��������", value: "watchlist" },
                      { label: "黑名�?, value: "blocklist" },
                    ]}
                  />
                </Form.Item>
                <Form.Item label="ԭ��" name="reason" rules={[{ required: true }]}>
                  <Input.TextArea rows={4} />
                </Form.Item>
                <Button htmlType="submit" loading={pendingAction === "create"} type="primary" block>
                  ��������
                </Button>
              </Form>
            </Card>
          </Space>
        </Col>
      </Row>

      <Card title="��������" extra={<Tag color="gold">ģ��</Tag>}>
        <Space direction="vertical" size={16} style={{ width: "100%" }}>
          <Statistic title="�������? value={openCaseCount} />
          <ProTable<RiskCaseItem>
            columns={caseColumns}
            dataSource={snapshot?.cases ?? []}
            loading={loading}
            options={false}
            pagination={{ pageSize: 6 }}
            rowKey="id"
            search={false}
            toolBarRender={false}
          />
        </Space>
      </Card>
    </Space>
  );
}


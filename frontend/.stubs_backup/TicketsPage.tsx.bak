                        ]}
                      />
                    </Form.Item>
                    <Button htmlType="submit" disabled={Boolean(replyBlocker)} loading={pendingAction === "reply"} type="primary">
                      ���€�����?                    </Button>
                  </Form>
                </Card>
              </Col>
              <Col lg={12} xs={24}>
                <Card size="small" title="������ת">
                  <Form
                    key={`status:${detail.id}:${detail.status}`}
                    layout="vertical"
                    initialValues={{ status: allowedStatus[0], note: "" }}
                    onFinish={(values) => void handleStatusUpdate(values.status, values.note ?? "")}
                  >
                    <Form.Item label="���€? name="status">
                      <Select
                        disabled={allowedStatus.length === 0}
                        options={allowedStatus.map((status) => ({
                          label: getSupportTicketStatusLabel(status),
                          value: status,
                        }))}
                      />
                    </Form.Item>
                    <Form.Item label="��ע" name="note">
                      <Input.TextArea rows={4} disabled={allowedStatus.length === 0} />
                    </Form.Item>
                    <Button htmlType="submit" disabled={allowedStatus.length === 0} loading={pendingAction === "status"}>
                      ��������€?                    </Button>
                  </Form>
                </Card>
              </Col>
            </Row>
          </Space>
        ) : (
          <Typography.Text type="secondary">��������</Typography.Text>
        )}
      </Card>
    </Space>
  );
}


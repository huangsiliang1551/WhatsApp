              />
            </Card>

            <Row gutter={[16, 16]}>
              <Col lg={12} xs={24}>
                <Card size="small" title="��������">
                  <Form
                    key={`reply:${detail.id}`}
                    layout="vertical"
                    initialValues={{
                      sender_type: "agent",
                      sender_name: consoleAgentName,
                      content: "",
                      internal_only: false,
                    }}
                    onFinish={(values) => void handleReply(values)}
                  >
                    <Form.Item label="sender_type" name="sender_type">
                      <Select
                        disabled={Boolean(replyBlocker)}
                        options={[
                          { label: "agent", value: "agent" },
                          { label: "system", value: "system" },
                        ]}
                      />
                    </Form.Item>
                    <Form.Item label="sender_name" name="sender_name" rules={[{ required: true }]}>
                      <Input disabled={Boolean(replyBlocker)} />
                    </Form.Item>
                    <Form.Item label="content" name="content" rules={[{ required: true }]}>
                      <Input.TextArea rows={4} disabled={Boolean(replyBlocker)} />
                    </Form.Item>
                    <Form.Item label="internal_only" name="internal_only">
                      <Select
                        disabled={Boolean(replyBlocker)}
                        options={[
                          { label: "�?, value: false },

                            </Tag>
                          </Descriptions.Item>
                          <Descriptions.Item label="��֤����">{latestVerification.requestType}</Descriptions.Item>
                          <Descriptions.Item label="������ע">
                            {latestVerification.reviewNote ?? latestVerification.notes ?? "����"}
                          </Descriptions.Item>
                          <Descriptions.Item label="�€�����������?>
                            {formatTimestamp(latestVerification.updatedAt)}
                          </Descriptions.Item>
                        </Descriptions>
                        <Typography.Text type="secondary">
                          认֤记¼ {memberStatus?.verificationRequests.length ?? 0} �?                        </Typography.Text>
                      </>
                    ) : (
                      <Typography.Text type="secondary">������Ա��֤��¼</Typography.Text>
                    )}
                  </Space>
                </Card>
              </Col>

              <Col lg={12} xs={24}>
                <Card size="small" title="WhatsApp ��������€? extra={<Tag color="blue">API</Tag>}>
                  <Space direction="vertical" size={12} style={{ width: "100%" }}>
                    {memberStatusLoading ? (
                      <Typography.Text type="secondary">加载�?/Typography.Text>
                    ) : latestBinding ? (
                      <>
                        <Descriptions bordered column={1} size="small">
                          <Descriptions.Item label="���€?>
                            <Tag color={getBindingStatusColor(latestBinding.status)}>
                              {latestBinding.status}
                            </Tag>
                          </Descriptions.Item>
                          <Descriptions.Item label="��������">
                            {latestBinding.requestedPhoneNumber ?? "����"}
                          </Descriptions.Item>
                          <Descriptions.Item label="ʧ��ԭ��">
                            {latestBinding.lastError ?? "����"}
                          </Descriptions.Item>
                          <Descriptions.Item label="�€�����������?>
                            {formatTimestamp(latestBinding.updatedAt)}
                          </Descriptions.Item>
                        </Descriptions>
                        <Typography.Text type="secondary">
                          绑定记¼ {memberStatus?.bindingRequests.length ?? 0} �?                        </Typography.Text>
                      </>
                    ) : (
                      <Typography.Text type="secondary">���� WhatsApp ������¼</Typography.Text>
                    )}
                  </Space>
                </Card>
              </Col>
            </Row>

            <Card size="small" title="消Ϣʱ间�?>
              <Timeline
                items={detail.messages.map((message) => ({
                  children: (
                    <Space direction="vertical" size={2}>
                      <Typography.Text strong>{`${message.sender_name} / ${message.sender_type}`}</Typography.Text>
                      <Typography.Text>{message.content}</Typography.Text>
                      <Typography.Text type="secondary">
                        {`${formatTimestamp(message.created_at)}${message.internal_only ? " / 内部备注" : ""}`}
                      </Typography.Text>
                    </Space>
                  ),
                }))}
              />
            </Card>
            */}

            <Space size={[8, 8]} wrap>
              <Button
                size="small"
                onClick={() =>
                  openCustomersPage({
                    account_id: detail.account_id ?? undefined,
                    query: detail.public_user_id,
                  })
                }
              >
                客户�?              </Button>
            </Space>

            <Row gutter={[16, 16]}>
              <Col lg={12} xs={24}>
                <Card size="small" title="�������������€? extra={<Tag color="blue">API</Tag>}>
                  <Space direction="vertical" size={12} style={{ width: "100%" }}>
                    {memberStatusError ? <Alert message={memberStatusError} showIcon type="warning" /> : null}
                    {memberStatusLoading ? (
                      <Typography.Text type="secondary">加载�?/Typography.Text>
                    ) : latestVerification ? (
                      <>
                        <Descriptions bordered column={1} size="small">
                          <Descriptions.Item label="���€?>
                            <Tag color={getVerificationStatusColor(latestVerification.status)}>
                              {latestVerification.status}
                            </Tag>
                          </Descriptions.Item>
                          <Descriptions.Item label="��֤����">{latestVerification.requestType}</Descriptions.Item>
                          <Descriptions.Item label="������ע">
                            {latestVerification.reviewNote ?? latestVerification.notes ?? "����"}
                          </Descriptions.Item>
                          <Descriptions.Item label="�€������?>
                            {formatTimestamp(latestVerification.updatedAt)}

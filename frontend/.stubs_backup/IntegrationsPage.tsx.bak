import { lazy, useEffect, useMemo, useRef, useState, type ComponentType, type JSX } from "react";

import { ProTable, type ProColumns } from "@ant-design/pro-table";
import {
  Alert,
  Button,
  Card,
  Col,
  Descriptions,
  List,
  Row,
  Select,
  Space,
  Statistic,
  Tabs,
  Tag,
  Typography,
} from "antd";

const LazyApiWebhooksContent = lazy(() =>
  import("./ApiWebhooksPage").then((m) => ({ default: m.ApiWebhooksPage }))
);
const LazySitesContent = lazy(() =>
  import("./SitesPage").then((m) => ({ default: m.SitesPage }))
);

import { getIntegrationCenterSnapshot } from "../services/adminCenter";
import { useAppStore } from "../stores/appStore";
import type { IntegrationAccountSummary, IntegrationCenterSnapshot } from "../types/integrations";

function formatTimestamp(value: string | null | undefined): string {
  return value ? new Date(value).toLocaleString("zh-CN") : "����";
}

function getReadyTag(ready: boolean, okLabel = "已就�?, pendingLabel = "待补�?): JSX.Element {
  return <Tag color={ready ? "success" : "warning"}>{ready ? okLabel : pendingLabel}</Tag>;
}

function getRuntimeTag(status: string | null | undefined): JSX.Element {
  if (status === "healthy") return <Tag color="success">����</Tag>;
  if (status === "verification_pending" || status === "pending") {
    return <Tag color="warning">待验�?/Tag>;
  }
  if (!status) return <Tag>����</Tag>;
  return <Tag color="error">{status}</Tag>;
}

export function IntegrationsContent(): JSX.Element {
  const actorAccountIds = useAppStore((state) => state.actorAccountIds);
  const openSettingsPage = useAppStore((state) => state.openSettingsPage);
  const openMetaAccountsPage = useAppStore((state) => state.openMetaAccountsPage);
  const openProviderEventsPage = useAppStore((state) => state.openProviderEventsPage);
  const integrationsPagePrefill = useAppStore((state) => state.integrationsPagePrefill);
  const clearIntegrationsPagePrefill = useAppStore((state) => state.clearIntegrationsPagePrefill);
  const setIntegrationsPagePrefill = useAppStore((state) => state.setIntegrationsPagePrefill);
  const lastAppliedPrefillNonce = useRef<number | null>(null);

  const [accountFilter, setAccountFilter] = useState<string>("ALL");
  const [snapshot, setSnapshot] = useState<IntegrationCenterSnapshot | null>(null);
  const [selectedAccountKey, setSelectedAccountKey] = useState<string>("");
  const [selectionLocked, setSelectionLocked] = useState(false);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const [selectionWarning, setSelectionWarning] = useState<string | null>(null);

  const selectedAccount = useMemo(
    () => snapshot?.accounts.find((item) => `${item.account_id}:${item.waba_id}` === selectedAccountKey) ?? null,
    [selectedAccountKey, snapshot]
  );

  useEffect(() => {
    if (accountFilter === "ALL" && actorAccountIds.length === 1) {
      setAccountFilter(actorAccountIds[0]);
    }
  }, [accountFilter, actorAccountIds]);

  useEffect(() => {
    if (!integrationsPagePrefill) {
      return;
    }
    if (lastAppliedPrefillNonce.current === integrationsPagePrefill.nonce) {
      return;
    }
    lastAppliedPrefillNonce.current = integrationsPagePrefill.nonce;
    setAccountFilter(integrationsPagePrefill.account_id ?? "ALL");
    setSelectedAccountKey(integrationsPagePrefill.selected_account_key ?? "");
    setSelectionLocked(Boolean(integrationsPagePrefill.selected_account_key));
    setSelectionWarning(null);
    clearIntegrationsPagePrefill();
  }, [clearIntegrationsPagePrefill, integrationsPagePrefill]);

  useEffect(() => {
    void loadPage();
  }, [accountFilter]);

  useEffect(() => {
    if (!snapshot?.accounts.length) {
      setSelectedAccountKey("");
      if (selectionLocked) {
        setSelectionLocked(false);
      }
      return;
    }
    if (
      selectedAccountKey &&
      snapshot.accounts.some((item) => `${item.account_id}:${item.waba_id}` === selectedAccountKey)
    ) {
      return;
    }
    if (selectionLocked && selectedAccountKey) {
      setSelectionWarning("�������������������������������€�����?);
      setSelectionLocked(false);
      return;
    }
    setSelectionWarning(null);
    setSelectedAccountKey(`${snapshot.accounts[0].account_id}:${snapshot.accounts[0].waba_id}`);
  }, [selectedAccountKey, selectionLocked, snapshot]);

  useEffect(() => {
    setIntegrationsPagePrefill({
      account_id: accountFilter,
      selected_account_key: selectedAccountKey || undefined,
    });
  }, [accountFilter, selectedAccountKey, setIntegrationsPagePrefill]);

  async function loadPage(): Promise<void> {
    setLoading(true);
    setError(null);
    setNotice(null);
    try {
      const nextSnapshot = await getIntegrationCenterSnapshot(
        accountFilter !== "ALL" ? accountFilter : undefined
      );
      setSnapshot(nextSnapshot);
      setNotice(`已ˢ�?${formatTimestamp(nextSnapshot.generated_at)}`);
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "������������ʧ��");
    } finally {
      setLoading(false);
    }
  }

  const accountOptions = [
    { label: "ȫ������", value: "ALL" },
    ...actorAccountIds.map((item) => ({ label: item, value: item })),
  ];

  const accounts = snapshot?.accounts ?? [];
  const subscriptions = snapshot?.subscriptions ?? [];
  const signupSessions = snapshot?.signup_sessions ?? [];
  const readyWebhookCount = accounts.filter((item) => item.ready_for_webhook_delivery).length;
  const readyActivationCount = accounts.filter((item) => item.ready_for_formal_activation).length;
  const pendingSignupCount = signupSessions.filter((item) => item.status !== "completed").length;

  const columns: ProColumns<IntegrationAccountSummary>[] = [
    {
      title: "����",
      render: (_, record) => (
        <Space direction="vertical" size={0}>
          <Typography.Text strong>{record.display_name}</Typography.Text>
          <Typography.Text type="secondary">{record.account_id}</Typography.Text>
        </Space>
      ),
    },
    {
      title: "WABA",
      dataIndex: "waba_id",
      ellipsis: true,
    },
    {
      title: "Webhook",
      render: (_, record) => getRuntimeTag(record.webhook_runtime_status),
    },
    {
      title: "���€?,
      render: (_, record) => getReadyTag(record.ready_for_webhook_delivery),
    },
    {
      title: "��վ",
      render: (_, record) => getReadyTag(record.ready_for_outbound_messages),
    },
    {
      title: "������€�?,
      render: (_, record) => getReadyTag(record.ready_for_formal_activation, "����?, "������?),
    },
    {
      title: "�€�?Signup",
      render: (_, record) =>
        record.last_signup_status ? `${record.last_signup_status} / ${record.last_signup_stage}` : "����",
    },
  ];

  return (
    <Space direction="vertical" size={16} style={{ width: "100%" }}>
      {error ? <Alert message={error} showIcon type="error" /> : null}
      {selectionWarning ? <Alert message={selectionWarning} showIcon type="warning" /> : null}
      {notice ? <Alert message={notice} showIcon type="info" /> : null}
      {snapshot?.warnings.map((item) => (
        <Alert key={item} message={item} showIcon type="warning" />
      ))}
      
      <Card>
        <Space align="center" size={[12, 12]} wrap>
          <Select
            style={{ width: 220 }}
            value={accountFilter}
            options={accountOptions}
            onChange={(value) => {
              setSelectionLocked(false);
              setSelectionWarning(null);
              setAccountFilter(value);
            }}
          />
          <Button
            onClick={() =>
              openMetaAccountsPage({
                focused_account_id: accountFilter !== "ALL" ? accountFilter : undefined,
              })
            }
          >
            Meta ����
          </Button>
          <Button
            onClick={() =>
              openProviderEventsPage({
                account_id: accountFilter !== "ALL" ? accountFilter : undefined,
              })
            }
          >
            Webhook
          </Button>
          <Button
            onClick={() =>
              openSettingsPage({
                account_id: accountFilter !== "ALL" ? accountFilter : undefined,
              })
            }
          >
            ����
          </Button>
          <Button loading={loading} onClick={() => void loadPage()} type="primary">
            ˢ��
          </Button>
        </Space>
      </Card>

      <Row gutter={[16, 16]}>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="WABA" value={accounts.length} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="Webhook ����? value={readyWebhookCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="�������? value={readyActivationCount} />
          </Card>
        </Col>
        <Col lg={6} md={12} xs={24}>
          <Card>
            <Statistic title="����?Signup" value={pendingSignupCount} />
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={14} xs={24}>
          <ProTable<IntegrationAccountSummary>
            columns={columns}
            dataSource={accounts}
            loading={loading}
            options={false}
            pagination={{ pageSize: 6 }}
            rowKey={(record) => `${record.account_id}:${record.waba_id}`}
            search={false}
            toolBarRender={false}
            onRow={(record) => ({
              onClick: () => {
                setSelectionLocked(false);
                setSelectionWarning(null);
                setSelectedAccountKey(`${record.account_id}:${record.waba_id}`);
              },
            })}
          />
        </Col>

        <Col lg={10} xs={24}>
          <Card title="��ǰ����">
            {selectedAccount ? (
              <Descriptions bordered column={1} size="small">
                <Descriptions.Item label="����">{selectedAccount.account_id}</Descriptions.Item>
                <Descriptions.Item label="WABA">{selectedAccount.waba_id}</Descriptions.Item>
                <Descriptions.Item label="Portfolio">
                  {selectedAccount.meta_business_portfolio_id}
                </Descriptions.Item>
                <Descriptions.Item label="������ʽ">
                  {selectedAccount.onboarding_mode}
                </Descriptions.Item>
                <Descriptions.Item label="����">
                  {`${selectedAccount.registered_phone_number_count} / ${selectedAccount.phone_number_count}`}
                </Descriptions.Item>
                <Descriptions.Item label="Webhook">
                  <Space size={[8, 8]} wrap>
                    {getRuntimeTag(selectedAccount.webhook_runtime_status)}
                    <Tag>{selectedAccount.webhook_verification_status ?? "����"}</Tag>
                    <Tag>{selectedAccount.webhook_subscription_status ?? "����"}</Tag>
                  </Space>
                </Descriptions.Item>
                <Descriptions.Item label="������€�?>
                  {getReadyTag(selectedAccount.ready_for_formal_activation, "����?, "������?)}
                </Descriptions.Item>
                <Descriptions.Item label="���">
                  {selectedAccount.blocking_reasons.length ? (
                    <Space size={[8, 8]} wrap>
                      {selectedAccount.blocking_reasons.map((item) => (
                        <Tag key={`${selectedAccount.account_id}:${item}`} color="warning">
                          {item}
                        </Tag>
                      ))}
                    </Space>
                  ) : (
                    "����"
                  )}
                </Descriptions.Item>
              </Descriptions>
            ) : (
              <Typography.Text type="secondary">��������</Typography.Text>
            )}
          </Card>
        </Col>
      </Row>

      <Row gutter={[16, 16]}>
        <Col lg={12} xs={24}>
          <Card title="Webhook ����">
            <List
              dataSource={subscriptions}
              locale={{ emptyText: "��������" }}
              renderItem={(item) => (
                <List.Item>
                  <List.Item.Meta
                    description={
                      <Space direction="vertical" size={0}>
                        <Typography.Text type="secondary">
                          {`${item.account_id} / ${item.waba_id}`}
                        </Typography.Text>
                        <Typography.Text type="secondary">{item.callback_url}</Typography.Text>
                      </Space>
                    }
                    title={
                      <Space size={[8, 8]} wrap>
                        <span>{item.account_display_name}</span>
                        <Tag>{item.status}</Tag>
                        {getRuntimeTag(item.webhook_runtime_status)}
                      </Space>
                    }
                  />
                </List.Item>
              )}
            />
          </Card>
        </Col>

        <Col lg={12} xs={24}>
          <Card title="Embedded Signup">
            <List
              dataSource={signupSessions}
              locale={{ emptyText: "��������" }}
              renderItem={(item) => (
                <List.Item>
                  <List.Item.Meta
                    description={
                      <Space direction="vertical" size={0}>
                        <Typography.Text type="secondary">
                          {`${item.account_id} / ${item.waba_id ?? "���� WABA"}`}
                        </Typography.Text>
                        <Typography.Text type="secondary">
                          {formatTimestamp(item.completed_at ?? item.callback_received_at)}
                        </Typography.Text>
                      </Space>
                    }
                    title={
                      <Space size={[8, 8]} wrap>
                        <span>{item.display_name}</span>
                        <Tag>{item.status}</Tag>
                        <Tag>{item.completion_stage}</Tag>
                      </Space>
                    }
                  />
                </List.Item>
              )}
            />
          </Card>
        </Col>
      </Row>
    </Space>
  );
}

export function IntegrationsPage(): JSX.Element {
  return (
    <Tabs
      defaultActiveKey="integrations"
      items={[
        { key: "integrations", label: "��������", children: <IntegrationsContent /> },
        { key: "webhooks", label: "API / Webhook", children: <LazyApiWebhooksContent /> },
        { key: "sites", label: "վ������", children: <LazySitesContent /> },
      ]}
    />
  );
}
